# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_erp?schema=public
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=your-secret-key-change-in-production
BETTER_AUTH_URL=http://localhost:4000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Email
RESEND_API_KEY=

# App
# NEXT_PUBLIC_APP_URL é a URL pública do frontend — aparece em emails (orçamento, pesquisa,
# notificação, BI público), redirects do Stripe, magic links etc. Em LAN, use o IP da rede
# (ex: http://192.168.0.58:3000). Em produção, use o domínio (ex: https://app.empresa.com).
NEXT_PUBLIC_APP_URL=http://192.168.0.58:3000
API_URL=http://localhost:4000

# Google Drive — sincronização automática de XMLs por cliente.
# Escolha UM dos 2 modos (OAuth tem precedência se ambos setados):
#
# MODO 1 — OAuth de usuário (recomendado se já tem app OAuth + token.pickle):
#   1. Rode: python scripts/extract-google-refresh-token.py
#   2. Cole as 2 linhas abaixo retornadas pelo script:
GOOGLE_DRIVE_OAUTH_CREDENTIALS_FILE=./google/credentials.json
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
#
# MODO 2 — Service Account (identidade do sistema, sem conta humana):
#   GOOGLE_DRIVE_SA_JSON_FILE: caminho pro arquivo JSON, OU
#   GOOGLE_DRIVE_SA_JSON: conteúdo inline (cru ou base64).
GOOGLE_DRIVE_SA_JSON_FILE=
GOOGLE_DRIVE_SA_JSON=
#
# Cron:
GOOGLE_DRIVE_SYNC_ENABLED=false
GOOGLE_DRIVE_SYNC_CRON=*/15 * * * *
