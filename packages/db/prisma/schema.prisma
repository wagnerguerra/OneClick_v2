model ClienteBiCategoria {
  id           String   @id @default(cuid())
  clienteId    String   @map("cliente_id")
  conta        String
  nomeSci      String   @default("") @map("nome_sci")
  nomeExibicao String   @default("") @map("nome_exibicao")
  parentConta  String?  @map("parent_conta")
  nivel        Int      @default(1)
  ordem        Int      @default(0)
  tipo         String   @default("real") // real | calculada | referencia
  ativo        Boolean  @default(true)
  formula      Json?
  // Override do template SERPRO2 — quando preenchidos, prevalecem sobre PlanoContasCategoriaPadrao
  // Valores possíveis: RECEITA_BRUTA, DEDUCOES_IMPOSTOS, CUSTO_DAS_VENDAS, DESPESAS_VARIAVEIS,
  // DESPESAS_OPERACIONAIS, RECEITAS_FINANCEIRAS, DESPESAS_FINANCEIRAS, IR_CS, DISTRIBUICAO_LUCROS
  categoriaDre String?  @map("categoria_dre")
