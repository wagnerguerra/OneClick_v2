  descricao           String   @default("")
  tipo                String // PROVENTO ou DESCONTO
  contaCustoDebito    Int?     @map("conta_custo_debito")
  contaCustoCredito   Int?     @map("conta_custo_credito")
  contaDespesaDebito  Int?     @map("conta_despesa_debito")
  contaDespesaCredito Int?     @map("conta_despesa_credito")
  geraLancamento      Boolean  @default(true) @map("gera_lancamento")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, codigoEvento, tipo])
  @@index([clienteId])
  @@map("folha_evento_contas")
}

model FolhaImportacao {
  id               String   @id @default(cuid())
  clienteId        String   @map("cliente_id")
  competencia      String // MM/AAAA
  dataImportacao   DateTime @default(now()) @map("data_importacao")
  arquivoOrigem    String?  @map("arquivo_origem")
  status           String   @default("importado") // importado, contabilizado, exportado
  totalLinhas      Int      @default(0) @map("total_linhas")
  totalLancamentos Int      @default(0) @map("total_lancamentos")
  erros            Json? // Eventos não encontrados, alertas
  createdAt        DateTime @default(now()) @map("created_at")

  cliente     Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lancamentos FolhaLancamento[]
  dados       FolhaImportacaoDado[]

  @@index([clienteId])
  @@index([competencia])
  @@map("folha_importacoes")
}

model FolhaImportacaoDado {
  id           String   @id @default(cuid())
  importacaoId String   @map("importacao_id")
  endereco     String   @default("")
  setor        String   @default("")
  cnpj         String   @default("")
  competencia  String   @default("")
  codDebito    Int?     @map("cod_debito")
  descDebito   String?  @map("desc_debito")
  valorDebito  Decimal? @map("valor_debito") @db.Decimal(14, 2)
  codCredito   Int?     @map("cod_credito")
  descCredito  String?  @map("desc_credito")
  valorCredito Decimal? @map("valor_credito") @db.Decimal(14, 2)

  importacao FolhaImportacao @relation(fields: [importacaoId], references: [id], onDelete: Cascade)

  @@index([importacaoId])
  @@map("folha_importacao_dados")
}

model FolhaLancamento {
  id              String   @id @default(cuid())
  importacaoId    String   @map("importacao_id")
  filialId        String?  @map("filial_id")
  setorId         String?  @map("setor_id")
  dataLancamento  DateTime @map("data_lancamento")
  contaDebito     Int?     @map("conta_debito")
  contaCredito    Int?     @map("conta_credito")
  valor           Decimal  @db.Decimal(14, 2)
  historico       String   @default("")
  tipo            String // DEBITO ou CREDITO
  codigoEvento    Int      @map("codigo_evento")
  descricaoEvento String   @default("") @map("descricao_evento")
  lote            Int? // Sequencial de exportação
  createdAt       DateTime @default(now()) @map("created_at")

  importacao FolhaImportacao @relation(fields: [importacaoId], references: [id], onDelete: Cascade)
  filial     FolhaFilial?    @relation(fields: [filialId], references: [id], onDelete: SetNull)
  setor      FolhaSetor?     @relation(fields: [setorId], references: [id], onDelete: SetNull)

  @@index([importacaoId])
  @@index([filialId])
  @@index([tipo])
  @@map("folha_lancamentos")
}

// ============================================================
// Módulo Administrativo — Agenda Corporativa
// ============================================================

enum AgendaPresenca {
  PRESENCIAL
  ONLINE
  HIBRIDO
}

enum AgendaRecorrencia {
  NENHUMA
  DIARIA
  SEMANAL
  MENSAL
  ANUAL
}

/// Comportamento ao detectar conflito de horário (participante ou sala).
enum AgendaConflitoModo {
  DESLIGADO  // não verifica
  AVISAR     // mostra dialog mas deixa salvar
  BLOQUEAR   // impede salvar
}

/// Configuração singleton por tenant (1 linha apenas) — regras de conflito da agenda.
model AgendaConfig {
  id                   String             @id @default(cuid())
  conflitoParticipante AgendaConflitoModo @default(AVISAR) @map("conflito_participante")
  conflitoSala         AgendaConflitoModo @default(AVISAR) @map("conflito_sala")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("agenda_config")
}

/// Configuração singleton do disparo automático da "Agenda do Dia" por email.
/// Quando ativo, o scheduler envia diariamente um email pros usuarios listados em
/// `destinatariosIds` no horário/dias configurados.
model AgendaDisparoConfig {
  id               String   @id @default(cuid())
  ativo            Boolean  @default(false)
  horario          String   @default("07:00")             // HH:MM
  diasSemana       Int[]    @default([1, 2, 3, 4, 5])    // 0=dom..6=sab — default seg-sex
  enviarParaTodos  Boolean  @default(false) @map("enviar_para_todos")  // ignora destinatariosIds e manda pra todos os colaboradores ativos
  destinatariosIds String[] @default([]) @map("destinatarios_ids")
  ultimoDisparoEm  DateTime? @map("ultimo_disparo_em")    // pra evitar disparos duplicados no mesmo minuto
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("agenda_disparo_config")
}

/// Log de cada disparo da "Agenda do Dia" — automático (scheduler), teste manual
/// ou reenvio de um disparo histórico. Permite auditoria + botão "Reenviar" na UI.
model AgendaDisparoLog {
  id             String   @id @default(cuid())
  disparadoEm    DateTime @default(now()) @map("disparado_em")
  dataReferencia DateTime @map("data_referencia") @db.Date    // a data do "Agenda do Dia" disparada
  modo           String                                       // 'auto' | 'teste' | 'reenvio'
  enviados       Int      @default(0)
  falhas         Int      @default(0)
  destinatarios  String[] @default([])                        // userIds que receberam OK
  erros          Json?                                        // [{ userId, email, motivo }]
  triggeredBy    String?  @map("triggered_by")                // userId quando manual
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([disparadoEm(sort: Desc)])
  @@map("agenda_disparo_logs")
}

/// Cadastro de salas de reunião — usado pra detectar conflito de uso da mesma sala
/// no mesmo período. O AgendaEvento.salaId aponta pra cá; o campo legado `sala`
/// (string) é mantido pra eventos importados do SERPRO2.
model AgendaSala {
  id           String   @id @default(cuid())
  nome         String
  capacidade   Int?
  equipamentos String?  @db.Text
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  eventos AgendaEvento[]

  @@map("agenda_salas")
}

model AgendaTipo {
  id             String   @id @default(cuid())
  nome           String
  cor            String   @default("#3b82f6")
  corBorda       String   @default("#2563eb") @map("cor_borda")
  corTexto       String   @default("#ffffff") @map("cor_texto")
  bloqueiaAgenda Boolean  @default(false) @map("bloqueia_agenda")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  eventos AgendaEvento[]

  @@map("agenda_tipos")
}

model AgendaEvento {
  id           String         @id @default(cuid())
  titulo       String
  descricao    String?        @db.Text
  data         DateTime       @db.Date
  dataFim      DateTime?      @map("data_fim") @db.Date
  horaInicio   String?        @map("hora_inicio")
  horaFim      String?        @map("hora_fim")
  diaInteiro   Boolean        @default(false) @map("dia_inteiro")
  local        String?
  contato      String?
  link         String?
  presenca     AgendaPresenca @default(PRESENCIAL)
  particular   Boolean        @default(false)
  editavel     Boolean        @default(true)
  sala         String?
  salaId       String?        @map("sala_id")
  salaRef      AgendaSala?    @relation(fields: [salaId], references: [id])
  garagem      Boolean        @default(false)
  vagas        Int?
  equipamentos String?
  isTarefa     Boolean        @default(false) @map("is_tarefa")
  isActive     Boolean        @default(true) @map("is_active")

  // Recorrência
  recorrencia      AgendaRecorrencia @default(NENHUMA)
  recorrenciaVezes Int?              @map("recorrencia_vezes")
  lote             String?

  // Google Calendar
  googleId String? @map("google_id")

  // Relações
  tipoId    String     @map("tipo_id")
  tipo      AgendaTipo @relation(fields: [tipoId], references: [id])
  criadorId String     @map("criador_id")
  criador   User       @relation("EventoCriador", fields: [criadorId], references: [id])
  empresaId String?    @map("empresa_id")

  participantes AgendaParticipante[]
  logs          AgendaLog[]
  lembretes     AgendaLembrete[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([data])
  @@index([criadorId])
  @@index([tipoId])
  @@index([empresaId])
  @@index([lote])
  @@index([salaId])
  @@map("agenda_eventos")
}

model AgendaParticipante {
  id          String       @id @default(cuid())
  eventoId    String       @map("evento_id")
  evento      AgendaEvento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  usuarioId   String?      @map("usuario_id")
  usuario     User?        @relation("EventoParticipante", fields: [usuarioId], references: [id])
  nomeAvulso  String?      @map("nome_avulso")
  isActive    Boolean      @default(true) @map("is_active")
  removidoEm  DateTime?    @map("removido_em")
  removidoPor String?      @map("removido_por")

  @@unique([eventoId, usuarioId])
  @@index([eventoId])
  @@index([usuarioId])
  @@map("agenda_participantes")
}

model AgendaLog {
  id        String       @id @default(cuid())
  eventoId  String       @map("evento_id")
  evento    AgendaEvento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  usuarioId String       @map("usuario_id")
  acao      String
  detalhes  String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([eventoId])
  @@map("agenda_logs")
}

/// Canal de notificação do lembrete.
/// POPUP: notificação no app (browser Notification API + toast in-app, via SSE).
/// EMAIL: e-mail transacional via EmailService pros participantes do evento.
enum AgendaLembreteCanal {
  POPUP
  EMAIL
}

/// Tarefa simples na agenda — sem participantes, sem sala, sem link, sem
/// conflito de horário. Tem prazo (data + hora opcional), pode ter lembrete
/// próprio e ser marcada como concluída. Inspirada em Google Tasks.
model AgendaTarefa {
  id             String    @id @default(cuid())
  titulo         String
  descricao      String?   @db.Text
  prazo          DateTime  @db.Date          // data do prazo (sempre UTC midnight)
  horaPrazo      String?   @map("hora_prazo") // HH:MM opcional (null = sem hora específica)
  concluida      Boolean   @default(false)
  concluidaEm    DateTime? @map("concluida_em")
  prioridade     String    @default("NORMAL") // BAIXA | NORMAL | ALTA

  criadorId      String    @map("criador_id")
  criador        User      @relation("TarefaCriador", fields: [criadorId], references: [id])
  empresaId      String?   @map("empresa_id")

  lembretes      AgendaTarefaLembrete[]

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([criadorId, concluida, prazo])
  @@index([prazo])
  @@index([empresaId])
  @@map("agenda_tarefas")
}

/// Lembrete pra uma tarefa — mesma semântica do AgendaLembrete mas pra
/// AgendaTarefa. Modelos separados pra evitar coluna opcional com FK condicional.
model AgendaTarefaLembrete {
  id              String              @id @default(cuid())
  tarefaId        String              @map("tarefa_id")
  tarefa          AgendaTarefa        @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  canal           AgendaLembreteCanal @default(POPUP)
  minutosAntes    Int                 @map("minutos_antes")
  ultimoDisparoEm DateTime?           @map("ultimo_disparo_em")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@index([tarefaId])
  @@index([minutosAntes])
  @@map("agenda_tarefa_lembretes")
}

/// Lembrete agendado pra um evento — pertence ao evento (todos participantes
/// recebem o mesmo lembrete). Disparado pelo scheduler quando o "horário do
/// evento - minutosAntes" cai na janela do tick atual.
model AgendaLembrete {
  id              String              @id @default(cuid())
  eventoId        String              @map("evento_id")
  evento          AgendaEvento        @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  canal           AgendaLembreteCanal @default(POPUP)
  minutosAntes    Int                 @map("minutos_antes")
  ultimoDisparoEm DateTime?           @map("ultimo_disparo_em")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@index([eventoId])
  @@index([minutosAntes])
  @@map("agenda_lembretes")
}

// ============================================================
// Opcoes editaveis (Atividade, Origem, etc)
// ============================================================

model OpcaoCadastro {
  id        String   @id @default(cuid())
  tipo      String // ATIVIDADE | ORIGEM
  valor     String
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  empresaId String?  @map("empresa_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tipo])
  @@map("opcoes_cadastro")
}

// ============================================================
// CRM — Pipeline de Oportunidades
// ============================================================

model CrmEtapa {
  id            String   @id @default(cuid())
  nome          String
  ordem         Int
  cor           String   @default("#818cf8")
  probabilidade Int      @default(0)
  ehGanho       Boolean  @default(false) @map("eh_ganho")
  ehPerda       Boolean  @default(false) @map("eh_perda")
  slaDias       Int?     @map("sla_dias")
  empresaId     String?  @map("empresa_id")
  createdAt     DateTime @default(now()) @map("created_at")

  oportunidades Oportunidade[]

  @@map("crm_etapas")
}

model CrmTag {
  id        String   @id @default(cuid())
  nome      String
  cor       String   @default("#94a3b8")
  empresaId String?  @map("empresa_id")
  createdAt DateTime @default(now()) @map("created_at")

  oportunidades OportunidadeTag[]

  @@map("crm_tags")
}

model OportunidadeTag {
  id             String @id @default(cuid())
  oportunidadeId String @map("oportunidade_id")
  tagId          String @map("tag_id")

  oportunidade Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  tag          CrmTag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([oportunidadeId, tagId])
  @@map("oportunidade_tags")
}

model Oportunidade {
  id                 String    @id @default(cuid())
  titulo             String
  descricao          String?   @db.Text
  valor              Decimal?  @db.Decimal(12, 2)
  etapaId            String    @map("etapa_id")
  clienteId          String?   @map("cliente_id")
  responsavelId      String?   @map("responsavel_id")
  previsaoFechamento DateTime? @map("previsao_fechamento")
  motivoPerda        String?   @map("motivo_perda")
  origem             String?
  atividade          String?
  // Dados do lead/empresa (texto livre)
  cpfCnpj            String?   @map("cpf_cnpj")
  razaoSocial        String?   @map("razao_social")
  // Contato
  contatoNome        String?   @map("contato_nome")
  contatoCargo       String?   @map("contato_cargo")
  contatoTelefone    String?   @map("contato_telefone")
  contatoEmail       String?   @map("contato_email")
  empresaId          String?   @map("empresa_id")
  ordem              Int       @default(0)
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  etapa     CrmEtapa               @relation(fields: [etapaId], references: [id])
  tags      OportunidadeTag[]
  tarefas   OportunidadeTarefa[]
  mensagens OportunidadeMensagem[]
  arquivos  OportunidadeArquivo[]
  eventos   OportunidadeEvento[]

  @@index([etapaId])
  @@index([clienteId])
  @@index([empresaId])
  @@map("oportunidades")
}

model OportunidadeTarefa {
  id             String    @id @default(cuid())
  oportunidadeId String    @map("oportunidade_id")
  titulo         String
  concluida      Boolean   @default(false)
  responsavelId  String?   @map("responsavel_id")
  prazo          DateTime?
  createdAt      DateTime  @default(now()) @map("created_at")

  oportunidade Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  @@index([oportunidadeId])
  @@map("oportunidade_tarefas")
}

model OportunidadeMensagem {
  id             String   @id @default(cuid())
  oportunidadeId String   @map("oportunidade_id")
  userId         String?  @map("user_id")
  mensagem       String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  oportunidade Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  @@index([oportunidadeId])
  @@map("oportunidade_mensagens")
}

model OportunidadeArquivo {
  id             String   @id @default(cuid())
  oportunidadeId String   @map("oportunidade_id")
  fileName       String   @map("file_name")
  fileUrl        String   @map("file_url")
  fileSize       Int?     @map("file_size")
  mimeType       String?  @map("mime_type")
  userId         String?  @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  oportunidade Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  @@index([oportunidadeId])
  @@map("oportunidade_arquivos")
}

model OportunidadeEvento {
  id             String   @id @default(cuid())
  oportunidadeId String   @map("oportunidade_id")
  userId         String?  @map("user_id")
  tipo           String // criacao | etapa | edicao | tarefa | mensagem | arquivo | tag
  descricao      String
  de             String? // valor anterior (ex: etapa anterior)
  para           String? // valor novo (ex: etapa nova)
  createdAt      DateTime @default(now()) @map("created_at")

  oportunidade Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  @@index([oportunidadeId])
  @@map("oportunidade_eventos")
}

// ============================================================
// Orcamentos — Propostas Comerciais
// ============================================================

enum OrcamentoStatus {
  NOVO
  A_ENVIAR
  ENVIADO
  APROVADO
  LIBERADO
  FINALIZADO
  ENCERRADO
}

model Orcamento {
  id                String          @id @default(cuid())
  numero            Int             @default(autoincrement())
  token             String          @unique @default(cuid())
  oportunidadeId    String?         @map("oportunidade_id")
  clienteId         String?         @map("cliente_id")
  responsavelId     String?         @map("responsavel_id")
  solicitanteId     String?         @map("solicitante_id")
  status            OrcamentoStatus @default(NOVO)
  tipo              String? // SERVICO_EXTRA | SERVICO_MENSAL
  area              String?
  validadeDias      Int             @default(90) @map("validade_dias")
  contatos          String?
  emailsContatos    String?         @map("emails_contatos")
  descontoPct       Decimal?        @map("desconto_pct") @db.Decimal(5, 2)
  descontoValor     Decimal?        @map("desconto_valor") @db.Decimal(12, 2)
  formaPagamento    String?         @map("forma_pagamento")
  textoInterno      String?         @map("texto_interno") @db.Text
  textoCorpoCliente String?         @map("texto_corpo_cliente") @db.Text
  observacoes       String?         @db.Text
  // Decisao do cliente
  decisaoTipo       String?         @map("decisao_tipo")
  decisaoEm         DateTime?       @map("decisao_em")
  decisaoNome       String?         @map("decisao_nome")
  decisaoCpf        String?         @map("decisao_cpf")
  decisaoObs        String?         @map("decisao_obs") @db.Text
  // Totais calculados
  totalServicos     Decimal         @default(0) @map("total_servicos") @db.Decimal(12, 2)
  totalTaxas        Decimal         @default(0) @map("total_taxas") @db.Decimal(12, 2)
  totalDespesas     Decimal         @default(0) @map("total_despesas") @db.Decimal(12, 2)
  descontoAplicado  Decimal         @default(0) @map("desconto_aplicado") @db.Decimal(12, 2)
  totalGeral        Decimal         @default(0) @map("total_geral") @db.Decimal(12, 2)
  // Controle
  arquivado         Boolean         @default(false)
  arquivadoEm       DateTime?       @map("arquivado_em")
  arquivadoPor      String?         @map("arquivado_por")
  ordem             Int             @default(0)
  // Datas dedicadas por transicao de status
  dtEnviado         DateTime?       @map("dt_enviado")
  dtAprovado        DateTime?       @map("dt_aprovado")
  dtLiberado        DateTime?       @map("dt_liberado")
  dtFinalizado      DateTime?       @map("dt_finalizado")
  dtEncerrado       DateTime?       @map("dt_encerrado")
  dtCancelado       DateTime?       @map("dt_cancelado")
  // Paralizacao (pausa sem mudar status)
  paralizado        Boolean         @default(false)
  paralizadoEm      DateTime?       @map("paralizado_em")
  paralizadoPor     String?         @map("paralizado_por")
  paralizadoMotivo  String?         @map("paralizado_motivo") @db.Text
  // Auditoria — quantas vezes este orcamento foi reaberto
  reaberturasCount  Int             @default(0) @map("reaberturas_count")
  // Servico template vinculado — quando orcamento for APROVADO, sistema cria
  // automaticamente uma ServicoExecucao para o responsavel executar o checklist
  servicoId         String?         @map("servico_id")
  empresaId         String?         @map("empresa_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  servico   Servico?            @relation("OrcamentoServicoTemplate", fields: [servicoId], references: [id], onDelete: SetNull)
  itens     OrcamentoItem[]
  mensagens OrcamentoMensagem[]
  arquivos  OrcamentoArquivo[]
  eventos   OrcamentoEvento[]
  contratos Contrato[]

  @@index([clienteId])
  @@index([status])
  @@index([empresaId])
  @@index([servicoId])
  @@map("orcamentos")
}

model OrcamentoItem {
  id            String   @id @default(cuid())
  orcamentoId   String   @map("orcamento_id")
  tipo          String // SERVICO | TAXA | DESPESA
  descricao     String
  quantidade    Decimal  @default(1) @db.Decimal(15, 4)
  valorUnitario Decimal  @map("valor_unitario") @db.Decimal(12, 2)
  catalogoId    String?  @map("catalogo_id")
  situacao      String   @default("A_FAZER") // A_FAZER | FAZENDO | PENDENTE | CONCLUIDO (legado crp_orcamentos.com_orc_ser.situacao)
  createdAt     DateTime @default(now()) @map("created_at")

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("orcamento_itens")
}

model OrcamentoMensagem {
  id                 String    @id @default(cuid())
  orcamentoId        String    @map("orcamento_id")
  userId             String?   @map("user_id")
  mensagem           String    @db.Text
  // Visibilidade — vazio = todos veem
  acessoUsuarios     String[]  @default([]) @map("acesso_usuarios")
  restritoFinanceiro Boolean   @default(false) @map("restrito_financeiro")
  createdAt          DateTime  @default(now()) @map("created_at")
  editadoEm          DateTime? @map("editado_em")
  parentId           String?   @map("parent_id")

  orcamento Orcamento           @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  parent    OrcamentoMensagem?  @relation("OrcamentoMensagemThread", fields: [parentId], references: [id], onDelete: Cascade)
  respostas OrcamentoMensagem[] @relation("OrcamentoMensagemThread")

  @@index([orcamentoId])
  @@index([parentId])
  @@map("orcamento_mensagens")
}

model OrcamentoArquivo {
  id          String   @id @default(cuid())
  orcamentoId String   @map("orcamento_id")
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")
  userId      String?  @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("orcamento_arquivos")
}

model OrcamentoEvento {
  id          String   @id @default(cuid())
  orcamentoId String   @map("orcamento_id")
  userId      String?  @map("user_id")
  tipo        String // status_change | created | updated | archived
  de          String? // status anterior
  para        String? // status novo
  descricao   String?
  createdAt   DateTime @default(now()) @map("created_at")

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("orcamento_eventos")
}

model ServicoCatalogo {
  id                  String   @id @default(cuid())
  nome                String
  tipo                String   @default("SERVICO") // SERVICO | TAXA | DESPESA
  valorPadrao         Decimal? @map("valor_padrao") @db.Decimal(12, 2)
  textoPadrao         String?  @map("texto_padrao") @db.Text
  ativo               Boolean  @default(true)
  disponivelOrcamento Boolean  @default(true) @map("disponivel_orcamento")
  empresaId           String?  @map("empresa_id")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("servicos_catalogo")
}

// ============================================================
// Servicos — Templates + Execucao (Checklist)
// ============================================================

// Prioridade de servico — herdada da execucao do template, mas pode ser sobrescrita
enum PrioridadeServico {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

// Status agregado de um Processo (cadeia de execucoes encadeadas).
enum ProcessoStatus {
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

// Tipo do bloco no fluxograma de Serviços.
// ATIVIDADE     = template normal com etapas/passos (comportamento default)
// DECISAO       = losango que apenas roteia (avalia condicao das saídas)
// DOCUMENTACAO  = nota/marco informativo no fluxo (sem etapas)
// INICIO/FIM    = marcadores decorativos no canvas; sem efeito no engine
enum ServicoTipo {
  ATIVIDADE
  DECISAO
  DOCUMENTACAO
  INICIO
  FIM
  // Decisão interativa: ao chegar nesse bloco em runtime, a execução fica
  // AGUARDANDO_RESPOSTA. O gestor escolhe uma ou mais opções e o engine
  // dispara só os sucessores cujo `rotulo` casa com as opções escolhidas.
  PERGUNTA
}

// Estratégia de atribuição de responsável na execução de um serviço.
// O engine resolve em runtime conforme essa configuração no template.
enum AtribuicaoResponsavel {
  /**
   * Default pra EXTRA: pega `responsavelId` do orçamento que originou a execução.
   */
  ORCAMENTO
  /**
   * Default pra MENSAL: busca `ClienteAreaContratada.responsavelId` no cliente,
   * matching pela `Servico.categoria` (case-insensitive) contra `Area.name`.
   * Fallback: substitutoId quando o responsável estiver ausente.
   */
  CLIENTE_AREA
  /**
   * Usa `Servico.responsavelFixoId` — todo cliente/orçamento recebe a mesma pessoa.
   */
  MANUAL_FIXO
  /**
   * Default pra FLUXO: herda do predecessor na cadeia de processos.
   * Já governado por `ServicoEncadeamento.herdaResponsavel`.
   */
  HERDA_PREDECESSOR
}

/**
 * Como contar os dias do lembrete antes do vencimento.
 */
enum TipoDiasAntes {
  CORRIDOS
  UTEIS
}

// Diferencia o papel do registro na tabela `servicos`:
//  - MENSAL: serviço top-level cobrado de forma recorrente (entra em contratos).
//  - EXTRA:  serviço top-level pontual/avulso (cobrança por execução).
//  - FLUXO:  item interno do fluxo de um serviço top-level. NÃO aparece na
//            listagem de serviços — é só um nó da cadeia de trabalho. Sempre
//            tem um `servicoPaiId` apontando pro serviço dono.
enum ServicoCategoria {
  MENSAL
  EXTRA
  FLUXO
}

model Servico {
  id                  String            @id @default(cuid())
  nome                String
  descricao           String?           @db.Text
  slaHoras            Int?              @map("sla_horas")
  ativo               Boolean           @default(true)
  empresaId           String?           @map("empresa_id")
  // Categoria livre para agrupamento (ex: "Fiscal", "Trabalhista", "Contabil")
  categoria           String?
  // Prioridade padrao — copiada para a execucao na criacao
  prioridadePadrao    PrioridadeServico @default(MEDIA) @map("prioridade_padrao")
  // Catalogo: valor padrao quando esse servico e adicionado como item de orcamento.
  // Pode ser sobrescrito no item especifico.
  valorPadrao         Decimal?          @map("valor_padrao") @db.Decimal(12, 2)
  // Se false, nao aparece no seletor de itens do orcamento (mas continua disponivel
  // como template de workflow para execucao manual).
  disponivelOrcamento Boolean           @default(true) @map("disponivel_orcamento")
  // Se true, o servico e cobrado de forma recorrente (mensal) — entra em contratos
  // de prestacao continua. Se false, e um servico pontual/extraordinario (uma cobranca
  // por execucao). Ex: Folha mensal=true, Abertura de Empresa=false.
  // (Mantido por compat; preferir `categoriaServico` daqui pra frente.)
  recorrenteMensal    Boolean           @default(false) @map("recorrente_mensal")
  // Slug do segmento de cliente ao qual este template pertence (ex: 'atacadista-lucro-real').
  // null = template genérico/avulso (Abertura de Empresa, Conciliação Bancária, certidões, etc).
  // Valores referenciam SEGMENTO_SLUGS em packages/types/src/segmento.ts
  segmentoSlug        String?           @map("segmento_slug")
  /**
   * Tipo do bloco no fluxograma — ATIVIDADE (default) ou DECISAO/INICIO/FIM
   */
  tipo                ServicoTipo       @default(ATIVIDADE)
  /**
   * Papel deste registro: MENSAL/EXTRA = serviço top-level; FLUXO = item interno do fluxo.
   */
  categoriaServico    ServicoCategoria  @default(EXTRA) @map("categoria_servico")
  /**
   * Quando categoriaServico = FLUXO, aponta pro serviço top-level dono do fluxo.
   */
  servicoPaiId        String?           @map("servico_pai_id")
  /**
   * Texto padrão (HTML do TipTap) — usado como conteúdo inicial em e-mails,
   * notas ou documentação automática quando o serviço é executado.
   */
  textoPadrao         String?           @map("texto_padrao") @db.Text

  // ── Bloco do tipo PERGUNTA — campos só preenchidos quando tipo=PERGUNTA ──
  /**
   * /** Texto da pergunta apresentada ao gestor em runtime
   * (ex.: "Serviço mensal em todas as áreas?").
   */
  perguntaTexto  String? @map("pergunta_texto") @db.Text
  /**
   * Lista de opções de resposta (array de strings em JSON).
   * Cada opção vira um rótulo de aresta que filtra qual sucessor é disparado.
   */
  perguntaOpcoes Json?   @map("pergunta_opcoes")
  /**
   * Se true, gestor pode marcar várias opções (multi-seleção dispara N sucessores).
   */
  perguntaMulti  Boolean @default(false) @map("pergunta_multi")

  // ── Estratégia de atribuição de responsável (legado) ──
  /**
   * /** @deprecated Mantido apenas para compat com bloco PERGUNTA / fluxos antigos.
   * Novas decisões de atribuição usam os campos `atribuicao*` abaixo.
   */
  atribuicaoResponsavel AtribuicaoResponsavel @default(ORCAMENTO) @map("atribuicao_responsavel")
  /**
   * @deprecated — ver `atribuicaoColaboradores`.
   */
  responsavelFixoId     String?               @map("responsavel_fixo_id")

  // ── Atribuição multi-valor (nova, padrão obrigatório) ──
  // União das fontes abaixo define o conjunto de candidatos. Quando a execução
  // é criada, o engine resolve: 1 candidato → responsavelId direto; >1 ou 0 →
  // null (claim-first — todos veem em /meus-servicos, primeiro a marcar passo
  // reivindica). Configurado na pill "Identificação" do detalhe do serviço.
  /**
   * /** IDs de usuários candidatos diretamente listados.
   */
  atribuicaoColaboradores  String[] @default([]) @map("atribuicao_colaboradores")
  /**
   * IDs de áreas — todos os usuários ativos dessas áreas viram candidatos.
   */
  atribuicaoAreas          String[] @default([]) @map("atribuicao_areas")
  /**
   * Se true, soma o responsável do orçamento que originou a execução.
   */
  atribuicaoUsaOrcamento   Boolean  @default(false) @map("atribuicao_usa_orcamento")
  /**
   * Se true, soma o responsável do cliente na área do serviço (ClienteAreaContratada).
   */
  atribuicaoUsaClienteArea Boolean  @default(false) @map("atribuicao_usa_cliente_area")

  // ── Procedência / referências externas ──
  /**
   * /** URL da fonte oficial onde o vencimento/regra foi confirmado (ex.: site Receita,
   * portal SEFAZ). Usada como prova de auditoria + facilita revisão anual.
   */
  fonteUrl             String? @map("fonte_url") @db.Text
  /**
   * URL da documentação oficial/guia/manual da obrigação (ex.: perguntas frequentes
   * Receita, Manual da DCTFWeb). Vinculada pra consulta rápida do operador.
   */
  documentacaoUrl      String? @map("documentacao_url") @db.Text
  /**
   * Marca o registro como template de "obrigação acessória" — listado em /obrigacoes
   * (Cadastros). Distingue dos demais Servicos globais ou da empresa.
   */
  ehObrigacaoAcessoria Boolean @default(false) @map("eh_obrigacao_acessoria")
  /**
   * Marca o registro como serviço de execução exclusivamente interna — não aparece
   * no catálogo de orçamentos. Listado em /servicos numa aba dedicada.
   */
  ehServicoInterno     Boolean @default(false) @map("eh_servico_interno")

  // ── Configurações avançadas (espelho dos campos do Acessórias) ──
  /**
   * /** Apelido curto exibido em colunas/relatórios. Max 10 chars.
   */
  mininome             String?       @db.VarChar(10)
  /**
   * Tempo previsto de execução em minutos — usado em planejamento e relatórios.
   */
  tempoPrevistoMinutos Int?          @map("tempo_previsto_minutos")
  /**
   * Quantos dias antes do prazo o sistema deve avisar o responsável. 0 = sem aviso.
   */
  lembrarDiasAntes     Int           @default(0) @map("lembrar_dias_antes")
  /**
   * Contagem dos dias do lembrete: corridos (calendário) ou úteis (excl. FDS/feriado).
   */
  tipoDiasAntes        TipoDiasAntes @default(CORRIDOS) @map("tipo_dias_antes")
  /**
   * Quando true, sábado é considerado dia útil para fins de prazo legal desta obrigação.
   */
  sabadoEhUtil         Boolean       @default(false) @map("sabado_eh_util")
  /**
   * Quando true, exige que a entrega seja feita pelo robô (sem upload manual).
   */
  exigirRobo           Boolean       @default(false) @map("exigir_robo")
  /**
   * Quando true, atraso gera multa — sinalização em dashboards.
   */
  passivelDeMulta      Boolean       @default(true) @map("passivel_de_multa")
  /**
   * Quando true, gera alerta nos dashboards quando guia ainda não foi lida.
   */
  alertaGuiaNaoLida    Boolean       @default(true) @map("alerta_guia_nao_lida")
  /**
   * Comentário padrão pré-preenchido no campo de comentário do anexo na entrega manual. Max 300.
   */
  comentarioPadrao     String?       @map("comentario_padrao") @db.VarChar(300)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  etapas               ServicoEtapa[]
  execucoes            ServicoExecucao[]
  orcamentos           Orcamento[]               @relation("OrcamentoServicoTemplate")
  clausulas            ServicoClausula[]
  contratoServicos     ContratoServico[]
  processosRaiz        Processo[]                @relation("ProcessoRaiz")
  encadeamentosOrigem  ServicoEncadeamento[]     @relation("EncadeamentoOrigem")
  encadeamentosDestino ServicoEncadeamento[]     @relation("EncadeamentoDestino")
  // Pertencimento a grupos — M→N: um serviço pode estar em vários grupos.
  grupos               ServicoGrupoItem[]
  // Mapeamentos do Acessórias (obrigações que disparam execuções deste serviço)
  acessoriasMaps       AcessoriasObligationMap[] @relation("AcessoriasMapServico")
  // Regra de recorrência (1:1) — quando o serviço dispara execuções automaticamente
  recorrencia          ServicoRecorrencia?
  // Regras de notificação por evento — múltiplas por serviço
  notificacoes         ServicoNotificacaoRegra[]
  // Back-refs: vínculos com grupos/templates e clientes (M:N)
  grupoObrigacaoItens  GrupoObrigacaoItem[]
  clienteObrigacoes    ClienteObrigacao[]
  // Overrides de vencimento por mês (1-12) — quando preenchido, sobrescreve
  // a regra padrão de ServicoRecorrencia naquele mês específico.
  vencimentosMensais   ServicoVencimentoMensal[]

  // Self-relation: filhos = itens de fluxo deste serviço top-level
  servicoPai   Servico?  @relation("ServicoFluxoItens", fields: [servicoPaiId], references: [id], onDelete: Cascade)
  itensDeFluxo Servico[] @relation("ServicoFluxoItens")

  @@index([categoria])
  @@index([categoriaServico])
  @@index([servicoPaiId])
  @@index([ehObrigacaoAcessoria])
  @@index([ehServicoInterno])
  @@map("servicos")
}

model ServicoEtapa {
  id        String @id @default(cuid())
  servicoId String @map("servico_id")
  nome      String
  ordem     Int
  slaHoras  Int?   @map("sla_horas")

  servico   Servico           @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  passos    ServicoPasso[]
  materiais ServicoMaterial[] @relation("EtapaMateriais")

  @@index([servicoId])
  @@map("servico_etapas")
}

model ServicoPasso {
  id               String  @id @default(cuid())
  etapaId          String  @map("etapa_id")
  nome             String
  ordem            Int
  obrigatorio      Boolean @default(true)
  // SLA do passo — precisão de minutos. Substitui slaHoras (que fica
  // como legado pra dados antigos: se slaMinutos é null e slaHoras > 0,
  // o frontend faz fallback slaHoras * 60).
  slaMinutos       Int?    @map("sla_minutos")
  slaHoras         Int?    @map("sla_horas")
  textoOrientativo String? @map("texto_orientativo") @db.Text
  recorrente       Boolean @default(false)
  recorrenciaTipo  String? @map("recorrencia_tipo")
  enviaEmail       Boolean @default(false) @map("envia_email")
  emailAssunto     String? @map("email_assunto")
  emailCorpo       String? @map("email_corpo") @db.Text
  // Dependencia: este passo so pode ser concluido apos o referenciado.
  // Self-reference dentro do mesmo template (mesma etapa ou de etapa anterior).
  dependeDoPassoId String? @map("depende_do_passo_id")
  // Permite anexar arquivos quando concluir o passo (Fase 4 vai usar)
  permiteAnexo     Boolean @default(false) @map("permite_anexo")
  // Quando true, o usuário pode "pular" este passo durante a execução.
  // Passos ignorados desbloqueiam os próximos sem terem sido concluídos.
  permiteIgnorar   Boolean @default(false) @map("permite_ignorar")

  etapa             ServicoEtapa                @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  dependeDoPasso    ServicoPasso?               @relation("ServicoPassoDependencia", fields: [dependeDoPassoId], references: [id], onDelete: SetNull)
  passosDependentes ServicoPasso[]              @relation("ServicoPassoDependencia")
  materiais         ServicoMaterial[]           @relation("PassoMateriais")
  emailTemplates    ServicoPassoEmailTemplate[]
  lembretes         ServicoPassoLembrete[]
  camposCliente     ServicoPassoCampoCliente[]

  @@index([etapaId])
  @@map("servico_passos")
}

/// Modelos de e-mail vinculados a um passo do template de serviço.
/// Dispar(am)ados automaticamente quando o passo é concluído via togglePasso.
/// Quando `exigirConfirmacao=true`, o frontend mostra modal de preview pro
/// usuário revisar/adicionar destinatários antes de enviar.
///
/// Tags suportadas no `assunto` e `corpo`:
///   {{cliente.razaoSocial}}, {{cliente.nomeFantasia}}, {{cliente.documento}}
///   {{responsavel.name}}, {{responsavel.email}}
///   {{servico.nome}}, {{etapa.nome}}, {{passo.nome}}
///
/// Substitui os campos legados `enviaEmail/emailAssunto/emailCorpo` do
/// `ServicoPasso` (que ficam como compat — único e-mail, sem confirmação).
model ServicoPassoEmailTemplate {
  id                String   @id @default(cuid())
  passoId           String   @map("passo_id")
  nome              String /// Rótulo interno (ex: "Aviso ao cliente")
  assunto           String
  corpo             String   @db.Text
  /// Destinatários default — gestor cadastra; gestor pode adicionar mais no
  /// momento do envio quando exigirConfirmacao=true.
  destinatarios     String[] @default([])
  ativo             Boolean  @default(true)
  ordem             Int      @default(0)
  /// Quando true, o togglePasso abre modal com preview e botão "Enviar".
  /// Quando false, dispara direto no commit do togglePasso.
  exigirConfirmacao Boolean  @default(false) @map("exigir_confirmacao")
  empresaId         String?  @map("empresa_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  passo  ServicoPasso                     @relation(fields: [passoId], references: [id], onDelete: Cascade)
  anexos ServicoPassoEmailTemplateAnexo[]

  @@index([passoId])
  @@map("servico_passo_email_templates")
}

/// Anexos de um template de e-mail. Arquivos ficam no storage local (/uploads)
/// e são lidos pelo backend na hora de disparar o e-mail (sendMail.attachments).
/// O upload acontece via POST /api/upload (multer) e o frontend persiste só a
/// referência (fileName/storageKey) aqui.
model ServicoPassoEmailTemplateAnexo {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  /// Nome amigável do arquivo (exibido pro destinatário no anexo do email).
  fileName   String   @map("file_name")
  /// Chave de storage — corresponde ao nome físico em /uploads (cuid + ext).
  /// Resolvido em URL pelo frontend via `/api/upload/<storageKey>`.
  storageKey String   @map("storage_key")
  fileSize   Int?     @map("file_size")
  mimeType   String?  @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")

  template ServicoPassoEmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("servico_passo_email_template_anexos")
}

/// Unidade do offset de tempo do lembrete em relação à conclusão do passo.
enum OffsetUnidade {
  DIAS
  MESES
  ANOS
}

/// Templates de lembrete vinculados a um passo. Quando o passo é concluído via
/// togglePasso, cada lembrete ativo gera um AgendaEvento com data = hoje +
/// offset (offsetValor + offsetUnidade), participantes configurados e o título
/// resolvendo as mesmas tags suportadas nos templates de e-mail.
model ServicoPassoLembrete {
  id                 String        @id @default(cuid())
  passoId            String        @map("passo_id")
  nome               String /// Rótulo interno (ex: "Parabenizar 1 ano de cliente")
  titulo             String /// Texto que vira o título do AgendaEvento (aceita tags)
  descricao          String?       @db.Text /// Descrição opcional do evento
  offsetValor        Int           @map("offset_valor") /// Ex.: 1
  offsetUnidade      OffsetUnidade @map("offset_unidade") /// Ex.: ANOS
  /// Tipo de agenda (FK). Quando null, usa o primeiro tipo "Lembrete"/default da empresa.
  tipoAgendaId       String?       @map("tipo_agenda_id")
  /// IDs de usuários que entram como participantes do evento.
  participantes      String[]      @default([])
  /// IDs de áreas — todos usuários ativos viram participantes.
  participantesAreas String[]      @default([]) @map("participantes_areas")
  ativo              Boolean       @default(true)
  ordem              Int           @default(0)
  empresaId          String?       @map("empresa_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  passo ServicoPasso @relation(fields: [passoId], references: [id], onDelete: Cascade)

  @@index([passoId])
  @@map("servico_passo_lembretes")
}

/// Vincula um campo do cadastro do Cliente (whitelist em packages/types/servico-passo-campos.ts)
/// a um passo do template. Quando o passo for concluído na execução, um modal
/// aparece pra o operador preencher esses campos, e o Cliente é atualizado.
///
/// `campoChave` precisa estar na whitelist do catálogo no momento do create — a
/// validação acontece no nivel Zod + no service antes de persistir o valor.
model ServicoPassoCampoCliente {
  id            String   @id @default(cuid())
  passoId       String   @map("passo_id")
  /// Nome do campo no model Cliente (e.g. "dataEntrada", "inscricaoEstadual").
  /// Limitado à whitelist exportada por CAMPOS_CLIENTE_CATALOGO.
  campoChave    String   @map("campo_chave")
  /// Sobrescreve o `label` padrão do catálogo. Null = usa o do catálogo.
  labelOverride String?  @map("label_override")
  /// Quando true, o passo não pode ser concluído se o campo estiver vazio.
  obrigatorio   Boolean  @default(false)
  /// Quando true, exige que o operador revise/confirme o valor (mesmo que já
  /// venha preenchido do cliente). Útil pra campos críticos como Situação.
  /// O modal mostra checkbox "Revisado"; auto-marca quando valor é alterado.
  exigeEdicao   Boolean  @default(false) @map("exige_edicao")
  ativo         Boolean  @default(true)
  ordem         Int      @default(0)
  empresaId     String?  @map("empresa_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  passo ServicoPasso @relation(fields: [passoId], references: [id], onDelete: Cascade)

  @@index([passoId])
  @@map("servico_passo_campos_cliente")
}

/// Materiais de apoio anexados a uma Etapa ou Passo do template.
/// Tipos:
///  - NOTA:    instrução/dica em texto longo (conteudo guarda o texto)
///  - LINK:    URL externa (conteudo guarda a URL; titulo é o rótulo amigável)
///  - ARQUIVO: upload no S3/Minio (conteudo guarda o storage key)
/// Vinculo polimórfico: etapaId OU passoId — exatamente um preenchido.
model ServicoMaterial {
  id        String              @id @default(cuid())
  etapaId   String?             @map("etapa_id")
  passoId   String?             @map("passo_id")
  tipo      ServicoMaterialTipo
  titulo    String
  /// NOTA: texto (markdown leve). LINK: URL. ARQUIVO: storage key.
  conteudo  String              @db.Text
  /// Só pra ARQUIVO — metadados úteis pra exibir corretamente.
  mimeType  String?             @map("mime_type")
  fileName  String?             @map("file_name")
  fileSize  Int?                @map("file_size")
  ordem     Int                 @default(0)
  empresaId String?             @map("empresa_id")
  createdBy String?             @map("created_by")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  etapa ServicoEtapa? @relation("EtapaMateriais", fields: [etapaId], references: [id], onDelete: Cascade)
  passo ServicoPasso? @relation("PassoMateriais", fields: [passoId], references: [id], onDelete: Cascade)

  @@index([etapaId])
  @@index([passoId])
  @@map("servico_materiais")
}

enum ServicoMaterialTipo {
  NOTA
  LINK
  ARQUIVO
}

/// Vincula uma obrigação do Acessórias (nome livre em maiúsculas, ex: "BALANCETE
/// MENSAL") a um Servico MENSAL do OneClick. Relação **M:N por design** — uma
/// obrigação pode estar vinculada a múltiplos serviços (ex: BALANCETE MENSAL faz
/// parte de "Contábil Mensal — Simples" + "Contábil Mensal — Presumido/Real").
///
/// Cada row representa UM vínculo. Pra ter múltiplos serviços, criar múltiplas rows.
/// O sync cria uma `ServicoExecucao` no OneClick **pra cada vínculo ativo**.
///
/// `servicoId = null` é uma "marca de ignorar" — quando existe row(s) só com
/// servicoId=null pra um nome, o sync sabe que o usuário explicitamente decidiu
/// não mapear (vs apenas "ainda não mapeei").
model AcessoriasObligationMap {
  id          String   @id @default(cuid())
  /// Nome exato como vem em /deliveries/...Entregas[].Nome
  nome        String
  /// Servico MENSAL vinculado. Null = vínculo "ignorar" (placeholder pra obrigação
  /// que o usuário decidiu não processar).
  servicoId   String?  @map("servico_id")
  /// Quando false, este vínculo específico é desabilitado (não cria execução)
  /// sem precisar deletar — útil pra pausar temporariamente.
  ativo       Boolean  @default(true)
  observacoes String?  @db.Text
  empresaId   String?  @map("empresa_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  servico Servico? @relation("AcessoriasMapServico", fields: [servicoId], references: [id], onDelete: Cascade)

  /// Cada par (empresa, obrigação, serviço) é único — evita duplicação de vínculos
  @@unique([empresaId, nome, servicoId])
  @@index([nome])
  @@index([servicoId])
  @@map("acessorias_obligation_maps")
}

/// Log de execução de sync — última vez que rodamos polling, quantos registros
/// foram processados, erros encontrados. Usado pra UI mostrar histórico.
model AcessoriasSyncLog {
  id                    String    @id @default(cuid())
  /// Tipo de sync: 'companies' | 'deliveries' | 'manual' | 'cron'
  tipo                  String
  startedAt             DateTime  @default(now()) @map("started_at")
  finishedAt            DateTime? @map("finished_at")
  /// 'running' | 'success' | 'error' | 'partial'
  status                String
  /// Contadores agregados — quantas empresas/deliveries criadas, atualizadas, ignoradas, com erro.
  empresasNovas         Int       @default(0) @map("empresas_novas")
  empresasAtualizadas   Int       @default(0) @map("empresas_atualizadas")
  empresasIgnoradas     Int       @default(0) @map("empresas_ignoradas")
  deliveriesNovas       Int       @default(0) @map("deliveries_novas")
  deliveriesAtualizadas Int       @default(0) @map("deliveries_atualizadas")
  deliveriesIgnoradas   Int       @default(0) @map("deliveries_ignoradas")
  /// Mensagem de erro quando status = error. Texto livre.
  erroMensagem          String?   @map("erro_mensagem") @db.Text
  /// Parâmetros da chamada (period, filtros) — debug.
  parametros            Json?
  /// Usuário que disparou (null = cron automático).
  triggeredBy           String?   @map("triggered_by")
  empresaId             String?   @map("empresa_id")

  @@index([tipo, startedAt])
  @@index([empresaId])
  @@map("acessorias_sync_logs")
}

/// Grupo de serviços — agrupa templates de serviço por operação
/// (ex: "Constituição de Cliente Mensal" contém vários serviços top-level
/// que devem ser executados juntos para um cliente). Relação M→N: um
/// serviço pode estar em vários grupos via ServicoGrupoItem.
model ServicoGrupo {
  id        String   @id @default(cuid())
  nome      String
  descricao String?  @db.Text
  /// Cor hex pra identificação visual (chip/badge no UI).
  cor       String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  empresaId String?  @map("empresa_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itens ServicoGrupoItem[]

  @@index([empresaId])
  @@index([ativo])
  @@map("servico_grupos")
}

/// Item de grupo — vincula um Servico a um ServicoGrupo (junção M→N).
/// `ordem` define a sequência opcional dos serviços dentro do grupo,
/// usada quando o usuário aciona "iniciar grupo para cliente X".
model ServicoGrupoItem {
  grupoId   String   @map("grupo_id")
  servicoId String   @map("servico_id")
  ordem     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  grupo   ServicoGrupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  servico Servico      @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@id([grupoId, servicoId])
  @@index([grupoId])
  @@index([servicoId])
  @@map("servico_grupo_itens")
}

model ServicoExecucao {
  id            String            @id @default(cuid())
  servicoId     String            @map("servico_id")
  orcamentoId   String?           @map("orcamento_id")
  clienteId     String            @map("cliente_id")
  responsavelId String?           @map("responsavel_id")
  // Status: EM_ANDAMENTO | CONCLUIDO | CANCELADO | AGUARDANDO_INICIO | PULADO
  // AGUARDANDO_INICIO: criada pela cascata mas exige confirmacao manual (sucessor opcional ou iniciaAuto=false)
  // PULADO: sucessor opcional recusado pelo gestor — nao executa, conta como fechado
  status        String            @default("EM_ANDAMENTO")
  // Prioridade desta execucao — copia do template no momento da criacao,
  // mas pode ser editada posteriormente
  prioridade    PrioridadeServico @default(MEDIA)
  // Prazo limite calculado a partir do slaHoras + iniciadoEm.
  // Painel "Meus Servicos" usa pra alertas de SLA estourando.
  prazoLimite   DateTime?         @map("prazo_limite")
  observacoes   String?           @db.Text
  iniciadoEm    DateTime          @default(now()) @map("iniciado_em")
  concluidoEm   DateTime?         @map("concluido_em")
  empresaId     String?           @map("empresa_id")
  createdAt     DateTime          @default(now()) @map("created_at")

  // Pausa do servico — quando aguardando cliente/terceiros. Nao conta tempo
  // de SLA enquanto pausado (Fase 4 vai recalcular prazoLimite ao retomar).
  pausado       Boolean   @default(false)
  pausadoEm     DateTime? @map("pausado_em")
  pausadoPor    String?   @map("pausado_por")
  pausadoMotivo String?   @map("pausado_motivo") @db.Text

  // Arquivamento — execucoes concluidas/canceladas podem ser arquivadas
  // manualmente para sair da listagem do /meus-servicos. Independente do
  // arquivamento manual, ha um filtro automatico por dias (system config
  // "meus_servicos.concluidos_dias_exibicao") que oculta concluidas antigas.
  arquivado    Boolean   @default(false)
  arquivadoEm  DateTime? @map("arquivado_em")
  arquivadoPor String?   @map("arquivado_por")

  // Notificação de atraso — preenchido na primeira vez que o scheduler
  // detecta `prazoLimite < now` em execução EM_ANDAMENTO não-pausada.
  // Evita spam de notificações no sino do responsável.
  notificadoAtrasoEm DateTime? @map("notificado_atraso_em")

  // Encadeamento (Processos): rastreia de qual cadeia esta execucao faz parte,
  // qual a execucao predecessora (se houver), e qual aresta do template criou esta.
  processoId            String? @map("processo_id")
  predecessorExecucaoId String? @map("predecessor_execucao_id")
  encadeamentoId        String? @map("encadeamento_id")

  // ── Sincronização com Acessórias ──
  /// Chave canônica da entrega no Acessórias (Config.EntID). Quando disponível,
  /// vira a chave primária do sync diferencial. Nulo até a 1ª sincronização.
  acessoriasEntId       String?   @map("acessorias_ent_id")
  /// Nome da obrigação no Acessórias — usado como fallback de match quando
  /// EntID ainda não foi resolvido (chave composta com competencia + clienteId).
  acessoriasNome        String?   @map("acessorias_nome")
  /// Competência da entrega (mês de referência). YYYY-MM-DD = primeiro dia do mês.
  acessoriasComp        DateTime? @map("acessorias_comp") @db.Date
  /// Prazo legal da entrega no Acessórias (EntDtPrazo).
  acessoriasPrazo       DateTime? @map("acessorias_prazo") @db.Date
  /// Status crú vindo do Acessórias (Pendente, Entregue, Atrasada!, Ent. antecipada, etc.).
  /// Mapeado pra ServicoExecucao.status na hora do sync, mas guardamos cru pra debug.
  acessoriasStatus      String?   @map("acessorias_status")
  /// EntLastDH — timestamp da última alteração no Acessórias. Usado pra detectar
  /// updates entre syncs (se mudou no Acessórias, reflete em OneClick).
  acessoriasLastDH      DateTime? @map("acessorias_last_dh")
  /// Quando esta execução foi sincronizada do Acessórias pela última vez.
  acessoriasSyncedAt    DateTime? @map("acessorias_synced_at")
  /// Nome do responsável pelo PRAZO no Acessórias (Config.RespPrazo). String pura —
  /// match com User do OneClick é feito por SincronizarResponsaveisService.
  acessoriasRespPrazo   String?   @map("acessorias_resp_prazo")
  /// Nome do responsável pela ENTREGA no Acessórias (Config.RespEntrega).
  acessoriasRespEntrega String?   @map("acessorias_resp_entrega")
  /// Departamento no Acessórias (Config.DptoNome): Fiscal, Trabalhista, Pessoal, Contábil...
  /// Usado pelo agregador pra decidir qual ClienteAreaContratada atualizar.
  acessoriasDpto        String?   @map("acessorias_dpto")

  // ── Log de entrega manual (módulo /minhas-obrigacoes) ──
  /// Usuário que marcou esta execução como entregue.
  entreguePor       String?   @map("entregue_por")
  /// Quando foi marcada como entregue.
  entregueEm        DateTime? @map("entregue_em")
  /// Observação livre do gestor ao entregar (opcional). Max 500.
  entregaObservacao String?   @map("entrega_observacao") @db.VarChar(500)
  /// URL do anexo enviado na entrega (PDF do protocolo, recibo, etc.).
  entregaAnexoUrl   String?   @map("entrega_anexo_url") @db.Text

  servico      Servico                  @relation(fields: [servicoId], references: [id])
  cliente      Cliente                  @relation("ClienteServicoExecucoes", fields: [clienteId], references: [id])
  passos       ServicoExecucaoPasso[]
  watchers     ServicoExecucaoWatcher[]
  eventos      ServicoExecucaoEvento[]
  processo     Processo?                @relation(fields: [processoId], references: [id], onDelete: SetNull)
  predecessor  ServicoExecucao?         @relation("Sucessores", fields: [predecessorExecucaoId], references: [id], onDelete: SetNull)
  sucessores   ServicoExecucao[]        @relation("Sucessores")
  encadeamento ServicoEncadeamento?     @relation(fields: [encadeamentoId], references: [id], onDelete: SetNull)

  @@index([servicoId])
  @@index([clienteId])
  @@index([status])
  @@index([responsavelId])
  @@index([prazoLimite])
  @@index([processoId])
  @@index([predecessorExecucaoId])
  @@index([acessoriasEntId])
  @@index([acessoriasLastDH])
  @@map("servico_execucoes")
}

model ServicoExecucaoPasso {
  id                   String    @id @default(cuid())
  execucaoId           String    @map("execucao_id")
  passoId              String    @map("passo_id")
  etapaNome            String    @map("etapa_nome")
  passoNome            String    @map("passo_nome")
  ordem                Int
  // Snapshot do flag de obrigatoriedade do template no momento da criação.
  // togglePasso bloqueia conclusão se houver passo OBRIGATÓRIO anterior
  // (na ordem) ainda nao concluido.
  obrigatorio          Boolean   @default(true)
  // Snapshot do flag de ignorável do template — só passos com este flag true
  // podem ser ignorados durante a execução.
  permiteIgnorar       Boolean   @default(false) @map("permite_ignorar")
  concluido            Boolean   @default(false)
  concluidoPor         String?   @map("concluido_por")
  concluidoEm          DateTime? @map("concluido_em")
  // Estado "ignorado" — passo pulado pelo usuário (apenas se permiteIgnorar=true).
  // Conta como "fechado" pra desbloqueio de passos seguintes e pra concluir
  // a execução, mas é distinto de "concluído" no histórico/relatórios.
  ignorado             Boolean   @default(false)
  ignoradoPor          String?   @map("ignorado_por")
  ignoradoEm           DateTime? @map("ignorado_em")
  ignoradoMotivo       String?   @map("ignorado_motivo") @db.Text
  observacao           String?   @db.Text
  // Tracking de tempo por passo
  iniciadoEm           DateTime? @map("iniciado_em")
  tempoGastoMinutos    Int?      @map("tempo_gasto_minutos")
  // Dependencia copiada do template — refere a outro ServicoExecucaoPasso
  // da mesma execucao. togglePasso valida que esse esteja concluido antes
  // de marcar este como concluido.
  dependeDoExecPassoId String?   @map("depende_do_exec_passo_id")

  execucao    ServicoExecucao                  @relation(fields: [execucaoId], references: [id], onDelete: Cascade)
  comentarios ServicoExecucaoPassoComentario[]
  anexos      ServicoExecucaoPassoAnexo[]

  @@index([execucaoId])
  @@map("servico_execucoes_passos")
}

// Comentarios inline por passo — colaboracao entre equipe durante a execucao
model ServicoExecucaoPassoComentario {
  id          String   @id @default(cuid())
  execPassoId String   @map("exec_passo_id")
  userId      String?  @map("user_id")
  mensagem    String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  execPasso ServicoExecucaoPasso @relation(fields: [execPassoId], references: [id], onDelete: Cascade)

  @@index([execPassoId])
  @@map("servico_execucao_passo_comentarios")
}

// Anexos por passo — uploads de comprovantes, fotos, documentos
model ServicoExecucaoPassoAnexo {
  id          String   @id @default(cuid())
  execPassoId String   @map("exec_passo_id")
  userId      String?  @map("user_id")
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")
  createdAt   DateTime @default(now()) @map("created_at")

  execPasso ServicoExecucaoPasso @relation(fields: [execPassoId], references: [id], onDelete: Cascade)

  @@index([execPassoId])
  @@map("servico_execucao_passo_anexos")
}

// Watchers — usuarios notificados sobre eventos importantes da execucao
// (passos concluidos, pausa, conclusao geral, etc) sem precisar ser responsaveis
model ServicoExecucaoWatcher {
  id         String   @id @default(cuid())
  execucaoId String   @map("execucao_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  execucao ServicoExecucao @relation(fields: [execucaoId], references: [id], onDelete: Cascade)

  @@unique([execucaoId, userId])
  @@index([userId])
  @@map("servico_execucao_watchers")
}

// Timeline de eventos da execucao — audit trail completo do que aconteceu
model ServicoExecucaoEvento {
  id         String   @id @default(cuid())
  execucaoId String   @map("execucao_id")
  userId     String?  @map("user_id")
  // tipo: 'criado', 'iniciado', 'pausado', 'retomado', 'passo_concluido',
  // 'passo_reaberto', 'comentario', 'anexo', 'concluido', 'cancelado'
  tipo       String
  descricao  String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  execucao ServicoExecucao @relation(fields: [execucaoId], references: [id], onDelete: Cascade)

  @@index([execucaoId])
  @@map("servico_execucao_eventos")
}

// ============================================================
// Processos — agregador de cadeia de execucoes encadeadas
// ============================================================
//
// Um Processo agrupa N execucoes que vieram de um mesmo orcamento (ou criacao
// manual) seguindo o DAG definido pelos ServicoEncadeamento. Casos de uso:
// "Transferencia de Contabilidade", "Constituicao de Cliente" — onde o ciclo
// envolve varios servicos-template em sequencia/paralelo.
//
// Decisoes (Fase 1):
//  - 1a: orcamento finaliza ao concluir a execucao raiz (nao a cadeia toda)
//  - 2b: sucessor opcional pode ser pulado pelo gestor (status PULADO na execucao)
//  - 3b: sucessores rodam em paralelo (todas elegiveis sao criadas de uma vez)
//  - 4b: condicao por aresta (avaliada em runtime contra cliente/orcamento)
//  - 5b: entidade Processo agregadora (este model)

model Processo {
  id              String         @id @default(cuid())
  nome            String // ex: "Transferencia - ACME LTDA"
  clienteId       String         @map("cliente_id")
  orcamentoId     String?        @map("orcamento_id")
  responsavelId   String?        @map("responsavel_id")
  empresaId       String?        @map("empresa_id")
  status          ProcessoStatus @default(EM_ANDAMENTO)
  // Servico-template que foi usado como raiz da cadeia
  servicoRaizId   String         @map("servico_raiz_id")
  iniciadoEm      DateTime       @default(now()) @map("iniciado_em")
  concluidoEm     DateTime?      @map("concluido_em")
  // Cancelamento manual: motivo declarado pelo gestor
  canceladoMotivo String?        @map("cancelado_motivo") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  cliente     Cliente           @relation("ClienteProcessos", fields: [clienteId], references: [id])
  servicoRaiz Servico           @relation("ProcessoRaiz", fields: [servicoRaizId], references: [id])
  execucoes   ServicoExecucao[]
  eventos     ProcessoEvento[]

  @@index([clienteId])
  @@index([status])
  @@index([orcamentoId])
  @@index([empresaId])
  @@map("processos")
}

// Aresta do DAG no nivel do template — define que ao concluir o servico
// origem, dispara a criacao de uma execucao do servico destino.
// Posições visuais salvas do editor de fluxograma de Serviços (/servicos/[id] → Fluxo).
// Chaveado por (raizId, nodeId): cada serviço-raiz tem seu próprio layout.
// Se o user mover o mesmo serviço quando aberto a partir de raízes diferentes,
// cada raiz mantém sua posição independente.
model ServicoFluxoLayout {
  id        String   @id @default(cuid())
  raizId    String   @map("raiz_id") // ID do serviço-raiz da visão
  nodeId    String   @map("node_id") // Servico.id desenhado no canvas
  x         Float
  y         Float
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([raizId, nodeId])
  @@index([raizId])
  @@map("servico_fluxo_layouts")
}

model ServicoEncadeamento {
  id               String   @id @default(cuid())
  servicoOrigemId  String   @map("servico_origem_id")
  servicoDestinoId String   @map("servico_destino_id")
  ordem            Int      @default(0)
  // Se true, cria sucessor com status EM_ANDAMENTO. Se false, cria com
  // status AGUARDANDO_INICIO — gestor confirma manualmente.
  iniciaAuto       Boolean  @default(true) @map("inicia_auto")
  // Se false, sucessor entra em AGUARDANDO_INICIO mesmo com iniciaAuto=true
  // (gestor pode "pular" — vira PULADO).
  obrigatorio      Boolean  @default(true)
  // Se true, sucessor herda o responsavel da execucao predecessora.
  // Se false, sucessor fica sem responsavel (gestor precisa atribuir).
  herdaResponsavel Boolean  @default(true) @map("herda_responsavel")
  // Condicao opcional avaliada em runtime contra cliente/orcamento.
  // Formato JSON: { all?: Regra[], any?: Regra[] } — ver packages/types/src/processo.ts
  // Se condicao retorna false, sucessor nao e criado (registra evento "sucessor_pulado_condicao").
  condicao         Json?
  observacao       String?  @db.Text // texto de orientacao ao gestor
  // Rótulo curto exibido em cima da aresta no editor visual (ex: "Sim", "Não",
  // "Aprovado pelo cliente"). Opcional — sem rótulo, a aresta fica limpa.
  rotulo           String?  @db.VarChar(80)
  createdAt        DateTime @default(now()) @map("created_at")

  servicoOrigem    Servico           @relation("EncadeamentoOrigem", fields: [servicoOrigemId], references: [id], onDelete: Cascade)
  servicoDestino   Servico           @relation("EncadeamentoDestino", fields: [servicoDestinoId], references: [id], onDelete: Cascade)
  execucoesGeradas ServicoExecucao[]

  @@unique([servicoOrigemId, servicoDestinoId])
  @@index([servicoOrigemId])
  @@map("servico_encadeamentos")
}

// ============================================================
// Recorrência automática de serviço — disparada por scheduler diário.
// 1:1 com Servico. Calcula `proximaExecucao` antecipadamente; cron lê
// registros ativos com proximaExecucao<=now e cria ServicoExecucao.
// ============================================================
enum RecorrenciaFrequencia {
  DIARIA
  SEMANAL
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum RecorrenciaAncoragem {
  /**
   * Dia do mês fixo (valorAncoragem = 1..28). Ex: dia 20 todo mês.
   */
  DIA_DO_MES
  /**
   * N-ésimo dia útil do mês (valorAncoragem = 1..23). Ex: 5º dia útil.
   */
  DIA_UTIL
  /**
   * X dias após o fim da competência. Ex: dia 10 após mês de referência.
   */
  DIAS_APOS_COMPETENCIA
}

/**
 * Como ajustar a data calculada quando cai em final de semana ou feriado nacional.
 */
enum AjusteVencimento {
  /**
   * Mantém a data exata (default — preserva legado e regras já oficialmente definidas em dia útil).
   */
  MANTER
  /**
   * Antecipa para o dia útil imediatamente anterior. Comum em 13º salário, pagamentos contratuais.
   */
  ANTECIPAR
  /**
   * Posterga para o próximo dia útil. Comum em obrigações fiscais (DAS, ICMS, ISS).
   */
  POSTERGAR
}

model ServicoRecorrencia {
  id                String                @id @default(cuid())
  servicoId         String                @unique @map("servico_id")
  ativa             Boolean               @default(true)
  frequencia        RecorrenciaFrequencia
  ancoragem         RecorrenciaAncoragem  @default(DIA_DO_MES)
  /**
   * Significado depende da ancoragem: dia do mês (1..28), nº dia útil ou dias após competência.
   */
  valorAncoragem    Int                   @map("valor_ancoragem")
  /**
   * Offset da competência em meses. 0 = mês corrente; 1 = competência mês anterior (típico fiscal).
   */
  competenciaOffset Int                   @default(1) @map("competencia_offset")
  /**
   * Responsável padrão atribuído à execução criada pelo cron.
   */
  responsavelPadrao String?               @map("responsavel_padrao")
  ultimaExecucao    DateTime?             @map("ultima_execucao")
  /**
   * Pré-calculado quando regra muda. Scheduler filtra por <=now.
   */
  proximaExecucao   DateTime?             @map("proxima_execucao")
  // ── Regras compostas (opcional). Quando preenchidos, substituem o modo simples
  // (ancoragem/valorAncoragem) e permitem múltiplos disparos por período.
  // Por que: situações como "DAS dia 20 e outra obrigação dia 5" exigem 2+ datas/mês
  // sem precisar de 2 ServicoRecorrencia separados. Mantém 1:1 com Servico.
  /**
   * /** Dias do mês a disparar (1..31; usar 31 como sentinela para "último dia"). Vazio = usa ancoragem clássica.
   */
  diasDoMes         Int[]                 @default([]) @map("dias_do_mes")
  /**
   * Meses do ano elegíveis (1..12). Vazio = todos os meses (default). Usado pra regras tipo trimestral em meses fixos.
   */
  mesesDoAno        Int[]                 @default([]) @map("meses_do_ano")
  /**
   * Quando true, scheduler usa diasDoMes/mesesDoAno em vez de frequencia+ancoragem (mesmo se vazios → regra inválida).
   */
  modoPersonalizado Boolean               @default(false) @map("modo_personalizado")
  /**
   * Política aplicada quando a data calculada cai em final de semana ou feriado nacional.
   * MANTER = não muda · ANTECIPAR = dia útil anterior · POSTERGAR = próximo dia útil.
   */
  ajusteVencimento  AjusteVencimento      @default(MANTER) @map("ajuste_vencimento")
  empresaId         String?               @map("empresa_id")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  servico Servico @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@index([proximaExecucao, ativa])
  @@map("servico_recorrencias")
}

/**
 * Override de vencimento por mês — espelha os campos ObrD01..ObrD12 do
 * Acessórias. Quando preenchido pra um (servico, mes), sobrescreve a regra
 * padrão de ServicoRecorrencia naquele mês específico.
 * Encoding do campo `valor` (idem Acessórias, mantido por compatibilidade):
 * 0      = "Não tem" — não gera vencimento neste mês
 * 1..31  = "Todo dia N" — dia fixo do mês (clamp natural pra fevereiro)
 * 51..70 = "N-ésimo dia útil" (51=1º, 52=2º, ..., 70=20º)
 * 90     = "Último dia útil" do mês
 */
model ServicoVencimentoMensal {
  id        String   @id @default(cuid())
  servicoId String   @map("servico_id")
  /**
   * Mês 1-12 (Janeiro=1).
   */
  mes       Int
  /**
   * Valor encoded — ver doc do modelo.
   */
  valor     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  servico Servico @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@unique([servicoId, mes])
  @@index([servicoId])
  @@map("servico_vencimentos_mensais")
}

// ============================================================
// Regras de notificação automática — disparadas por eventos no
// ciclo de vida da execução. Multi-canal (hoje só EMAIL).
// ============================================================
enum NotificacaoEvento {
  INICIADA
  CONCLUIDA
  ATRASADA
  PRAZO_PROXIMO
  PAUSADA
  CANCELADA
  AGUARDANDO_RESPOSTA
}

enum NotificacaoCanal {
  EMAIL
}

enum NotificacaoDestinatario {
  /**
   * Usuário atribuído à execução (ServicoExecucao.responsavelId)
   */
  RESPONSAVEL
  /**
   * Gestor do processo (Processo.responsavelId) ou líder da área
   */
  GESTOR
  /**
   * E-mail principal do cliente vinculado
   */
  CLIENTE
  /**
   * Lista de watchers cadastrados na execução
   */
  WATCHERS
  /**
   * Lista de e-mails livres (destinatariosCustom)
   */
  CUSTOM
}

model ServicoNotificacaoRegra {
  id                  String                  @id @default(cuid())
  servicoId           String                  @map("servico_id")
  ativa               Boolean                 @default(true)
  evento              NotificacaoEvento
  canal               NotificacaoCanal        @default(EMAIL)
  destinatariosTipo   NotificacaoDestinatario @map("destinatarios_tipo")
  /**
   * Quando destinatariosTipo=CUSTOM, lista de e-mails livres.
   */
  destinatariosCustom String[]                @default([]) @map("destinatarios_custom")
  assunto             String
  /**
   * HTML do TipTap com placeholders {{cliente.razaoSocial}} etc.
   */
  corpoHtml           String                  @map("corpo_html") @db.Text
  /**
   * Quando evento=PRAZO_PROXIMO, antecedência em horas (24 = avisa 1 dia antes).
   */
  antecedenciaHoras   Int?                    @map("antecedencia_horas")
  empresaId           String?                 @map("empresa_id")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  servico Servico                 @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  logs    ServicoNotificacaoLog[]

  @@index([servicoId, evento])
  @@map("servico_notificacao_regras")
}

// ============================================================
// Log de notificações enviadas — auditoria + idempotência.
// Unique composto previne envio duplicado em retries do engine.
// ============================================================
enum NotificacaoStatus {
  ENVIADO
  FALHA
}

model ServicoNotificacaoLog {
  id            String            @id @default(cuid())
  regraId       String            @map("regra_id")
  /**
   * ID da execução que disparou a notificação.
   */
  execucaoId    String            @map("execucao_id")
  evento        NotificacaoEvento
  /**
   * Lista de e-mails efetivamente atendidos no envio (snapshot).
   */
  destinatarios String[]          @default([])
  status        NotificacaoStatus
  erro          String?           @db.Text
  sentAt        DateTime          @default(now()) @map("sent_at")

  regra ServicoNotificacaoRegra @relation(fields: [regraId], references: [id], onDelete: Cascade)

  // Idempotência: uma regra dispara no máximo 1 vez por (execucao, evento).
  // Retries do engine não duplicam — UPSERT no insert.
  @@unique([regraId, execucaoId, evento])
  @@index([execucaoId])
  @@map("servico_notificacao_logs")
}

model ProcessoEvento {
  id         String   @id @default(cuid())
  processoId String   @map("processo_id")
  userId     String?  @map("user_id")
  // tipo: 'criado', 'execucao_criada', 'execucao_concluida', 'execucao_cancelada',
  //       'sucessor_pulado_condicao', 'sucessor_pulado_manual',
  //       'sucessor_iniciado_manual', 'concluido', 'cancelado'
  tipo       String
  descricao  String   @db.Text
  metadata   Json? // { execucaoId?, encadeamentoId?, ... }
  createdAt  DateTime @default(now()) @map("created_at")

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([processoId])
  @@map("processo_eventos")
}

// ============================================================
// Resposta de um bloco PERGUNTA — registra qual gestor respondeu,
// quando, quais opções foram escolhidas e observação livre. Cada
// resposta fecha uma execução de bloco PERGUNTA e dispara só os
// sucessores cujo rotulo casa com alguma opção escolhida.
// ============================================================
model ProcessoRespostaPergunta {
  id               String   @id @default(cuid())
  processoId       String?  @map("processo_id")
  execucaoId       String   @unique @map("execucao_id")
  // Serviço do bloco PERGUNTA respondido — guardamos snapshot do texto e
  // opções no momento da resposta pra histórico não quebrar se o template
  // for editado depois.
  servicoId        String   @map("servico_id")
  perguntaSnapshot String   @map("pergunta_snapshot") @db.Text
  opcoesSnapshot   Json     @map("opcoes_snapshot") // string[]
  opcoesEscolhidas Json     @map("opcoes_escolhidas") // string[]
  respondidoPor    String?  @map("respondido_por")
  respondidoEm     DateTime @default(now()) @map("respondido_em")
  observacao       String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([processoId])
  @@index([servicoId])
  @@map("processo_respostas_pergunta")
}

// ============================================================
// Pesquisa de Satisfacao (Pos-Venda)
// ============================================================

model PesquisaSatisfacao {
  id               String    @id @default(cuid())
  token            String    @unique @default(cuid())
  clienteId        String?   @map("cliente_id")
  orcamentoId      String?   @map("orcamento_id")
  execucaoId       String?   @map("execucao_id")
  enviadaEm        DateTime? @map("enviada_em")
  respondidaEm     DateTime? @map("respondida_em")
  // Identificacao do respondente
  respondenteNome  String?   @map("respondente_nome")
  respondenteArea  String?   @map("respondente_area")
  respondenteEmail String?   @map("respondente_email")
  // Questoes padrao
  q1Atendeu        Boolean?  @map("q1_atendeu") // Atendeu as expectativas?
  q2Qualidade      Int?      @map("q2_qualidade") // 1-5 — Qualidade do atendimento
  q3Recomendaria   Boolean?  @map("q3_recomendaria") // Recomendaria nossos servicos?
  // NPS classico (0-10) e comentario livre
  nota             Int?
  comentario       String?   @db.Text
  empresaId        String?   @map("empresa_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([clienteId])
  @@index([orcamentoId])
  @@index([token])
  @@map("pesquisas_satisfacao")
}

// ============================================================
// Contratos — Cláusulas versionadas + Templates + Instâncias + Assinaturas
// ============================================================

// Categoria da cláusula — agrupa visualmente no editor e ajuda a montar o
// "Objeto" do contrato (cláusulas OBJETO entram automaticamente quando um
// Servico que as referencia é vinculado).
enum ClausulaCategoria {
  OBJETO // cláusula 1.x — descreve um serviço prestado
  RESPONSABILIDADES // cláusula 2.x — responsabilidades CONTRATADA
  OBRIGACOES // cláusula 3.x — obrigações CONTRATANTE
  DISPOSICOES // cláusula 4.x — disposições gerais
  DOCUMENTACAO // cláusula 5.x — envio de documentação
  PRIVACIDADE // cláusula 6.x — LGPD
  HONORARIOS // cláusula 7.x — honorários
  EXTRAORDINARIOS // cláusula 8.x — serviços extraordinários
  VIGENCIA // cláusula 9.x — vigência e rescisão
  FORO // cláusula 10.x — foro
  OUTROS
}

enum ContratoStatus {
  RASCUNHO
  AGUARDANDO_ASSINATURA // contadora já assinou; aguardando cliente
  ASSINADO // ambas as partes assinaram
  VIGENTE // assinado e dentro do período de vigência
  ENCERRADO // distrato ou prazo expirado
  CANCELADO // cancelado antes de assinatura
}

enum ContratoAssinaturaTipo {
  WEBPKI // Web PKI (cert ICP-Brasil instalado no PC do usuário)
  GOVBR // API gov.br Assinatura Eletronica
  SERPROID // API SERPRO Neo iD (cert na nuvem do SERPRO; reservado p/ futuro)
  SERVER // Servidor assina com cert da empresa (.env CERTIFICADO_PATH) + TSA SERPRO opcional
  ACEITE // Aceite simples sem cert (audit trail: IP+nome+timestamp)
}

enum ContratoAssinaturaParte {
  CONTRATADA
  CONTRATANTE
}

// Cláusula versionada. (codigo, versao) é único — cada edição cria uma nova
// versão e despublica a anterior. O codigo é estável e identifica
// semanticamente a cláusula (ex: "OBJ.CONTABIL.SN" ou "RESP.5"). Os contratos
// já emitidos guardam um snapshot do texto, então editar uma versão NUNCA
// quebra contratos antigos.
model Clausula {
  id          String            @id @default(cuid())
  codigo      String // identificador estável entre versões
  versao      Int               @default(1)
  titulo      String
  conteudo    String            @db.Text // HTML do RichEditor
  categoria   ClausulaCategoria @default(OUTROS)
  // Hierarquia: cláusula 3 é pai de 3.1, 3.2... A cláusula raiz tem parentId null
  // e ordem dentro do template. Filhos têm ordem dentro do pai.
  parentId    String?           @map("parent_id")
  parent      Clausula?         @relation("ClausulaHierarquia", fields: [parentId], references: [id], onDelete: SetNull)
  filhos      Clausula[]        @relation("ClausulaHierarquia")
  ordem       Int               @default(0)
  // Apenas cláusulas publicadas entram em novos contratos. Despublicadas
  // continuam acessíveis via histórico mas não são propostas.
  publicada   Boolean           @default(false)
  publicadaEm DateTime?         @map("publicada_em")
  // Notas internas sobre o motivo da nova versão (changelog)
  notasVersao String?           @map("notas_versao") @db.Text
  empresaId   String?           @map("empresa_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  templates ContratoTemplateClausula[]
  // (não há relação direta para ServicoClausula porque o vínculo é por
  //  codigo, não por id — busca-se em runtime a versão publicada mais recente)
  snapshots ContratoClausulaSnapshot[]

  @@unique([codigo, versao])
  @@index([codigo, publicada])
  @@index([categoria])
  @@index([parentId])
  @@index([empresaId])
  @@map("clausulas")
}

// Template de contrato — agrupa cláusulas para um cenário. Ex: "Simples
// Nacional COM IE", "Presumido SEM movimento", "Contrato Fiscal Filial ES".
// As condições (regimeTributario, temIE, comMovimento) ajudam a sugerir
// o template ao gerar contrato a partir de um orçamento.
model ContratoTemplate {
  id               String   @id @default(cuid())
  nome             String
  descricao        String?  @db.Text
  // Filtros sugestivos (não bloqueiam — apenas auxiliam na escolha)
  regimeTributario String?  @map("regime_tributario") // SIMPLES | PRESUMIDO | REAL | SEM_MOVIMENTO
  temIE            Boolean? @map("tem_ie")
  comMovimento     Boolean? @map("com_movimento")
  ativo            Boolean  @default(true)
  empresaId        String?  @map("empresa_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  clausulas ContratoTemplateClausula[]
  contratos Contrato[]

  @@index([regimeTributario])
  @@index([empresaId])
  @@map("contrato_templates")
}

// Vínculo template <-> cláusula. Por padrão usa "fixaVersao=false" que faz
// o sistema buscar SEMPRE a versão publicada mais recente do mesmo codigo.
// Se fixaVersao=true, usa exatamente esta cláusulaId — útil para travar
// um template em uma redação específica.
model ContratoTemplateClausula {
  id         String  @id @default(cuid())
  templateId String  @map("template_id")
  clausulaId String  @map("clausula_id")
  ordem      Int     @default(0)
  fixaVersao Boolean @default(false) @map("fixa_versao")

  template ContratoTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  clausula Clausula         @relation(fields: [clausulaId], references: [id], onDelete: Cascade)

  @@unique([templateId, clausulaId])
  @@index([templateId])
  @@map("contrato_template_clausulas")
}

// Vínculo Servico → Cláusula (codigo, não versão). Quando o serviço é
// adicionado a um orçamento aprovado e este gera um contrato, suas cláusulas
// OBJETO entram automaticamente no contrato (versão publicada mais recente).
model ServicoClausula {
  id             String @id @default(cuid())
  servicoId      String @map("servico_id")
  clausulaCodigo String @map("clausula_codigo") // referencia codigo, não versão
  ordem          Int    @default(0)

  servico Servico @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  // (não cria FK direta para Clausula porque codigo+versao é o id real e
  // queremos versão flutuante — busca em runtime)

  @@unique([servicoId, clausulaCodigo])
  @@index([servicoId])
  @@map("servico_clausulas")
}

// Contrato emitido para um cliente. Snapshot do texto vai em
// ContratoClausulaSnapshot — editar a cláusula original NÃO afeta este
// contrato. Suporta vínculo com orçamento (workflow APROVADO → CONTRATO).
model Contrato {
  id          String         @id @default(cuid())
  numero      Int            @default(autoincrement())
  // Token público para o cliente acessar e assinar sem login
  token       String         @unique @default(cuid())
  clienteId   String         @map("cliente_id")
  orcamentoId String?        @map("orcamento_id")
  templateId  String         @map("template_id")
  status      ContratoStatus @default(RASCUNHO)

  // Vigência
  dataInicio     DateTime? @map("data_inicio")
  dataFim        DateTime? @map("data_fim") // null = prazo indeterminado
  prazoAvisoDias Int       @default(30) @map("prazo_aviso_dias")

  // Honorários (snapshot — congelado no contrato)
  honorarioMensal         Decimal? @map("honorario_mensal") @db.Decimal(12, 2)
  honorarioFormaPagamento String?  @map("honorario_forma_pagamento")
  diaVencimento           Int?     @map("dia_vencimento") // 1-31

  // PDF gerado (S3/MinIO)
  pdfUrl  String? @map("pdf_url")
  pdfHash String? @map("pdf_hash") // SHA-256 pra auditoria

  // Snapshot dos dados das partes no momento da emissão
  contratanteRazaoSocial   String? @map("contratante_razao_social")
  contratanteCnpj          String? @map("contratante_cnpj")
  contratanteEndereco      String? @map("contratante_endereco")
  contratanteRepresentante String? @map("contratante_representante")
  contratanteCpfRep        String? @map("contratante_cpf_rep")

  observacoes String? @db.Text

  empresaId          String?   @map("empresa_id")
  responsavelId      String?   @map("responsavel_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  encerradoEm        DateTime? @map("encerrado_em")
  motivoEncerramento String?   @map("motivo_encerramento") @db.Text

  cliente   Cliente          @relation(fields: [clienteId], references: [id])
  orcamento Orcamento?       @relation(fields: [orcamentoId], references: [id], onDelete: SetNull)
  template  ContratoTemplate @relation(fields: [templateId], references: [id])

  snapshots   ContratoClausulaSnapshot[]
  servicos    ContratoServico[]
  assinaturas ContratoAssinatura[]
  eventos     ContratoEvento[]

  @@index([clienteId])
  @@index([status])
  @@index([orcamentoId])
  @@index([token])
  @@index([empresaId])
  @@map("contratos")
}

// Snapshot — o texto da cláusula CONGELADO no momento em que o contrato foi
// emitido (ou re-renderizado). Mesmo que a Clausula original seja editada
// (nova versão) ou removida, este snapshot permanece intacto.
model ContratoClausulaSnapshot {
  id         String            @id @default(cuid())
  contratoId String            @map("contrato_id")
  clausulaId String            @map("clausula_id") // versão que originou
  // Cópia para auditoria — sobrevive mesmo se a Clausula sumir
  codigo     String
  versao     Int
  titulo     String
  conteudo   String            @db.Text // HTML JÁ RENDERIZADO (placeholders substituídos)
  categoria  ClausulaCategoria
  ordem      Int               @default(0)
  parentId   String?           @map("parent_id") // referência hierárquica entre snapshots do mesmo contrato

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  clausula Clausula @relation(fields: [clausulaId], references: [id], onDelete: Restrict)

  @@index([contratoId])
  @@index([clausulaId])
  @@map("contrato_clausula_snapshots")
}

// Vínculo Contrato <-> Servico — registra os serviços que estão no
// "Objeto" deste contrato (geralmente herdados do orçamento aprovado).
model ContratoServico {
  id          String  @id @default(cuid())
  contratoId  String  @map("contrato_id")
  servicoId   String  @map("servico_id")
  // Snapshot do nome no momento da emissão (caso o Servico seja renomeado depois)
  nomeServico String  @map("nome_servico")
  categoria   String?
  ordem       Int     @default(0)

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  servico  Servico  @relation(fields: [servicoId], references: [id])

  @@unique([contratoId, servicoId])
  @@index([contratoId])
  @@map("contrato_servicos")
}

// Uma assinatura é uma linha — pode haver múltiplas (CONTRATADA + CONTRATANTE
// no mínimo). Tipo registra como foi assinado (Web PKI, gov.br ou aceite).
// O PKCS#7 da assinatura é guardado em base64 quando aplicável.
model ContratoAssinatura {
  id                 String                  @id @default(cuid())
  contratoId         String                  @map("contrato_id")
  parte              ContratoAssinaturaParte
  tipo               ContratoAssinaturaTipo
  // Identificação do signatário (sempre preenchidos)
  signatarioNome     String                  @map("signatario_nome")
  signatarioDoc      String?                 @map("signatario_doc") // CPF ou CNPJ extraído do cert / aceite
  signatarioEmail    String?                 @map("signatario_email")
  // Dados do certificado (WEBPKI/GOVBR)
  certSubject        String?                 @map("cert_subject") @db.Text
  certIssuer         String?                 @map("cert_issuer") @db.Text
  certSerial         String?                 @map("cert_serial")
  certValidoAte      DateTime?               @map("cert_valido_ate")
  // Bytes da assinatura (PKCS#7 em base64) — null para ACEITE
  pkcs7Base64        String?                 @map("pkcs7_base64") @db.Text
  // Audit trail
  hashPdf            String?                 @map("hash_pdf") // SHA-256 do PDF assinado
  ip                 String?
  userAgent          String?                 @map("user_agent") @db.Text
  geolocation        String? // "lat,lon" se capturado
  // gov.br: id da transação para validação posterior
  govbrTransactionId String?                 @map("govbr_transaction_id")
  assinadoEm         DateTime                @default(now()) @map("assinado_em")

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([parte])
  @@map("contrato_assinaturas")
}

// Timeline de eventos do contrato — auditoria de mudanças de status,
// envios, assinaturas etc.
model ContratoEvento {
  id         String   @id @default(cuid())
  contratoId String   @map("contrato_id")
  userId     String?  @map("user_id")
  tipo       String // criado | enviado | assinado_contratada | assinado_cliente | vigente | encerrado | cancelado
  descricao  String?
  metadata   Json? // dados auxiliares (ex: hash anterior x novo)
  createdAt  DateTime @default(now()) @map("created_at")

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@map("contrato_eventos")
}

// ============================================================
// Dashboard customizável — layout salvo por empresa pelo master
// ============================================================
model DashboardLayout {
  id        String   @id @default(cuid())
  empresaId String   @unique @map("empresa_id")
  // JSON: array de { i: string (widgetId), x, y, w, h, minW?, minH? }
  layout    Json
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dashboard_layouts")
}

/// Layout pessoal do dashboard por usuário. Se a linha existir, é usada como
/// override sobre o DashboardLayout da empresa. Permite cada user ter sua
/// própria organização de widgets persistente entre máquinas.
model DashboardLayoutUser {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  empresaId String?  @map("empresa_id")
  // JSON: mesmo shape do DashboardLayout (array de SavedItem)
  layout    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("dashboard_layouts_user")
}

// ============================================================
// Chat Interno — mensagens em tempo real entre usuários
// ============================================================
// MVP: DMs 1:1, grupos multi-pessoa, anexos, indicador "digitando" + lido.
// Presença (online/ausente/offline) é derivada do User.lastActivityAt
// (mesmo tracking usado pelo painel "Usuários online" do Service Manager).
//
// `isGrupo=false` → DM. Quando 2 usuários iniciam DM, criamos 1 ChatConversa
// + 2 ChatParticipante. Lookup feito por interseção de participantes (não
// guardamos par ordenado pra evitar duplicação).

model ChatConversa {
  id               String    @id @default(cuid())
  nome             String?   // só pra grupos; DMs usam nome do "outro"
  isGrupo          Boolean   @default(false) @map("is_grupo")
  criadorId        String    @map("criador_id")
  /// Cache do timestamp da última mensagem — usado pra ordenar conversas
  /// na lista sem precisar de subquery a cada listagem.
  ultimaMensagemEm DateTime? @map("ultima_mensagem_em")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  participantes ChatParticipante[]
  mensagens     ChatMensagem[]

  @@index([ultimaMensagemEm])
  @@map("chat_conversas")
}

model ChatParticipante {
  id          String       @id @default(cuid())
  conversaId  String       @map("conversa_id")
  conversa    ChatConversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  usuarioId   String       @map("usuario_id")
  usuario     User         @relation("ChatParticipanteUser", fields: [usuarioId], references: [id])
  /// Timestamp da última mensagem que o user marcou como lida. Mensagens com
  /// createdAt > lastReadAt contam pro unreadCount.
  lastReadAt  DateTime?    @map("last_read_at")
  /// 'admin' ou 'membro' — só relevante em grupos. DMs ignoram.
  papel       String       @default("membro")
  /// "Excluir conversa pra mim" — soft hide do lado do usuário. Quando uma
  /// nova mensagem chega, o backend zera esse campo e a conversa reaparece.
  hiddenAt    DateTime?    @map("hidden_at")
  joinedAt    DateTime     @default(now()) @map("joined_at")

  @@unique([conversaId, usuarioId])
  @@index([usuarioId])
  @@map("chat_participantes")
}

model ChatMensagem {
  id         String       @id @default(cuid())
  conversaId String       @map("conversa_id")
  conversa   ChatConversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  autorId    String       @map("autor_id")
  /// Texto puro (sem HTML) — UI escapa na renderização. Mentions são gravadas
  /// como `<@userId>` no texto e a UI resolve em runtime via lista de participantes.
  conteudo   String       @db.Text
  editedAt   DateTime?    @map("edited_at")
  /// Soft delete — mensagem fica no histórico mas UI mostra "mensagem apagada".
  deletedAt  DateTime?    @map("deleted_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  anexos    ChatAnexo[]
  reactions ChatReaction[]

  @@index([conversaId, createdAt])
  @@map("chat_mensagens")
}

/// Reações de emoji em mensagens — múltiplos users podem reagir com o mesmo
/// emoji (agregado na UI por count). Único por user/emoji/mensagem.
model ChatReaction {
  id          String       @id @default(cuid())
  mensagemId  String       @map("mensagem_id")
  mensagem    ChatMensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  usuarioId   String       @map("usuario_id")
  emoji       String
  createdAt   DateTime     @default(now()) @map("created_at")

  @@unique([mensagemId, usuarioId, emoji])
  @@index([mensagemId])
  @@map("chat_reactions")
}

model ChatAnexo {
  id         String       @id @default(cuid())
  mensagemId String       @map("mensagem_id")
  mensagem   ChatMensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  fileName   String       @map("file_name")
  fileUrl    String       @map("file_url")
  mimeType   String?      @map("mime_type")
  tamanho    Int          @default(0)
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([mensagemId])
  @@map("chat_anexos")
}

/// Configuração global do chat interno (singleton — sempre 1 linha).
/// Editável apenas pelo master em /configuracoes/chat.
model ChatConfig {
  id              String   @id @default(cuid())
  /// Minutos sem atividade antes do status virar 'ausente' automaticamente.
  ausenteAposMin  Int      @default(5) @map("ausente_apos_min")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("chat_config")
}

// ============================================================
// HelpDesk — Tickets de suporte interno (e externo via e-mail)
// ============================================================
// MVP voltado para TI; depois pode generalizar pra RH/Financeiro.
// Tabela dedicada (não compartilhada com Projetos como no legado).
//
// Roles efetivos:
//   - Solicitante: criador do ticket (interno ou externo via e-mail)
//   - Agente: user da área do helpdesk (lê/atua nos tickets da área)
//   - Líder de área (Area.leaderId): reatribui, gerencia
//   - Coordenador/Diretor/Master: tudo + configuração
//
// Permissão admin: slug "helpdesk" em UserPermission.

enum HelpdeskStatus {
  NOVO
  EM_ANDAMENTO
  AGUARDANDO_AUDITORIA // IA respondeu, aguarda revisão humana antes de fechar
  RESOLVIDO // técnico declarou; janela X dias pra confirmação/CSAT (UI exibe como "Pendente")
  CONCLUIDO // CSAT preenchido ou auto-fechado
  CANCELADO
}

enum HelpdeskPrioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum HelpdeskTipo {
  INCIDENTE // algo quebrou, precisa restaurar
  REQUISICAO // novo recurso/acesso/equipamento
  DUVIDA // pergunta, instrução
  MELHORIA // sugestão, evolução
}

model HelpdeskCategoria {
  id             String   @id @default(cuid())
  nome           String
  descricao      String?
  parentId       String?  @map("parent_id") // sub-categoria (Rede > Wi-Fi)
  areaId         String?  @map("area_id") // área padrão de roteamento
  slaPadraoHoras Int?     @map("sla_padrao_horas") // override por categoria
  cor            String? // hex opcional pra UI
  ativo          Boolean  @default(true)
  ordem          Int      @default(0)
  empresaId      String?  @map("empresa_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  parent   HelpdeskCategoria?  @relation("CategoriaHierarchy", fields: [parentId], references: [id])
  children HelpdeskCategoria[] @relation("CategoriaHierarchy")
  area     Area?               @relation(fields: [areaId], references: [id], onDelete: SetNull)
  empresa  Empresa?            @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  tickets  HelpdeskTicket[]

  @@index([empresaId, ativo])
  @@map("helpdesk_categorias")
}

model HelpdeskTicket {
  id        String @id @default(cuid())
  numero    Int    @default(autoincrement()) // visível como #HLP0001
  hash      String @unique @default(cuid()) // link público compartilhável
  titulo    String
  descricao String @db.Text // HTML (CKEditor/RichEditor)

  tipo       HelpdeskTipo       @default(INCIDENTE)
  prioridade HelpdeskPrioridade @default(MEDIA)
  status     HelpdeskStatus     @default(NOVO)
  tags       String[]           @default([]) // tags livres pra busca

  // Solicitante: interno (FK User) OU externo (email/nome avulsos quando vier por
  // e-mail inbound de um remetente que não está cadastrado)
  solicitanteId           String? @map("solicitante_id")
  solicitanteExternoEmail String? @map("solicitante_externo_email")
  solicitanteExternoNome  String? @map("solicitante_externo_nome")

  // Atribuição
  responsavelId String? @map("responsavel_id")

  // Categorização
  categoriaId String? @map("categoria_id")
  areaId      String? @map("area_id") // herda da categoria, mas pode ser overridden

  // Vínculo opcional com um ativo (TI). Quando setado, a página do ativo
  // mostra os tickets relacionados e a página do ticket exibe histórico
  // de manutenção do ativo.
  ativoId String? @map("ativo_id")

  // SLA — datas-chave
  prazoSla              DateTime? @map("prazo_sla") // deadline absoluto de resolução
  primeiroAtendimentoEm DateTime? @map("primeiro_atendimento_em") // primeira ação do agente
  resolvidoEm           DateTime? @map("resolvido_em") // status virou RESOLVIDO
  concluidoEm           DateTime? @map("concluido_em") // status virou CONCLUIDO
  // Para SLA pausado em AGUARDANDO_SOLICITANTE/TERCEIRO: marca início da pausa.
  // Quando retomar, soma (now - pausadoEm) em totalPausadoMs.
  pausadoEm             DateTime? @map("pausado_em")
  totalPausadoMs        BigInt    @default(0) @map("total_pausado_ms")

  // CSAT (obrigatório no fechamento)
  csatNota         Int?      @map("csat_nota") // 1-5
  csatComentario   String?   @map("csat_comentario") @db.Text
  csatRespondidoEm DateTime? @map("csat_respondido_em")

  // Notificação de SLA — marca pra evitar reenvio
  slaAlertadoEm  DateTime? @map("sla_alertado_em")
  slaEstouradoEm DateTime? @map("sla_estourado_em")

  // Triagem IA (#HLP0083 — sistema de pesos + plano de resolução)
  // aiScore     = soma dos pontos calculados pelo HelpdeskAiAgentService.calcularScore
  // aiElegivel  = score atingiu o scoreThreshold da config (decisão local, sem API)
  // aiPlano*    = plano gerado pela API do Claude (markdown + metadados estruturados)
  // Status do plano: pendente | aprovado | rejeitado. Aprovado vira mensagem no ticket;
  // rejeitado volta status pra NOVO e o operador trata manualmente.
  aiScore                Int?      @map("ai_score")
  aiElegivel             Boolean?  @map("ai_elegivel")
  aiPlano                String?   @map("ai_plano") @db.Text
  aiPlanoMeta            Json?     @map("ai_plano_meta")
  aiPlanoStatus          String?   @map("ai_plano_status")
  aiPlanoAprovadoPor     String?   @map("ai_plano_aprovado_por")
  aiPlanoAprovadoEm      DateTime? @map("ai_plano_aprovado_em")
  aiPlanoMotivoRejeicao  String?   @map("ai_plano_motivo_rejeicao") @db.Text

  arquivado Boolean  @default(false)
  ativo     Boolean  @default(true)
  empresaId String?  @map("empresa_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  solicitante User?              @relation("HelpdeskTicketSolicitante", fields: [solicitanteId], references: [id], onDelete: SetNull)
  responsavel User?              @relation("HelpdeskTicketResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  categoria   HelpdeskCategoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  area        Area?              @relation(fields: [areaId], references: [id], onDelete: SetNull)
  empresa     Empresa?           @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  ativoRef    Ativo?             @relation(fields: [ativoId], references: [id], onDelete: SetNull)
  mensagens   HelpdeskMensagem[]
  anexos      HelpdeskAnexo[]
  watchers    HelpdeskWatcher[]
  eventos     HelpdeskEvento[]
  aiDecisions HelpdeskAiDecision[]

  @@index([empresaId, status, arquivado])
  @@index([responsavelId])
  @@index([solicitanteId])
  @@index([prazoSla])
  @@index([ativoId])
  @@map("helpdesk_tickets")
}

model HelpdeskMensagem {
  id                String    @id @default(cuid())
  ticketId          String    @map("ticket_id")
  autorId           String?   @map("autor_id") // null = vindo por e-mail de remetente externo
  // Nome/email do autor externo (quando autorId é null)
  autorExternoNome  String?   @map("autor_externo_nome")
  autorExternoEmail String?   @map("autor_externo_email")
  conteudo          String    @db.Text // HTML
  interna           Boolean   @default(false) // true = nota privada (só agentes), não notifica solicitante
  editadoEm         DateTime? @map("editado_em")
  createdAt         DateTime  @default(now()) @map("created_at")

  ticket HelpdeskTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  autor  User?           @relation(fields: [autorId], references: [id], onDelete: SetNull)
  anexos HelpdeskAnexo[]

  @@index([ticketId])
  @@map("helpdesk_mensagens")
}

model HelpdeskAnexo {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  mensagemId String?  @map("mensagem_id") // null = anexo do ticket (criação)
  autorId    String?  @map("autor_id")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  mimeType   String?  @map("mime_type")
  tamanho    Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  ticket   HelpdeskTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  mensagem HelpdeskMensagem? @relation(fields: [mensagemId], references: [id], onDelete: SetNull)
  autor    User?             @relation(fields: [autorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("helpdesk_anexos")
}

model HelpdeskWatcher {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@index([userId])
  @@map("helpdesk_watchers")
}

model HelpdeskEvento {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  autorId   String?  @map("autor_id")
  // tipos: criado, atribuido, status_alterado, prioridade_alterada, prazo_alterado,
  //        categoria_alterada, mensagem_publica, nota_interna, anexo_adicionado,
  //        arquivado, desarquivado, sla_alertado, sla_estourado, csat_recebido
  tipo      String
  descricao String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  autor  User?          @relation(fields: [autorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("helpdesk_eventos")
}

/// Configuração singleton da triagem IA do helpdesk. Editável apenas
/// pelo master em /configuracoes/helpdesk-ia.
model HelpdeskAiConfig {
  id           String   @id @default(cuid())
  /// Master pode desligar a triagem rapidamente sem mexer no .env.
  enabled      Boolean  @default(true)
  /// Limite mensal de gasto em USD. Quando o consumo do mês ultrapassa,
  /// a triagem é pulada até o início do próximo mês. 0 = sem limite.
  capUsdMensal Decimal  @default(10) @map("cap_usd_mensal") @db.Decimal(10, 2)
  /// Limite mínimo/máximo de caracteres da descrição pra a IA processar.
  /// Fora dessa faixa o ticket é pulado (provável lixo ou exige humano).
  minCharsDescricao Int @default(20) @map("min_chars_descricao")
  maxCharsDescricao Int @default(10000) @map("max_chars_descricao")
  /// Score mínimo pra chamar a API. Tickets abaixo disso são marcados como
  /// não-elegíveis e NÃO consomem crédito (#HLP0083).
  scoreThreshold Int @default(30) @map("score_threshold")
  /// JSON com faixas e pesos editáveis pelo master. Formato:
  /// {
  ///   "faixasChars":  [{min, max, pontos}],
  ///   "faixasAnexos": [{min, max, pontos}],
  ///   "bonusCategoria": number,
  ///   "pesosTipo": { DUVIDA, INCIDENTE, REQUISICAO, MELHORIA }
  /// }
  /// null → o service aplica os defaults internos (ver DEFAULT_REGRAS_PESO).
  regrasPeso   Json?    @map("regras_peso")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("helpdesk_ai_config")
}

/// Auditoria das decisões da IA (Anthropic Claude) sobre cada ticket.
/// Grava input, decisão estruturada, custo e latência pra debugging e
/// análise de qualidade. 1 ticket pode ter N decisões se for reprocessado.
model HelpdeskAiDecision {
  id           String   @id @default(cuid())
  ticketId     String   @map("ticket_id")
  modelo       String // ex.: claude-sonnet-4-6
  /// 'simples' | 'complexo' | 'erro'
  complexidade String
  /// JSON com a resposta estruturada do modelo (categoria, prioridade,
  /// resposta proposta, raciocínio, deve_responder_publicamente, etc.)
  decisao      Json?
  /// Trecho do FAQ usado como contexto (limita 8000 chars pra economizar)
  contextoFaq  String?  @map("contexto_faq") @db.Text
  /// Tokens de input/output e custo estimado em USD (sonnet ~$3/MTok in, $15/MTok out)
  tokensInput  Int?     @map("tokens_input")
  tokensOutput Int?     @map("tokens_output")
  custoUsd     Decimal? @map("custo_usd") @db.Decimal(10, 6)
  /// Latência total da chamada (ms)
  duracaoMs    Int?     @map("duracao_ms")
  /// Mensagem de erro (se complexidade='erro')
  erro         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("helpdesk_ai_decisions")
}

// ============================================================
// Calendário de feriados
// ============================================================
/**
 * Classificação do feriado. Nacionais móveis (Páscoa/Carnaval/Corpus Christi) e
 * fixos seguem em feriados-br.ts (lib). Tabela cobre estaduais, municipais e
 * pontos facultativos, mais o que cada tenant precisar adicionar manualmente.
 */
enum FeriadoTipo {
  NACIONAL
  ESTADUAL
  MUNICIPAL
  PONTO_FACULTATIVO
}

model Feriado {
  id         String      @id @default(cuid())
  nome       String
  tipo       FeriadoTipo
  /// Data do feriado. Quando recorrente=true, dia/mês são o que importa (ano é referência).
  data       DateTime    @db.Date
  /// Quando true, vale todo ano (mesma data). Quando false, é específico daquele ano (ex.: ponto facultativo de 2026).
  recorrente Boolean     @default(true)
  /// UF brasileira (ex.: 'ES'). Obrigatório quando tipo = ESTADUAL ou MUNICIPAL.
  uf         String?     @db.VarChar(2)
  /// Nome do município. Obrigatório quando tipo = MUNICIPAL.
  cidade     String?
  /// Observação livre — útil pra referenciar a lei municipal ou decreto estadual.
  observacao String?     @db.Text
  /// Quando null = template global (visível pra todos os tenants). Preenchido = só dessa empresa.
  empresaId  String?     @map("empresa_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tipo])
  @@index([uf, cidade])
  @@index([empresaId])
  @@index([data])
  @@map("feriados")
}

// ============================================================
// Templates de grupos de obrigação + vínculo cliente↔obrigação
// ============================================================
/**
 * Template de grupo de obrigações — agrupa N obrigações por regime/segmento/área.
 * Ex.: "Simples Nacional · Comércio" com DAS, DEFIS, NFC-e, Balancete. Usado pra
 * aplicar em lote no cliente (cria ClienteObrigacao em massa).
 */
model GrupoObrigacao {
  id              String     @id @default(cuid())
  nome            String
  slug            String     @unique
  descricao       String?    @db.Text
  /**
   * Quando preenchido, sugere o template pra clientes desta tributação.
   */
  tributacao      TaxRegime?
  /**
   * Slug do segmento (referencia SEGMENTO_SLUGS em packages/types). Opcional.
   */
  segmentoSlug    String?    @map("segmento_slug")
  /**
   * Área dominante (Fiscal | Trabalhista | Contabil | Comercial). Opcional.
   */
  area            String?
  /**
   * Cor de identificação visual (hex). Default herda do módulo Cadastros.
   */
  cor             String?    @default("#10b981")
  ativo           Boolean    @default(true)
  /**
   * Global (empresaId=null) ou da empresa.
   */
  empresaId       String?    @map("empresa_id")
  /**
   * Prefixos de CNAE aplicáveis (ex.: ["45", "47"] = Comércio). Match por
   * prefixo do cnaePrincipal do cliente. Vazio = qualquer atividade.
   */
  cnaesAplicaveis String[]   @default([]) @map("cnaes_aplicaveis")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itens             GrupoObrigacaoItem[]
  // Clientes que receberam ClienteObrigacao oriundas deste template (rastreio)
  clienteObrigacoes ClienteObrigacao[]

  @@index([tributacao])
  @@index([empresaId])
  @@map("grupos_obrigacao")
}

/**
 * Pivot N:M GrupoObrigacao ↔ Servico (obrigação).
 */
model GrupoObrigacaoItem {
  id          String  @id @default(cuid())
  grupoId     String  @map("grupo_id")
  servicoId   String  @map("servico_id")
  /**
   * Quando true, esta obrigação é OBRIGATÓRIA do template (sempre aplicada).
   * Quando false, é sugestão — pode ser desmarcada na hora de aplicar.
   */
  obrigatoria Boolean @default(true)
  ordem       Int     @default(0)

  grupo   GrupoObrigacao @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  servico Servico        @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@unique([grupoId, servicoId])
  @@index([servicoId])
  @@map("grupos_obrigacao_itens")
}

/**
 * Vínculo Cliente ↔ Servico (obrigação). Cada cliente tem sua lista própria.
 * Originado de template (`vindoDeTemplateId`) ou cadastro manual (null).
 */
model ClienteObrigacao {
  id                       String            @id @default(cuid())
  clienteId                String            @map("cliente_id")
  servicoId                String            @map("servico_id")
  /**
   * Quando o vínculo veio de um template, aponta pra ele (rastreabilidade).
   */
  vindoDeTemplateId        String?           @map("vindo_de_template_id")
  ativo                    Boolean           @default(true)
  observacao               String?           @db.Text
  /**
   * Override do ajuste de vencimento por cliente (FDS/feriado).
   * Quando null, usa o ajuste da ServicoRecorrencia global.
   */
  ajusteVencimentoOverride AjusteVencimento? @map("ajuste_vencimento_override")
  empresaId                String?           @map("empresa_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cliente  Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  servico  Servico         @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  template GrupoObrigacao? @relation(fields: [vindoDeTemplateId], references: [id], onDelete: SetNull)

  @@unique([clienteId, servicoId])
  @@index([servicoId])
  @@index([empresaId])
  @@index([vindoDeTemplateId])
  @@map("cliente_obrigacoes")
}

// ============================================================
// CORPORATIVO — Gestão de Ativos (TI / Patrimônio)
// ============================================================

enum AtivoStatus {
  ATIVO /// Em uso ativo
  MANUTENCAO /// Em conserto/revisão
  ESTOQUE /// Disponível, não atribuído
  EMPRESTADO /// Emprestado a cliente
  DESCARTADO /// Baixado por descarte
  PERDIDO /// Baixado por perda
}

enum AtivoMovimentacaoTipo {
  CADASTRO /// Criação do registro
  TRANSFERENCIA /// Mudança de responsável/área
  STATUS_CHANGE /// Mudança de status
  MANUTENCAO /// Vínculo de manutenção
  EMPRESTIMO /// Empréstimo a cliente
  DEVOLUCAO /// Devolução de empréstimo
  BAIXA /// Descarte/perda definitiva
}

enum AtivoManutencaoTipo {
  PREVENTIVA
  CORRETIVA
  UPGRADE
}

enum AtivoAnexoTipo {
  NOTA_FISCAL
  CONTRATO
  FOTO
  MANUAL
  OUTRO
}

/// Categoria-pai (Hardware, Software, Mobiliário, Equipamento de Rede).
/// Pais permitem agrupar categorias específicas + dar cor/ícone na UI.
model AtivoTipo {
  id        String   @id @default(cuid())
  nome      String
  cor       String? /// Hex usado em badges/chips
  icone     String? /// Nome de ícone lucide (laptop, monitor, mouse, etc)
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  empresaId String?  @map("empresa_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  categorias AtivoCategoria[]
  ativos     Ativo[]

  @@index([empresaId])
  @@map("ativo_tipos")
}

/// Categoria específica do ativo (Notebook, Monitor, Cadeira). Tem
/// `depreciacaoMeses` que dirige o cálculo de depreciação linear no Ativo.
model AtivoCategoria {
  id               String   @id @default(cuid())
  tipoId           String   @map("tipo_id")
  nome             String
  /// Vida útil em meses (depreciação linha reta). Null = sem depreciação.
  depreciacaoMeses Int?     @map("depreciacao_meses")
  ordem            Int      @default(0)
  ativo            Boolean  @default(true)
  empresaId        String?  @map("empresa_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tipo   AtivoTipo @relation(fields: [tipoId], references: [id], onDelete: Cascade)
  ativos Ativo[]

  @@index([tipoId])
  @@index([empresaId])
  @@map("ativo_categorias")
}

/// Ativo patrimonial. Cada registro representa UM item físico (ou licença
/// digital) com tag única + categorização + dados de aquisição + status atual
/// + atribuição (responsável/área/cliente em caso de empréstimo).
model Ativo {
  id   String @id @default(cuid())
  code Int    @default(autoincrement())

  // Identificação
  /// Etiqueta física única (ex: "TI-0001"). Pode ser gerada via QR code.
  tag       String  @unique
  nome      String
  descricao String? @db.Text

  // Categorização
  tipoId      String @map("tipo_id")
  categoriaId String @map("categoria_id")

  // Identidade física
  fabricante String?
  modelo     String?
  serial     String?
  patrimonio String? /// Número de patrimônio contábil (se aplicável)

  // Aquisição
  fornecedorId   String?   @map("fornecedor_id")
  notaFiscal     String?   @map("nota_fiscal")
  dataAquisicao  DateTime? @map("data_aquisicao")
  valorAquisicao Decimal?  @map("valor_aquisicao") @db.Decimal(12, 2)

  // Garantia
  garantiaInicio DateTime? @map("garantia_inicio")
  garantiaFim    DateTime? @map("garantia_fim")

  // Status atual
  status      AtivoStatus @default(ESTOQUE)
  localizacao String? /// Ex: "Sala TI", "Filial Vitória"

  // Atribuição atual (snapshot — histórico real fica em AtivoMovimentacao)
  responsavelId String? @map("responsavel_id")
  areaId        String? @map("area_id")
  clienteId     String? @map("cliente_id")

  // Auditoria/inventário
  ultimoInventarioEm DateTime? @map("ultimo_inventario_em")
  observacoes        String?   @db.Text

  // Multi-tenant
  empresaId String? @map("empresa_id")

  // Soft delete (baixa lógica)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tipo        AtivoTipo      @relation(fields: [tipoId], references: [id])
  categoria   AtivoCategoria @relation(fields: [categoriaId], references: [id])
  fornecedor  Fornecedor?    @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  responsavel User?          @relation("AtivoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  area        Area?          @relation("AtivoArea", fields: [areaId], references: [id], onDelete: SetNull)
  cliente     Cliente?       @relation("AtivoCliente", fields: [clienteId], references: [id], onDelete: SetNull)

  movimentacoes   AtivoMovimentacao[]
  manutencoes     AtivoManutencao[]
  anexos          AtivoAnexo[]
  helpdeskTickets HelpdeskTicket[]

  @@index([tipoId])
  @@index([categoriaId])
  @@index([responsavelId])
  @@index([areaId])
  @@index([clienteId])
  @@index([fornecedorId])
  @@index([status])
  @@index([empresaId])
  @@index([isActive])
  @@map("ativos")
}

/// Log imutável de movimentações do ativo. Toda transferência, mudança de
/// status, manutenção registrada ou empréstimo gera uma linha aqui — alimenta
/// a aba "Histórico" no detalhe do ativo.
model AtivoMovimentacao {
  id      String                @id @default(cuid())
  ativoId String                @map("ativo_id")
  tipo    AtivoMovimentacaoTipo

  // Diff de atribuição (null se irrelevante pro tipo de movimentação)
  deResponsavelId   String?      @map("de_responsavel_id")
  paraResponsavelId String?      @map("para_responsavel_id")
  deAreaId          String?      @map("de_area_id")
  paraAreaId        String?      @map("para_area_id")
  deClienteId       String?      @map("de_cliente_id")
  paraClienteId     String?      @map("para_cliente_id")
  statusAnterior    AtivoStatus? @map("status_anterior")
  statusNovo        AtivoStatus? @map("status_novo")

  motivo          String?
  observacoes     String? @db.Text
  registradoPorId String? @map("registrado_por_id")

  createdAt DateTime @default(now()) @map("created_at")

  ativo         Ativo @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  registradoPor User? @relation(fields: [registradoPorId], references: [id], onDelete: SetNull)

  @@index([ativoId])
  @@index([tipo])
  @@map("ativo_movimentacoes")
}

/// Manutenções (preventivas, corretivas, upgrades) feitas no ativo.
/// Custos somam pra calcular Total Cost of Ownership (TCO).
model AtivoManutencao {
  id        String              @id @default(cuid())
  ativoId   String              @map("ativo_id")
  tipo      AtivoManutencaoTipo
  descricao String              @db.Text

  fornecedorId      String?   @map("fornecedor_id")
  custoMaoObra      Decimal?  @map("custo_mao_obra") @db.Decimal(12, 2)
  custoPecas        Decimal?  @map("custo_pecas") @db.Decimal(12, 2)
  dataInicio        DateTime? @map("data_inicio")
  dataFim           DateTime? @map("data_fim")
  /// Data sugerida pra próxima preventiva — pode alimentar agenda automaticamente.
  proximaPreventiva DateTime? @map("proxima_preventiva")

  responsavelId String? @map("responsavel_id") /// User interno que conduziu
  observacoes   String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ativo       Ativo       @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  fornecedor  Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  responsavel User?       @relation("AtivoManutencaoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)

  @@index([ativoId])
  @@index([fornecedorId])
  @@map("ativo_manutencoes")
}

/// Anexos do ativo — NF, contrato, foto, manual. Reusa o /api/upload existente.
model AtivoAnexo {
  id         String         @id @default(cuid())
  ativoId    String         @map("ativo_id")
  tipo       AtivoAnexoTipo
  fileName   String         @map("file_name")
  storageKey String         @map("storage_key")
  fileSize   Int?           @map("file_size")
  mimeType   String?        @map("mime_type")
  descricao  String?
  createdAt  DateTime       @default(now()) @map("created_at")

  ativo Ativo @relation(fields: [ativoId], references: [id], onDelete: Cascade)

  @@index([ativoId])
  @@map("ativo_anexos")
}

// ============================================================
// CLIENT ERROR LOG — captura de erros JS do navegador (DEV)
// ============================================================

enum ClientErrorLevel {
  ERROR /// console.error, window.onerror, ErrorBoundary catch
  WARN /// console.warn
  REJECTION /// unhandled promise rejection
}

/// Log agrupado de erros disparados no navegador. Cada `hash` (gerado a partir
/// de `message` + 1ª linha do stack normalizada) é único — múltiplas ocorrências
/// do mesmo erro só incrementam `count` e atualizam `lastSeenAt`. Persiste só
/// quando NODE_ENV !== 'production'. UI fica em /admin/erros-cliente.
model ClientErrorLog {
  id          String           @id @default(cuid())
  /// Hash dedup (message+stackLineNormalizada). Múltiplas ocorrências
  /// do mesmo erro incrementam count em vez de inserir nova row.
  hash        String           @unique
  level       ClientErrorLevel
  message     String           @db.Text
  stack       String?          @db.Text
  /// URL onde o erro ocorreu (window.location.href).
  url         String?
  /// User-Agent do navegador.
  userAgent   String?          @map("user_agent")
  /// Usuário logado (se houver) quando o erro foi capturado.
  userId      String?          @map("user_id")
  user        User?            @relation("ClientErrorUser", fields: [userId], references: [id], onDelete: SetNull)
  empresaId   String?          @map("empresa_id")
  /// 'development' | 'production' | 'staging' — geralmente filtramos por 'development'.
  environment String           @default("development")

  /// Slug do módulo onde o erro aconteceu (derivado da URL no frontend).
  /// Ex: 'cnd', 'danfe', 'agendamento', 'sci', 'admin'. Null se não derivável.
  modulo String?

  /// Contagem total de ocorrências. Cresce a cada `report` com mesmo hash.
  count       Int      @default(1)
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")

  /// Marcação manual feita pelo dev quando corrige o erro.
  resolvedAt   DateTime? @map("resolved_at")
  resolvedById String?   @map("resolved_by_id")
  resolvedBy   User?     @relation("ClientErrorResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([resolvedAt])
  @@index([lastSeenAt])
  @@index([environment])
  @@index([modulo])
  @@map("client_error_logs")
}

// ============================================================
// FISCAL — DANFE (NFe XML → PDF)
// ============================================================

enum DanfeLoteStatus {
  PROCESSANDO
  CONCLUIDO
  CANCELADO
}

model Danfe {
  id              String    @id @default(cuid())
  /// Chave de acesso de 44 dígitos (única no sistema).
  chave           String    @unique
  /// "55" = NFe, "65" = NFCe (futuro: 57 CTe, 58 MDFe).
  modelo          String
  numero          Int
  serie           Int
  emitenteCnpj    String    @map("emitente_cnpj")
  emitenteRazao   String    @map("emitente_razao")
  destCnpjCpf     String?   @map("dest_cnpj_cpf")
  destRazao       String?   @map("dest_razao")
  valorTotal      Decimal   @map("valor_total") @db.Decimal(14, 2)
  dataEmissao     DateTime  @map("data_emissao")
  dataAutorizacao DateTime? @map("data_autorizacao")
  /// "AUTORIZADA" | "CANCELADA" | "DENEGADA" | "INUTILIZADA".
  status          String    @default("AUTORIZADA")
  protocolo       String?
  /// Path do XML no S3 (chave pra recuperar via signed URL).
  xmlKey          String    @map("xml_key")
  /// Path do PDF no S3 (gerado on-demand ou no upload).
  pdfKey          String?   @map("pdf_key")

  loteId String?    @map("lote_id")
  lote   DanfeLote? @relation(fields: [loteId], references: [id], onDelete: SetNull)

  empresaId    String? @map("empresa_id")
  uploadedById String  @map("uploaded_by_id")
  uploadedBy   User    @relation("DanfeUploader", fields: [uploadedById], references: [id])

  /// Cliente vinculado — populado quando importado via Drive sync (pasta do cliente).
  /// Null em uploads manuais (não temos como inferir). Indexed pra galeria por cliente.
  clienteId String?  @map("cliente_id")
  cliente   Cliente? @relation("ClienteDanfes", fields: [clienteId], references: [id], onDelete: SetNull)

  // Relação inversa: itens do lote que apontam pra este DANFE quando o XML foi processado com sucesso
  loteItens        DanfeLoteItem[]
  driveSyncedFiles DriveSyncedFile[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([emitenteCnpj])
  @@index([destCnpjCpf])
  @@index([dataEmissao])
  @@index([empresaId])
  @@index([loteId])
  @@index([clienteId])
  @@map("danfes")
}

model DanfeLote {
  id          String          @id @default(cuid())
  nome        String
  status      DanfeLoteStatus @default(PROCESSANDO)
  totalXmls   Int             @map("total_xmls")
  processados Int             @default(0)
  sucesso     Int             @default(0)
  erros       Int             @default(0)
  iniciadoEm  DateTime        @default(now()) @map("iniciado_em")
  concluidoEm DateTime?       @map("concluido_em")

  empresaId    String? @map("empresa_id")
  uploadedById String  @map("uploaded_by_id")
  uploadedBy   User    @relation("DanfeLoteUploader", fields: [uploadedById], references: [id])

  itens  DanfeLoteItem[]
  danfes Danfe[]

  @@index([uploadedById])
  @@index([status])
  @@map("danfe_lotes")
}

// ─────────────────────────────────────────────────────────────
// NFS-e Importada — Notas Fiscais de Serviço recebidas pelos clientes
// (via Emissor Nacional ADN, NFSe municipal direta, upload manual)
// ─────────────────────────────────────────────────────────────
model NotaServicoImportada {
  id String @id @default(cuid())

  /// Chave de acesso (padrão nacional: 50 dígitos; municipais variam — pode ser null)
  chave             String? @unique
  numero            String
  serie             String?
  codigoVerificacao String? @map("codigo_verificacao")

  // Prestador
  prestadorCnpj      String  @map("prestador_cnpj")
  prestadorRazao     String  @map("prestador_razao")
  prestadorMunicipio String? @map("prestador_municipio") // código IBGE

  // Tomador
  tomadorCnpjCpf String? @map("tomador_cnpj_cpf")
  tomadorRazao   String? @map("tomador_razao")

  // Valores
  valorServicos Decimal  @map("valor_servicos") @db.Decimal(14, 2)
  valorIss      Decimal? @map("valor_iss") @db.Decimal(14, 2)
  valorLiquido  Decimal? @map("valor_liquido") @db.Decimal(14, 2)
  aliquotaIss   Decimal? @map("aliquota_iss") @db.Decimal(7, 4)

  // Serviço
  itemListaServico String? @map("item_lista_servico") // código LC 116/2003
  cnae             String?
  discriminacao    String? @db.Text

  // Datas
  dataEmissao DateTime  @map("data_emissao")
  competencia DateTime?

  /// "EMITIDA" | "CANCELADA" | "SUBSTITUIDA"
  status String @default("EMITIDA")

  // Storage
  xmlKey     String  @map("xml_key")
  pdfKey     String? @map("pdf_key")
  /// true = PDF é DANFSe oficial baixado da API gov.br; false = PDF auxiliar interno
  /// gerado pelo nosso gerador (layout simplificado). Quando true, layout v1.0 com QR.
  pdfOficial Boolean @default(false) @map("pdf_oficial")

  /// JSON com todos os campos extras extraídos do XML (endereço prestador/tomador,
  /// telefone, email, IM, regime SN, NBS, tributação completa, etc.). Schema:
  /// ParsedNFSe em src/nfse-dist/nfse.parser.ts (campos não-canônicos).
  dadosExtras Json? @map("dados_extras")

  /// Origem: "NACIONAL" (Emissor Nacional ADN) | "MUNICIPAL_XXXX" | "UPLOAD_MANUAL"
  padrao    String  @default("NACIONAL")
  /// Código IBGE do município emissor (se aplicável)
  municipio String?

  // Vínculos
  clienteId    String?  @map("cliente_id")
  cliente      Cliente? @relation("ClienteNotasServico", fields: [clienteId], references: [id], onDelete: SetNull)
  empresaId    String?  @map("empresa_id")
  uploadedById String   @map("uploaded_by_id")
  uploadedBy   User     @relation("NfseUploader", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([prestadorCnpj])
  @@index([tomadorCnpjCpf])
  @@index([clienteId])
  @@index([dataEmissao])
  @@index([empresaId])
  @@map("nfse_importadas")
}

model DanfeLoteItem {
  id     String    @id @default(cuid())
  loteId String    @map("lote_id")
  lote   DanfeLote @relation(fields: [loteId], references: [id], onDelete: Cascade)

  fileName String  @map("file_name")
  chave    String?
  /// "OK" | "DUPLICADO" | "INVALIDO" | "ERRO_PDF".
  status   String
  mensagem String?

  danfeId String? @map("danfe_id")
  danfe   Danfe?  @relation(fields: [danfeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([loteId])
  @@map("danfe_lote_itens")
}

// ============================================================
// Log de Execuções de Scheduler
// ------------------------------------------------------------
// Persiste cada rodada de um scheduler (cron ou disparo manual).
// Alimenta a tela /danfe/agendamento com histórico e KPIs.
// ============================================================
model SchedulerExecution {
  id String @id @default(cuid())

  /// Slug estável: 'nfe-dist' | 'nfse-dist' | futuros
  scheduler String

  iniciadoEm   DateTime  @default(now()) @map("iniciado_em")
  finalizadoEm DateTime? @map("finalizado_em")

  /// RODANDO | OK | ERRO | PARCIAL
  status String @default("RODANDO")

  /// CRON | MANUAL
  trigger String @default("CRON")

  totalClientes Int @default(0) @map("total_clientes")
  sucesso       Int @default(0)
  erros         Int @default(0)

  duracaoMs Int? @map("duracao_ms")

  /// Array por cliente: [{ clienteId, razaoSocial, status, mensagem }, ...]
  detalhes Json?

  /// Mensagem agregada quando status='ERRO' (ex: falha de conectividade global)
  erroGeral String? @map("erro_geral") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([scheduler, iniciadoEm(sort: Desc)])
  @@index([status])
  @@map("scheduler_executions")
}

// ════════════════════════════════════════════════════════════════
// PROJETOS (Bloco TI) — gestão de projetos de desenvolvimento
// Modelo Linear: Projeto + Tarefa plana (parentId reserva subtarefa)
// ════════════════════════════════════════════════════════════════

enum ProjetoStatus {
  NOVO
  ANDAMENTO
  PENDENTE
  CONCLUIDO
}

enum TarefaStatus {
  BACKLOG
  A_FAZER
  EM_ANDAMENTO
  EM_REVISAO
  CONCLUIDO
  CANCELADO
}

enum TarefaPrioridade {
  URGENTE
  ALTA
  MEDIA
  BAIXA
}

model Projeto {
  id            String        @id @default(cuid())
  nome          String
  descricao     String?       @db.Text
  cor           String        @default("#22d3ee")
  status        ProjetoStatus @default(NOVO)
  responsavelId String?       @map("responsavel_id")
  dataInicio    DateTime?     @map("data_inicio")
  dataPrevisao  DateTime?     @map("data_previsao")
  ordem         Int           @default(0)
  empresaId     String?       @map("empresa_id")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tarefas   ProjetoTarefa[]
  tags      ProjetoTag[]
  mensagens ProjetoMensagem[]
  anexos    ProjetoAnexo[]
  eventos   ProjetoEvento[]

  @@index([status, isActive])
  @@index([responsavelId])
  @@map("projetos")
}

model ProjetoMensagem {
  id        String   @id @default(cuid())
  projetoId String   @map("projeto_id")
  autorId   String?  @map("autor_id")
  texto     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  @@index([projetoId, createdAt(sort: Desc)])
  @@map("projetos_mensagens")
}

model ProjetoAnexo {
  id           String   @id @default(cuid())
  projetoId    String   @map("projeto_id")
  nome         String
  url          String   @db.Text
  mimeType     String?  @map("mime_type")
  tamanho      Int
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  @@index([projetoId])
  @@map("projetos_anexos")
}

// Singleton de configurações do módulo Projetos (1 registro por schema/tenant).
// O service garante a existência via getOrCreate.
model ProjetoConfig {
  id                     String   @id @default(cuid())
  autoArquivarHabilitado Boolean  @default(false) @map("auto_arquivar_habilitado")
  autoArquivarDias       Int      @default(90)    @map("auto_arquivar_dias")
  ultimaExecucao         DateTime? @map("ultima_execucao")
  ultimoTotalArquivados  Int      @default(0) @map("ultimo_total_arquivados")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("projetos_config")
}

model ProjetoEvento {
  id          String   @id @default(cuid())
  projetoId   String   @map("projeto_id")
  tipo        String
  autorId     String?  @map("autor_id")
  comentario  String?  @db.Text
  campoAntes  String?  @map("campo_antes") @db.Text
  campoDepois String?  @map("campo_depois") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  @@index([projetoId, createdAt(sort: Desc)])
  @@map("projetos_eventos")
}

model ProjetoTag {
  id        String   @id @default(cuid())
  projetoId String   @map("projeto_id")
  nome      String
  cor       String   @default("#94a3b8")
  createdAt DateTime @default(now()) @map("created_at")

  projeto       Projeto              @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  tarefasLinked ProjetoTarefaTag[]

  @@unique([projetoId, nome])
  @@map("projetos_tags")
}

model ProjetoTarefa {
  id            String           @id @default(cuid())
  projetoId     String           @map("projeto_id")
  titulo        String
  descricao     String?          @db.Text
  status        TarefaStatus     @default(BACKLOG)
  prioridade    TarefaPrioridade @default(MEDIA)
  responsavelId String?          @map("responsavel_id")
  prazo         DateTime?
  estimativa    Int?
  ordem         Int              @default(0)
  parentId      String?          @map("parent_id")
  concluidoEm   DateTime?        @map("concluido_em")
  empresaId     String?          @map("empresa_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  projeto  Projeto               @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  parent   ProjetoTarefa?        @relation("ProjetoTarefaSubtask", fields: [parentId], references: [id])
  children ProjetoTarefa[]       @relation("ProjetoTarefaSubtask")
  tags     ProjetoTarefaTag[]
  anexos   ProjetoTarefaAnexo[]
  eventos  ProjetoTarefaEvento[]

  @@index([projetoId, status])
  @@index([responsavelId])
  @@index([prazo])
  @@map("projetos_tarefas")
}

model ProjetoTarefaTag {
  tarefaId String @map("tarefa_id")
  tagId    String @map("tag_id")

  tarefa ProjetoTarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  tag    ProjetoTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([tarefaId, tagId])
  @@map("projetos_tarefas_tags")
}

model ProjetoTarefaAnexo {
  id           String   @id @default(cuid())
  tarefaId     String   @map("tarefa_id")
  nome         String
  url          String   @db.Text
  mimeType     String?  @map("mime_type")
  tamanho      Int
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tarefa ProjetoTarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)

  @@index([tarefaId])
  @@map("projetos_tarefas_anexos")
}

model ProjetoTarefaEvento {
  id          String   @id @default(cuid())
  tarefaId    String   @map("tarefa_id")
  tipo        String
  autorId     String?  @map("autor_id")
  comentario  String?  @db.Text
  campoAntes  String?  @map("campo_antes") @db.Text
  campoDepois String?  @map("campo_depois") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  tarefa ProjetoTarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)

  @@index([tarefaId, createdAt(sort: Desc)])
  @@map("projetos_tarefas_eventos")
}
