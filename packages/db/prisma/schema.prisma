// ============================================================
// Módulo Cadastros — Fornecedores
// ============================================================

enum TipoFornecedor {
  PRODUTO
  SERVICO
  AMBOS
}

model Fornecedor {
  id   String @id @default(cuid())
  code Int    @default(autoincrement())

  // Identificação
  razaoSocial        String         @map("razao_social")
  nomeFantasia       String?        @map("nome_fantasia")
  documento          String
  tipoDocumento      TipoDocumento  @default(CNPJ) @map("tipo_documento")
  inscricaoEstadual  String?        @map("inscricao_estadual")
  inscricaoMunicipal String?        @map("inscricao_municipal")
  tipoFornecedor     TipoFornecedor @default(AMBOS) @map("tipo_fornecedor")
  categoria          String?
  logoUrl            String?        @map("logo_url")

  // Contato
  telefone         String?
  celular          String?
  email            String?
  site             String?
  contatoPrincipal String? @map("contato_principal")
  cargoContato     String? @map("cargo_contato")

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String? @db.Char(2)

  // Dados Bancários
  banco     String?
  agencia   String?
  conta     String?
  tipoConta String? @map("tipo_conta")
  pixChave  String? @map("pix_chave")
  pixTipo   String? @map("pix_tipo")

  // Comercial
  observacoes String? @db.Text

  // Multi-empresa
  empresaId String? @map("empresa_id")

  // Controle
  isActive  Boolean  @default(true) @map("is_active")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa          Empresa?          @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  events           FornecedorEvent[]
  ativos           Ativo[]
  ativoManutencoes AtivoManutencao[]

  @@map("fornecedores")
}

model FornecedorEvent {
  id           String   @id @default(cuid())
  fornecedorId String   @map("fornecedor_id")
  userId       String?  @map("user_id")
  type         String
  version      Int
  changes      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("fornecedor_events")
}

// ============================================================
// Módulo Cadastros — Sócios
// ============================================================

enum TipoSocio {
  SOCIO_ADMINISTRADOR
  SOCIO_QUOTISTA
  SOCIO_DIRETOR
  ACIONISTA
  TITULAR
  PROCURADOR
  REPRESENTANTE_LEGAL
}

model Socio {
  id   String @id @default(cuid())
  code Int    @default(autoincrement())

  // Dados Pessoais
  nomeCompleto   String       @map("nome_completo")
  cpf            String
  rg             String?
  orgaoEmissor   String?      @map("orgao_emissor")
  dataNascimento DateTime?    @map("data_nascimento")
  nacionalidade  String?      @default("Brasileira")
  estadoCivil    EstadoCivil? @map("estado_civil")
  profissao      String?

  // Contato
  email    String?
  telefone String?
  celular  String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String? @db.Char(2)

  // Dados Societários
  tipoSocio        TipoSocio @default(SOCIO_QUOTISTA) @map("tipo_socio")
  participacao     Decimal?  @db.Decimal(10, 4)
  valorQuotas      Decimal?  @map("valor_quotas") @db.Decimal(14, 2)
  dataEntrada      DateTime? @map("data_entrada")
  dataSaida        DateTime? @map("data_saida")
  assinaNaEmpresa  Boolean   @default(false) @map("assina_na_empresa")
  responsavelLegal Boolean   @default(false) @map("responsavel_legal")
  observacoes      String?   @db.Text

  // Vínculo com empresa (qual empresa este sócio pertence)
  empresaId String? @map("empresa_id")
  // Vínculo com cliente (se for sócio de um cliente)
  clienteId String? @map("cliente_id")

  // Controle
  isActive  Boolean  @default(true) @map("is_active")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa              Empresa?             @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  cliente              Cliente?             @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  events               SocioEvent[]
  arquivos             SocioArquivo[]
  mensagens            SocioMensagem[]
  certificadosDigitais CertificadoDigital[] @relation("CertificadoSocio")

  @@index([cpf])
  @@index([clienteId])
  @@map("socios")
}

model SocioArquivo {
  id         String    @id @default(cuid())
  socioId    String    @map("socio_id")
  fileName   String    @map("file_name")
  fileUrl    String    @map("file_url")
  fileSize   Int?      @map("file_size")
  mimeType   String?   @map("mime_type")
  vencimento DateTime?
  userId     String?   @map("user_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  socio Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("socio_arquivos")
}

model SocioMensagem {
  id        String   @id @default(cuid())
  socioId   String   @map("socio_id")
  userId    String?  @map("user_id")
  mensagem  String   @db.Text
  tipo      String   @default("interna")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  socio Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("socio_mensagens")
}

model SocioEvent {
  id        String   @id @default(cuid())
  socioId   String   @map("socio_id")
  userId    String?  @map("user_id")
  type      String
  version   Int
  changes   Json?
  createdAt DateTime @default(now()) @map("created_at")

  socio Socio @relation(fields: [socioId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("socio_events")
}

// ============================================================
// Configurações do Sistema (key-value)
// ============================================================

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String?
  group     String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model SavedQuery {
  id        String   @id @default(cuid())
  name      String
  sql       String   @db.Text
  dbType    String   @map("db_type") // postgresql | mysql | firebird
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("saved_query")
}

// ============================================================
// Notificações para o usuário (sino global no header)
// ============================================================
// Notificações criadas por outros módulos (ex: serviço atribuído, prazo
// vencendo, mensagem nova) e exibidas no popover do sino. Cada user tem
// sua própria lista; não há broadcast — para múltiplos usuários,
// criar registros separados.

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  titulo    String
  mensagem  String?   @db.Text
  // Tipo visual: info | success | warning | error
  tipo      String    @default("info")
  // Rota interna para navegar ao clicar (opcional)
  link      String?
  // Origem: módulo/feature que gerou (ex: "servicos", "orcamentos") — útil
  // pra agrupar/filtrar e exibir ícone correspondente
  origem    String?
  lida      Boolean   @default(false)
  lidaEm    DateTime? @map("lida_em")
  empresaId String?   @map("empresa_id")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, lida])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// Sistema de Abas (Chrome-like)
// ============================================================
// Cada usuário tem uma lista persistente de abas abertas. Pinadas
// vêm primeiro na ordem; restante segue ordenação manual via drag.
// Salva em banco para sincronizar entre máquinas/sessões.

model UserTab {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  href      String // rota interna (ex: /clientes, /orcamentos/abc)
  label     String // título exibido na aba
  icon      String? // nome do ícone Lucide (ex: "Users")
  pinned    Boolean  @default(false)
  ordem     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, href])
  @@index([userId, ordem])
  @@map("user_tabs")
}

// ============================================================
// Gestão de Certificados Digitais (ICP-Brasil A1)
// ============================================================
// Armazena certificados de clientes/empresas/sócios. PFX é guardado
// localmente em uploads/certificados/{empresaId}/{id}.pfx; senha é
// criptografada com KEK (CERTIFICADO_KEK env) usando AES-256-GCM.
// Toda operação gera registro em CertificadoDigitalAcesso para auditoria.

model CertificadoDigital {
  id String @id @default(cuid())

  // Vínculo com PF e PJ (qualquer combinação válida)
  clienteId String? @map("cliente_id")
  empresaId String? @map("empresa_id")
  socioId   String? @map("socio_id")

  // Identificação extraída do PFX
  tipo        String // 'A1' (futuro: A3)
  titular     String // CN do certificado
  documento   String // CPF/CNPJ do titular
  numeroSerie String? @map("numero_serie")
  emissor     String? // AC emissora

  // Validade
  emitidoEm DateTime @map("emitido_em")
  expiraEm  DateTime @map("expira_em")

  // Status: ATIVO | EXPIRADO | REVOGADO | RENOVADO | ARQUIVADO
  status String @default("ATIVO")

  // Versionamento: quando um certificado é renovado, o novo aponta para o antigo
  // via parentId. O antigo é marcado com status='RENOVADO'. Isso preserva a
  // cadeia histórica para auditoria/relatórios sem duplicar dados.
  parentId String?              @map("parent_id")
  parent   CertificadoDigital?  @relation("CertificadoVersoes", fields: [parentId], references: [id], onDelete: SetNull)
  filhos   CertificadoDigital[] @relation("CertificadoVersoes")

  // Storage (somente A1)
  arquivoPath  String? @map("arquivo_path") // path local relativo
  arquivoHash  String? @map("arquivo_hash") // SHA-256 hex
  // Senha cifrada — JSON {iv, ciphertext, tag} em base64 (AES-256-GCM)
  senhaCifrada String? @map("senha_cifrada") @db.Text
  kekVersion   Int     @default(1) @map("kek_version")

  observacoes  String?   @db.Text
  arquivado    Boolean   @default(false)
  arquivadoEm  DateTime? @map("arquivado_em")
  arquivadoPor String?   @map("arquivado_por")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cliente          Cliente?                   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  empresa          Empresa?                   @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  socio            Socio?                     @relation("CertificadoSocio", fields: [socioId], references: [id], onDelete: SetNull)
  acessos          CertificadoDigitalAcesso[]
  // Relações inversas — clientes que usam este certificado pra integrações fiscais
  clientesNfeDist  Cliente[]                  @relation("ClienteNFeDistCert")
  clientesNfseDist Cliente[]                  @relation("ClienteNFSeDistCert")

  @@index([clienteId])
  @@index([empresaId])
  @@index([socioId])
  @@index([expiraEm])
  @@index([status])
  @@map("certificados_digitais")
}

model CertificadoDigitalAcesso {
  id            String   @id @default(cuid())
  certificadoId String   @map("certificado_id")
  userId        String?  @map("user_id")
  // Ações: cadastrado | visualizado | editado | download_pfx |
  //        senha_visualizada | usado_assinatura | revogado |
  //        arquivado | desarquivado | excluido | integridade_falhou
  acao          String
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  detalhes      String?  @db.Text // motivo informado pelo user, contexto extra
  createdAt     DateTime @default(now()) @map("created_at")

  certificado CertificadoDigital @relation(fields: [certificadoId], references: [id], onDelete: Cascade)

  @@index([certificadoId])
  @@index([userId])
  @@index([createdAt])
  @@map("certificados_digitais_acessos")
}

// ============================================================
// Log de Requisições API (para Métricas)
// ============================================================

model ApiLog {
  id        String   @id @default(cuid())
  source    String // ex: "serpro", "brasilapi", "omie"
  endpoint  String // ex: "/cnpj/v1"
  method    String   @default("GET")
  status    Int? // HTTP status code
  duration  Int? // ms
  documento String? // CNPJ/CPF consultado
  userId    String?  @map("user_id")
  empresaId String?  @map("empresa_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([source, createdAt])
  @@index([createdAt])
  @@map("api_logs")
}

// Preços por fonte de API (para cálculo de custo)
model ApiPricing {
  id         String @id @default(cuid())
  source     String @unique
  unitPrice  Float  @default(0) @map("unit_price")
  multiplier Float  @default(1)
  currency   String @default("BRL")

  @@map("api_pricing")
}

// ============================================================
// Situação Fiscal (Integra Contador SERPRO)
// ============================================================

model SituacaoFiscal {
  id              String  @id @default(cuid())
  documento       String
  periodo         String? // AAAAMM ou null
  tipoDocumento   Int     @default(2) @map("tipo_documento")
  cnpjContratante String? @map("cnpj_contratante")
  razaoSocial     String? @map("razao_social")

  // Protocolo e etapa
  protocolo String? @db.VarChar(500)
  etapa     String  @default("pendente")

  // Resultado
  tipoCertidao   String?   @map("tipo_certidao")
  numeroCertidao String?   @map("numero_certidao")
  dataEmissao    DateTime? @map("data_emissao")
  dataValidade   DateTime? @map("data_validade")

  // PDF em base64
  pdfBase64 String? @map("pdf_base64") @db.Text

  // Dados extraídos do PDF (JSON)
  dadosExtraidos Json? @map("dados_extraidos")

  // Resposta completa da API (JSON)
  respostaCompleta Json? @map("resposta_completa")

  // Headers da resposta (JSON)
  headersResposta Json? @map("headers_resposta")

  // Status
  sucesso    Boolean @default(false)
  erro       String? @db.Text
  statusHttp Int?    @map("status_http")

  // Vínculo com cliente
  clienteId String? @map("cliente_id")
  empresaId String? @map("empresa_id")
  userId    String? @map("user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([documento])
  @@index([documento, periodo, etapa])
  @@index([clienteId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("situacao_fiscal")
}

// ============================================================
// Caixa Postal e-CAC (Integra Contador SERPRO)
// ============================================================

enum CaixaPostalPrioridade {
  P0
  P1
  P2
  P3
}

enum CaixaPostalTipoOperacao {
  LISTAR
  DETALHAR
  INDICADOR
}

enum CaixaPostalRegraTipo {
  PRIORIDADE
  RELEVANCIA
  DESCONSIDERAR
}

// Cache/auditoria de chamadas à API SERPRO
model CaixaPostalMensagem {
  id                String                  @id @default(cuid())
  tipoOperacao      CaixaPostalTipoOperacao @map("tipo_operacao")
  isn               String?
  statusLeitura     String?                 @map("status_leitura")
  indicadorPagina   String?                 @map("indicador_pagina")
  ponteiroPagina    String?                 @map("ponteiro_pagina")
  contratante       String
  autorPedido       String                  @map("autor_pedido")
  contribuinte      String
  payloadRequisicao Json?                   @map("payload_requisicao")
  resposta          Json?
  sucesso           Boolean                 @default(true)
  erro              String?                 @db.Text
  statusHttp        Int?                    @map("status_http")
  empresaId         String?                 @map("empresa_id")
  createdAt         DateTime                @default(now()) @map("created_at")

  @@index([tipoOperacao])
  @@index([isn])
  @@index([contribuinte])
  @@index([empresaId])
  @@index([createdAt])
  @@map("caixa_postal_mensagem")
}

// Mensagens individuais classificadas com prioridade e status de leitura
model CaixaPostalItem {
  id                   String                @id @default(cuid())
  isn                  String
  contribuinte         String
  empresaId            String?               @map("empresa_id")
  mensagemOriginal     Json                  @map("mensagem_original")
  prioridade           CaixaPostalPrioridade @default(P3)
  score                Int                   @default(0)
  motivos              Json?
  acaoRecomendada      String?               @map("acao_recomendada") @db.Text
  slaDias              Int?                  @map("sla_dias")
  prazoUrgente         Boolean               @default(false) @map("prazo_urgente")
  precisaTriagemHumana Boolean               @default(false) @map("precisa_triagem_humana")
  lida                 Boolean               @default(false)
  dataLeitura          DateTime?             @map("data_leitura")
  userId               String?               @map("user_id")
  responsavelId        String?               @map("responsavel_id")
  status               String                @default("pendente") // pendente, em_andamento, concluido, arquivado
  observacoes          String?               @db.Text
  arquivada            Boolean               @default(false)
  importante           Boolean               @default(false)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  user        User?                 @relation("CaixaPostalLeitora", fields: [userId], references: [id], onDelete: SetNull)
  responsavel User?                 @relation("CaixaPostalResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  acaoLogs    CaixaPostalAcaoLog[]
  eventos     CaixaPostalEventLog[]

  @@unique([isn, contribuinte])
  @@index([contribuinte])
  @@index([empresaId])
  @@index([prioridade])
  @@index([lida])
  @@index([prazoUrgente])
  @@index([responsavelId])
  @@index([status])
  @@index([createdAt])
  @@map("caixa_postal_item")
}

// Log de eventos/histórico de ações em mensagens da caixa postal
model CaixaPostalEventLog {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  userId    String?  @map("user_id")
  tipo      String // LEITURA, ENCAMINHAMENTO, RESPONSAVEL, OBSERVACAO, STATUS, OBRIGACAO_CRIADA, RECLASSIFICACAO
  descricao String   @db.Text
  detalhes  Json? // Dados extras (ex: para quem encaminhou, status anterior/novo, etc.)
  createdAt DateTime @default(now()) @map("created_at")

  item CaixaPostalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([userId])
  @@index([tipo])
  @@index([createdAt])
  @@map("caixa_postal_event_log")
}

// Regras de classificação automática de mensagens (por empresa)
model CaixaPostalRegra {
  id        String               @id @default(cuid())
  empresaId String               @map("empresa_id")
  nome      String
  descricao String?              @db.Text
  tipo      CaixaPostalRegraTipo
  ativo     Boolean              @default(true)
  ordem     Int                  @default(0)

  // Condições
  palavrasChave String? @map("palavras_chave") @db.Text
  origemContem  String? @map("origem_contem")
  assuntoContem String? @map("assunto_contem")
  codigoSistema String? @map("codigo_sistema")

  // Ações de classificação
  pesoScore                Int                    @default(0) @map("peso_score")
  prioridadeMinima         CaixaPostalPrioridade? @map("prioridade_minima")
  marcarRelevante          Boolean                @default(false) @map("marcar_relevante")
  desconsiderarSePesoMenor Int?                   @map("desconsiderar_se_peso_menor")

  // Ações automáticas
  autoNotificar        Boolean @default(false) @map("auto_notificar")
  autoNotificarLider   Boolean @default(false) @map("auto_notificar_lider")
  autoNotificarGerente Boolean @default(false) @map("auto_notificar_gerente")
  autoCriarTarefa      Boolean @default(false) @map("auto_criar_tarefa")
  autoMarcarLida       Boolean @default(false) @map("auto_marcar_lida")
  emailsExtras         String? @map("emails_extras") @db.Text

  // Metadata
  criadoPor String?  @map("criado_por")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [criadoPor], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([tipo])
  @@index([ativo])
  @@index([ordem])
  @@map("caixa_postal_regra")
}

// Configuração editável do classificador automático
model CaixaPostalConfig {
  id        String   @id @default(cuid())
  empresaId String   @unique @map("empresa_id")
  config    Json // Thresholds, keywords, pesos de prazo/relevância/leitura
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("caixa_postal_config")
}

// Log de ações automáticas executadas
model CaixaPostalAcaoLog {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  regraId   String?  @map("regra_id")
  empresaId String?  @map("empresa_id")
  tipoAcao  String   @map("tipo_acao")
  detalhes  Json?
  sucesso   Boolean  @default(true)
  erro      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  item CaixaPostalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([empresaId])
  @@index([tipoAcao])
  @@index([createdAt])
  @@map("caixa_postal_acao_log")
}

// ============================================================
// Módulo Contabilização de Folha de Pagamento
// ============================================================

model FolhaFilial {
