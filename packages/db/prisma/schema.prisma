  createdAt    DateTime @default(now()) @map("created_at")

  filial      FolhaFilial       @relation(fields: [filialId], references: [id], onDelete: Cascade)
  lancamentos FolhaLancamento[]

  @@unique([filialId, nome])
  @@map("folha_setores")
