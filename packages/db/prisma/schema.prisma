generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Multi-tenancy: schema public — dados globais
// ============================================================

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Tenant {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  schema           String       @unique // nome do schema no Postgres: tenant_<id>
  status           TenantStatus @default(ACTIVE)
  stripeCustomerId String?      @unique @map("stripe_customer_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  users         User[]
  subscriptions Subscription[]

  @@map("tenants")
}

// ============================================================
// Tema global — cores por módulo (sidebar groups + headers)
// Editável no Design System (/admin/design-system) por master.
// Carregada uma vez por sessão e injetada como CSS variables em :root.
// ============================================================
model ModuleColor {
  slug      String   @id // ex: "cadastros", "comercial", "fiscal"
  label     String // ex: "Cadastros"
  color     String // hex, ex: "#10b981"
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("module_colors")
}

// ============================================================
// Planos e assinaturas (Stripe)
// ============================================================

enum PlanInterval {
  MONTHLY
  YEARLY
}

model Plan {
  id            String       @id @default(cuid())
  name          String
  description   String?
  stripePriceId String       @unique @map("stripe_price_id")
  interval      PlanInterval @default(MONTHLY)
  price         Int // valor em centavos
  features      Json         @default("[]")
  maxUsers      Int          @default(5) @map("max_users")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @map("tenant_id")
  planId               String             @map("plan_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripeCustomerId     String             @map("stripe_customer_id")
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// ============================================================
// Usuários e autenticação (Better Auth)
// ============================================================

enum Role {
  COLABORADOR_INTERNO
  PRESTADOR_SERVICO
  COLABORADOR_CLIENTE
  GESTOR
  COORDENADOR
  DIRETOR
}

enum UserProfile {
  OPERADOR
  SUPERVISOR
  GERENTE
  ADMIN
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  name            String
  emailVerified   Boolean     @default(false) @map("email_verified")
  image           String?
  coverImage      String?     @map("cover_image") // background personalizado da pagina de perfil (espelha legado profile-bg/{empresa}/profile-bg.jpg)
  role            Role        @default(COLABORADOR_INTERNO)
  profile         UserProfile @default(OPERADOR)
  isMaster        Boolean     @default(false) @map("is_master")
  isEmpresaMaster Boolean     @default(false) @map("is_empresa_master")
  /// Usuário-sistema da IA (assistente automático do helpdesk). Mensagens
  /// criadas por esse user aparecem com badge especial na UI.
  isAi            Boolean     @default(false) @map("is_ai")
  isActive        Boolean     @default(true) @map("is_active")
  tenantId        String?     @map("tenant_id")
  empresaId       String?     @map("empresa_id")

  // Visibilidade no módulo Colaboradores (público) — quando true, aparece no listing
  exibirComoColaborador Boolean @default(false) @map("exibir_como_colaborador")

  // Tracking de presença (atualizado por middleware em toda request autenticada,
  // throttled a cada 30s pra não martelar o banco). Usado pelo painel "Usuários
  // online" no Service Manager via SSE.
  lastActivityAt   DateTime? @map("last_activity_at")
  lastActivityPath String?   @map("last_activity_path")
  lastActivityIp   String?   @map("last_activity_ip")

  /// Override manual do status do chat. Valores: 'online' | 'ausente' | 'dnd'
  /// (não perturbar) | 'invisible' (parece offline pros outros). null = automático
  /// derivado do lastActivityAt.
  chatStatus       String?   @map("chat_status")

  // Documentos
  cpf            String?
  rg             String?
  orgaoEmissor   String?      @map("orgao_emissor")
  dataNascimento DateTime?    @map("data_nascimento")
  sexo           Sexo?
  estadoCivil    EstadoCivil? @map("estado_civil")
  nacionalidade  String?      @default("Brasileira")
  naturalidade   String?

  // Documentos trabalhistas
  pis           String?
  ctps          String?
  ctpsSerie     String? @map("ctps_serie")
  tituloEleitor String? @map("titulo_eleitor")
  reservista    String?

  // Contato
  telefone String?
  celular  String?
  ramal    String?
  whatsapp String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String? @db.Char(2)
  pais        String? @default("Brasil")

  // Apresentação / Sociais
  bio          String? @db.Text
  siteUrl      String? @map("site_url")
  linkedinUrl  String? @map("linkedin_url")
  githubUrl    String? @map("github_url")
  instagramUrl String? @map("instagram_url")
  facebookUrl  String? @map("facebook_url")

  // Assinatura de email — foto tratada (fundo removido, tom verde aplicado).
  // Separada de `image` (avatar do app) porque pessoas costumam usar fotos
  // diferentes pra cada contexto.
  signatureImageUrl String? @map("signature_image_url")

  // Dados Organizacionais
  areaId  String?  @map("area_id")
  cargoId String?  @map("cargo_id")
  salario Decimal? @db.Decimal(10, 2)

  // Contrato / RH
  tipoContrato  TipoContrato @default(CLT) @map("tipo_contrato")
  dataAdmissao  DateTime?    @map("data_admissao")
  dataDemissao  DateTime?    @map("data_demissao")
  cargaHoraria  Int?         @default(44) @map("carga_horaria")
  idOneClick    String?      @map("id_oneclick")
  incluirFerias Boolean      @default(true) @map("incluir_ferias")
  observacoes   String?      @db.Text

  // MFA / 2FA (Better Auth two-factor plugin)
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant                 Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  empresa                Empresa?                @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  area                   Area?                   @relation("UserArea", fields: [areaId], references: [id], onDelete: SetNull)
  cargo                  Cargo?                  @relation(fields: [cargoId], references: [id], onDelete: SetNull)
  sessions               Session[]
  accounts               Account[]
  twoFactor              TwoFactor[]
  trustedDevices         TrustedDevice[]
  ledAreas               Area[]
  permissions            UserPermission[]
  cargoEvents            CargoEvent[]
  empresaEvents          EmpresaEvent[]
  clienteEvents          ClienteEvent[]
  clienteArquivos        ClienteArquivo[]
  clienteHistoricos      ClienteHistorico[]
  fornecedorEvents       FornecedorEvent[]
  socioEvents            SocioEvent[]
  socioArquivos          SocioArquivo[]
  socioMensagens         SocioMensagem[]
  situacoesFiscais       SituacaoFiscal[]
  caixaPostalItems       CaixaPostalItem[]       @relation("CaixaPostalLeitora")
  caixaPostalResponsavel CaixaPostalItem[]       @relation("CaixaPostalResponsavel")
  caixaPostalRegras      CaixaPostalRegra[]
  caixaPostalEventLogs   CaixaPostalEventLog[]
  responsavelAreas       ClienteAreaContratada[] @relation("AreaResponsavel")
  substitutoAreas        ClienteAreaContratada[] @relation("AreaSubstituto")
  eventoCriados          AgendaEvento[]          @relation("EventoCriador")
  eventoParticipacoes    AgendaParticipante[]    @relation("EventoParticipante")
  tarefasCriadas         AgendaTarefa[]          @relation("TarefaCriador")
  helpdeskSolicitados    HelpdeskTicket[]        @relation("HelpdeskTicketSolicitante")
  helpdeskResponsavel    HelpdeskTicket[]        @relation("HelpdeskTicketResponsavel")
  helpdeskMensagens      HelpdeskMensagem[]
  helpdeskAnexos         HelpdeskAnexo[]
  helpdeskWatchers       HelpdeskWatcher[]
  helpdeskEventos        HelpdeskEvento[]
  // Chat interno
  chatParticipacoes      ChatParticipante[]      @relation("ChatParticipanteUser")
  // Gestão de Ativos
  ativosResponsavel      Ativo[]                 @relation("AtivoResponsavel")
  ativoMovimentacoes     AtivoMovimentacao[]
  ativoManutencoes       AtivoManutencao[]       @relation("AtivoManutencaoResponsavel")
  // Client error logs
  clientErrorsReportados ClientErrorLog[]        @relation("ClientErrorUser")
  clientErrorsResolvidos ClientErrorLog[]        @relation("ClientErrorResolver")
  // DANFE
  danfesUploaded         Danfe[]                 @relation("DanfeUploader")
  notasServicoUploaded   NotaServicoImportada[]  @relation("NfseUploader")
  danfeLotes             DanfeLote[]             @relation("DanfeLoteUploader")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

// Better Auth two-factor plugin: armazena TOTP secret + backup codes (criptografados pelo plugin)
model TwoFactor {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  secret      String
  backupCodes String   @map("backup_codes")
  verified    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([secret])
  @@map("two_factors")
}

// Dispositivos confiaveis — pulam o MFA durante validade. Listavel/revogavel pelo proprio usuario em /perfil.
model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  tokenHash  String   @unique @map("token_hash") // SHA-256 do token armazenado no cookie
  label      String? // ex: "Chrome no Windows"
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  expiresAt  DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("trusted_devices")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

// ============================================================
// Módulo Cadastros — Áreas
// ============================================================

enum CostType {
  DIRECT
  INDIRECT
}

model Area {
  id        String  @id @default(cuid())
  code      Int     @default(autoincrement())
  name      String
  isActive  Boolean @default(true) @map("is_active")
  empresaId String? @map("empresa_id")

  // Visibilidade e Contratação
  availableForHiring Boolean @default(false) @map("available_for_hiring")
  showInOrgChart     Boolean @default(false) @map("show_in_org_chart")

  // Contato e Hierarquia
  email    String?
  leaderId String? @map("leader_id")
  parentId String? @map("parent_id")

  // Custeio por Cliente
  costType           CostType @default(DIRECT) @map("cost_type")
  costWeight         Decimal  @default(1) @map("cost_weight") @db.Decimal(10, 4)
  excludeFromCosting Boolean  @default(false) @map("exclude_from_costing")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa            Empresa?                @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  parent             Area?                   @relation("AreaHierarchy", fields: [parentId], references: [id])
  children           Area[]                  @relation("AreaHierarchy")
  leader             User?                   @relation(fields: [leaderId], references: [id])
  users              User[]                  @relation("UserArea")
  cargos             Cargo[]
  clienteContatos    ClienteContato[]
  clienteAreas       ClienteAreaContratada[]
  helpdeskCategorias HelpdeskCategoria[]
  helpdeskTickets    HelpdeskTicket[]
  ativos             Ativo[]                 @relation("AtivoArea")

  @@map("areas")
}

// ============================================================
// Módulo Cadastros — Cargos
// ============================================================

model Cargo {
  id             String  @id @default(cuid())
  code           Int     @default(autoincrement())
  name           String
  isActive       Boolean @default(true) @map("is_active")
  empresaId      String? @map("empresa_id")
  areaId         String? @map("area_id")
  showInOrgChart Boolean @default(false) @map("show_in_org_chart")

  // Campos descritivos (rich text — HTML)
  descricaoSumaria  String? @map("descricao_sumaria") @db.Text
  responsabilidades String? @db.Text
  habilidades       String? @db.Text
  autoridades       String? @db.Text
  experiencias      String? @db.Text
  treinamentos      String? @db.Text
  educacao          String? @db.Text

  // Versionamento (ISO 9001)
  version Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa Empresa?     @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  area    Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  users   User[]
  events  CargoEvent[]

  @@map("cargos")
}

// ============================================================
// Log de Eventos — Cargos (Auditoria ISO 9001)
// ============================================================

model CargoEvent {
  id        String   @id @default(cuid())
  cargoId   String   @map("cargo_id")
  userId    String?  @map("user_id")
  type      String // "created", "updated", "deleted"
  version   Int // Versão no momento do evento
  changes   Json? // { campo: { from: "antigo", to: "novo" } }
  createdAt DateTime @default(now()) @map("created_at")

  cargo Cargo @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("cargo_events")
}

// ============================================================
// Módulo Cadastros — Empresas
// ============================================================

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
  IMUNE
  ISENTA
}

model Empresa {
  id   String @id @default(cuid())
  code Int    @default(autoincrement())

  // Dados Legais
  razaoSocial        String     @map("razao_social")
  nomeFantasia       String?    @map("nome_fantasia")
  cnpj               String     @unique
  inscricaoEstadual  String?    @map("inscricao_estadual")
  inscricaoMunicipal String?    @map("inscricao_municipal")
  taxRegime          TaxRegime? @map("tax_regime")
  isActive           Boolean    @default(true) @map("is_active")

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String? @db.Char(2)

  // Contato
  telefone String?
  email    String?
  site     String?

  // Logo
  logoUrl       String? @map("logo_url")
  logoDarkUrl   String? @map("logo_dark_url")
  // Imagem usada como marca d'agua em documentos impressos (ex: orçamento)
  marcaDaguaUrl String? @map("marca_dagua_url")

  // Versionamento (ISO 9001)
  version Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  areas                Area[]
  cargos               Cargo[]
  clientes             Cliente[]
  fornecedores         Fornecedor[]
  socios               Socio[]
  events               EmpresaEvent[]
  certificadosDigitais CertificadoDigital[]
  helpdeskCategorias   HelpdeskCategoria[]
  helpdeskTickets      HelpdeskTicket[]
  signatureTemplate    EmpresaSignatureTemplate?

  @@map("empresas")
}

/**
 * Template de assinatura de email POR EMPRESA — editável só por isMaster em
 * /admin/assinatura-template. Quando não existe, usa-se os defaults hardcoded.
 * Dois modos:
 * 1. Visual (default): renderiza HTML a partir das colunas (cores/fonte/logo/visibilidade).
 * 2. customHtmlEnabled=true: usa `customHtml` literal, com placeholders
 * {{user.name}} {{empresa.logoUrl}} etc. interpolados client-side.
 */
model EmpresaSignatureTemplate {
  id        String @id @default(cuid())
  empresaId String @unique @map("empresa_id")

  // Tema visual
  backgroundColor    String  @default("#3a3a3a") @map("background_color")
  /// Quando setado, renderiza `background-image` no <table> da assinatura.
  /// A cor (backgroundColor) continua como fallback pra Outlook desktop (que
  /// strip-pa background-image sem VML).
  backgroundImageUrl String? @map("background_image_url")
  accentColor        String  @default("#10b981") @map("accent_color")
  textColor          String  @default("#ffffff") @map("text_color")
  subtleColor        String  @default("#cfd2d4") @map("subtle_color")
  fontFamily         String  @default("Arial, Helvetica, sans-serif") @map("font_family")

  // Visibilidade dos campos
  showPhoto           Boolean @default(true) @map("show_photo")
  showName            Boolean @default(true) @map("show_name")
  showArea            Boolean @default(true) @map("show_area")
  showPhone           Boolean @default(true) @map("show_phone")
  showAddress         Boolean @default(true) @map("show_address")
  showSite            Boolean @default(true) @map("show_site")
  showInstagram       Boolean @default(true) @map("show_instagram")
  showLogo            Boolean @default(true) @map("show_logo")
  /// Quando false, a célula esquerda (da foto) renderiza com fundo branco
  /// em vez de herdar o background do template — útil pra "isolar" a foto
  /// quando o fundo do template é uma imagem decorativa.
  showPhotoBackground Boolean @default(true) @map("show_photo_background")
  /// Quando false, as linhas de contato (telefone/endereço/site/instagram)
  /// não renderizam os ícones unicode (☎ ⚑ 🌐 📷).
  showIcons           Boolean @default(true) @map("show_icons")

  // Modo HTML avançado
  customHtmlEnabled Boolean @default(false) @map("custom_html_enabled")
  customHtml        String? @map("custom_html") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("empresa_signature_templates")
}

model EmpresaEvent {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  userId    String?  @map("user_id")
  type      String
  version   Int
  changes   Json?
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("empresa_events")
}

// ============================================================
// Permissões de Usuário por Módulo
// ============================================================

model UserPermission {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  moduleSlug     String   @map("module_slug")
  canRead        Boolean  @default(true) @map("can_read")
  canWrite       Boolean  @default(false) @map("can_write")
  canDelete      Boolean  @default(false) @map("can_delete")
  subPermissions Json?    @default("{}") @map("sub_permissions")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleSlug])
  @@map("user_permissions")
}

// ============================================================
// Módulo Cadastros — Clientes
// ============================================================

enum ClienteSituacao {
  MENSAL
  EM_CONSTITUICAO
  POTENCIAL
  AVULSO
  PARALIZADO
  PRE_OPERACIONAL
  PROSPECT
}

enum ClienteStatus {
  ATIVA
  INATIVA
  SUSPENSA
  BAIXADA
  INAPTA
  NULA
}

enum TipoDocumento {
  CNPJ
  CPF
}

enum RegimeContabil {
  CAIXA
  COMPETENCIA
}

model Cliente {
  id   String @id @default(cuid())
  code Int    @default(autoincrement())

  // Identificação
  razaoSocial   String        @map("razao_social")
  nomeFantasia  String?       @map("nome_fantasia")
  documento     String
  tipoDocumento TipoDocumento @default(CNPJ) @map("tipo_documento")
  tipoCliente   String?       @map("tipo_cliente")
  logoUrl       String?       @map("logo_url")

  // Integração
  idSistema      String? @map("id_sistema")
  idOmie         String? @map("id_omie")
  omieEmpresa    String? @map("omie_empresa")
  idOneClick     String? @map("id_oneclick")
  /// ID interno do cliente no Acessórias (campo `ID` em /companies/ListAll).
  /// Resolvido na 1ª sincronização e cacheado pra acessos rápidos posteriores.
  idAcessorias   Int?    @map("id_acessorias")
  /// CNPJ no Acessórias quando diferir do nosso (raro mas possível —
  /// ex: cliente migrou de filial, CNPJ antigo persistiu no Acessórias).
  cnpjAcessorias String? @map("cnpj_acessorias")

  // Alertas
  alertaProcuracao   Boolean   @default(false) @map("alerta_procuracao")
  alertaProcuracaoEm DateTime? @map("alerta_procuracao_em")

  // Comercial
  situacao    ClienteSituacao @default(MENSAL)
  status      ClienteStatus   @default(ATIVA)
  grupo       String?
  categoria   String?         @default("NAO_INFORMADO")
  origem      String?
  dataEntrada DateTime?       @map("data_entrada")
  dataSaida   DateTime?       @map("data_saida")
  observacoes String?         @db.Text

  // Fiscal
  tributacao         TaxRegime?
  regime             RegimeContabil?
  inscricaoEstadual  String?         @map("inscricao_estadual")
  inscricaoMunicipal String?         @map("inscricao_municipal")

  // Áreas contratadas (semicolon-separated: "Contabil;Fiscal;Trabalhista")
  areasContratadas String? @map("areas_contratadas") @db.Text

  // Legalização
  nire                String?
  rgEdificacao        String? @map("rg_edificacao")
  codigoSimples       String? @map("codigo_simples")
  bombeirosOcupacao   String? @map("bombeiros_ocupacao")
  bombeirosMetragem   String? @map("bombeiros_metragem")
  bombeirosRota       String? @map("bombeiros_rota")
  bombeirosProjeto    String? @map("bombeiros_projeto")
  bombeirosCapacidade String? @map("bombeiros_capacidade")
  cnaePrincipal       String? @map("cnae_principal")

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String? @db.Char(2)

  // Contato
  telefone String?
  email    String?

  // Multi-empresa
  empresaId String? @map("empresa_id")

  // CRM
  isLead Boolean @default(false) @map("is_lead")

  // Google Drive — pasta vinculada do cliente para ingestão automática de XML
  driveFolderId   String?   @map("drive_folder_id")
  driveFolderName String?   @map("drive_folder_name")
  driveSyncToken  String?   @map("drive_sync_token")
  driveSyncedAt   DateTime? @map("drive_synced_at")
  driveSyncStatus String?   @map("drive_sync_status") // ok | erro | nunca

  // Pasta local (PC do escritório) — monitorada pelo Launcher Electron via chokidar.
  // O caminho é interpretado pelo daemon local, não pela API. UI só persiste o valor.
  localFolderPath      String?   @map("local_folder_path")
  localSyncEnabled     Boolean   @default(false) @map("local_sync_enabled")
  localSyncedAt        DateTime? @map("local_synced_at")
  localSyncStatus      String?   @map("local_sync_status") // ok | erro | nunca | aguardando_daemon | monitorando
  /// Flag de "sync manual solicitada" — daemon detecta e faz scan completo. Limpa após processar.
  localSyncRequestedAt DateTime? @map("local_sync_requested_at")

  // NFe SEFAZ (NFeDistribuicaoDFe) — entradas de mercadorias via web service oficial
  nfeDistEnabled         Boolean             @default(false) @map("nfe_dist_enabled")
  nfeDistUltimoNsu       BigInt?             @map("nfe_dist_ultimo_nsu")
  nfeDistSyncedAt        DateTime?           @map("nfe_dist_synced_at")
  nfeDistSyncStatus      String?             @map("nfe_dist_sync_status") // ok | erro | nunca | aguardando
  nfeDistSyncRequestedAt DateTime?           @map("nfe_dist_sync_requested_at")
  nfeDistCertificadoId   String?             @map("nfe_dist_certificado_id")
  nfeDistCertificado     CertificadoDigital? @relation("ClienteNFeDistCert", fields: [nfeDistCertificadoId], references: [id], onDelete: SetNull)
  /// Progresso em tempo real durante sync NFe SEFAZ — `{ etapa, mensagem, atual, total, pct }`
  nfeDistProgresso       Json?               @map("nfe_dist_progresso")

  // NFS-e Nacional (ADN) — entradas de serviços via REST com mTLS
  nfseDistEnabled         Boolean             @default(false) @map("nfse_dist_enabled")
  nfseDistUltimoNsu       BigInt?             @map("nfse_dist_ultimo_nsu")
  nfseDistSyncedAt        DateTime?           @map("nfse_dist_synced_at")
  nfseDistSyncStatus      String?             @map("nfse_dist_sync_status")
  nfseDistSyncRequestedAt DateTime?           @map("nfse_dist_sync_requested_at")
  nfseDistCertificadoId   String?             @map("nfse_dist_certificado_id")
  nfseDistCertificado     CertificadoDigital? @relation("ClienteNFSeDistCert", fields: [nfseDistCertificadoId], references: [id], onDelete: SetNull)
  /// Progresso em tempo real durante sync NFS-e Nacional
  nfseDistProgresso       Json?               @map("nfse_dist_progresso")

  // Versionamento (ISO 9001)
  version   Int       @default(1)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  empresa              Empresa?                @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  socios               Socio[]
  situacoesFiscais     SituacaoFiscal[]
  events               ClienteEvent[]
  arquivos             ClienteArquivo[]
  contatos             ClienteContato[]
  contratoParams       ClienteContratoParam[]
  erpSnapshots         ClienteErpSnapshot[]
  biCategorias         ClienteBiCategoria[]
  biLinhas             ClienteBiLinha[]
  biLinks              ClienteBiLink[]
  biCacheFaturamento   BiCacheFaturamento[]
  biCacheBalancete     BiCacheBalancete[]
  biKpiContasIgnoradas BiKpiContaIgnorada[]
  biKpiRegrasCalculo   BiKpiRegraCalculo[]
  historicos           ClienteHistorico[]
  servicosContratados  ClienteAreaContratada[]
  folhaFiliais         FolhaFilial[]
  folhaEventoContas    FolhaEventoConta[]
  folhaImportacoes     FolhaImportacao[]
  contratos            Contrato[]
  servicoExecucoes     ServicoExecucao[]       @relation("ClienteServicoExecucoes")
  certificadosDigitais CertificadoDigital[]
  processos            Processo[]              @relation("ClienteProcessos")
  obrigacoes           ClienteObrigacao[]
  ativos               Ativo[]                 @relation("AtivoCliente")
  driveSyncLogs        DriveSyncLog[]
  driveSyncedFiles     DriveSyncedFile[]
  danfes               Danfe[]                 @relation("ClienteDanfes")
  notasServico         NotaServicoImportada[]  @relation("ClienteNotasServico")

  @@map("clientes")
}

// Drive Sync — rastreia cada arquivo já processado (dedup por file_id + sha256)
model DriveSyncedFile {
  id           String   @id @default(cuid())
  clienteId    String   @map("cliente_id")
  fileId       String   @map("file_id") // Drive file ID — estável
  sha256       String // hash do conteúdo
  fileName     String?  @map("file_name")
  pathDrive    String?  @map("path_drive") // caminho relativo dentro da pasta
  processadoEm DateTime @default(now()) @map("processado_em")
  status       String // ok | duplicado | ignorado | erro
  tipoIgnorado String?  @map("tipo_ignorado") // cce | cancelamento | inutilizacao | evento | nao_nfe
  danfeId      String?  @map("danfe_id")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  danfe   Danfe?  @relation(fields: [danfeId], references: [id], onDelete: SetNull)

  @@unique([clienteId, fileId])
  @@index([clienteId, sha256])
  @@map("drive_synced_files")
}

// Drive Sync — log de cada execução de sincronização da pasta do cliente
model DriveSyncLog {
  id                String    @id @default(cuid())
  clienteId         String    @map("cliente_id")
  /// Origem da sync: automatico | manual | local_auto | local_manual | nfe-sefaz | nfse-nacional
  tipo              String    @default("automatico")
  iniciadoPor       String?   @map("iniciado_por") // userId (se manual)
  iniciadoEm        DateTime  @default(now()) @map("iniciado_em")
  finalizadoEm      DateTime? @map("finalizado_em")
  status            String    @default("running") // running | completed | error
  arquivosVistos    Int       @default(0) @map("arquivos_vistos")
  arquivosNovos     Int       @default(0) @map("arquivos_novos")
  arquivosOk        Int       @default(0) @map("arquivos_ok")
  arquivosErro      Int       @default(0) @map("arquivos_erro")
  arquivosIgnorados Int       @default(0) @map("arquivos_ignorados")
  erroMensagem      String?   @map("erro_mensagem") @db.Text
  /// JSON: [{ nome, fileId, status: 'ok'|'erro'|'duplicado', danfeId?, erro? }]
  itens             Json      @default("[]")
  /// Progresso em tempo real (polling): { atual, total, nome, etapa }
  progresso         Json?
  /// Logs antigos vão sendo arquivados quando passam de 10 ativos por cliente.
  /// Mantém histórico no banco mas some do painel "Últimas sincronizações".
  arquivado         Boolean   @default(false)

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, iniciadoEm(sort: Desc)])
  @@index([clienteId, arquivado, iniciadoEm(sort: Desc)])
  @@map("drive_sync_logs")
}

// Arquivos do Cliente
