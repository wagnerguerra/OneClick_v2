  nivel1        String?
  nivel2        String?
  nivel3        String?
  nivel4        String?
  nivel5        String? // nome curto da conta (ex: "Salários")
  categoriaDre  String   @map("categoria_dre")
  sinal         Int // 1 ou -1
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([categoriaDre])
  @@map("plano_contas_categoria_padrao")
}

