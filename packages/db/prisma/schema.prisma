  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, conta])
  @@index([clienteId])
  @@index([categoriaDre])
  @@map("cliente_bi_categorias")
}

// Template global SERPRO2 — mapeamento padrão de classificação contábil
// para categoria de DRE + sinal. Replica o dPlano de Contas do PowerBI.
// Cada cliente pode sobrescrever via ClienteBiCategoria.
model PlanoContasCategoriaPadrao {
