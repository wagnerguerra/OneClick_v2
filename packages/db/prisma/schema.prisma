generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Multi-tenancy: schema public — dados globais
// ============================================================

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Tenant {
  id                String       @id @default(cuid())
  name              String
  slug              String       @unique
  schema            String       @unique // nome do schema no Postgres: tenant_<id>
  status            TenantStatus @default(ACTIVE)
  stripeCustomerId  String?      @unique @map("stripe_customer_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  users         User[]
  subscriptions Subscription[]

  @@map("tenants")
}

// ============================================================
// Planos e assinaturas (Stripe)
// ============================================================

enum PlanInterval {
  MONTHLY
  YEARLY
}

model Plan {
  id             String       @id @default(cuid())
  name           String
  description    String?
  stripePriceId  String       @unique @map("stripe_price_id")
  interval       PlanInterval @default(MONTHLY)
  price          Int          // valor em centavos
  features       Json         @default("[]")
  maxUsers       Int          @default(5) @map("max_users")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @map("tenant_id")
  planId               String             @map("plan_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripeCustomerId     String             @map("stripe_customer_id")
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// ============================================================
// Usuários e autenticação (Better Auth)
// ============================================================

enum Role {
  COLABORADOR_INTERNO
  PRESTADOR_SERVICO
  COLABORADOR_CLIENTE
  GESTOR
  COORDENADOR
  DIRETOR
}

enum UserProfile {
  OPERADOR
  SUPERVISOR
  GERENTE
  ADMIN
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  emailVerified Boolean     @default(false) @map("email_verified")
  image         String?
  role          Role        @default(COLABORADOR_INTERNO)
  profile       UserProfile @default(OPERADOR)
  isMaster          Boolean     @default(false) @map("is_master")
  isEmpresaMaster   Boolean     @default(false) @map("is_empresa_master")
  isActive      Boolean     @default(true) @map("is_active")
  tenantId      String?     @map("tenant_id")
  empresaId     String?     @map("empresa_id")

  // Contato
  telefone      String?

  // Dados Organizacionais
  areaId        String?     @map("area_id")
  cargoId       String?     @map("cargo_id")
  salario       Decimal?    @db.Decimal(10, 2)

  // Férias (RH)
  dataAdmissao  DateTime?   @map("data_admissao")
  idOneClick    String?     @map("id_oneclick")
  incluirFerias Boolean     @default(true) @map("incluir_ferias")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  empresa     Empresa?         @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  area        Area?            @relation("UserArea", fields: [areaId], references: [id], onDelete: SetNull)
  cargo       Cargo?           @relation(fields: [cargoId], references: [id], onDelete: SetNull)
  sessions    Session[]
  accounts    Account[]
  ledAreas    Area[]
  permissions UserPermission[]
  cargoEvents      CargoEvent[]
  empresaEvents    EmpresaEvent[]
  clienteEvents    ClienteEvent[]
  clienteArquivos      ClienteArquivo[]
  clienteHistoricos    ClienteHistorico[]
  colaboradores        Colaborador[]
  colaboradorEvents    ColaboradorEvent[]
  fornecedorEvents     FornecedorEvent[]
  socioEvents          SocioEvent[]
  socioArquivos        SocioArquivo[]
  socioMensagens       SocioMensagem[]
  situacoesFiscais     SituacaoFiscal[]
  caixaPostalItems          CaixaPostalItem[]     @relation("CaixaPostalLeitora")
  caixaPostalResponsavel    CaixaPostalItem[]     @relation("CaixaPostalResponsavel")
  caixaPostalRegras         CaixaPostalRegra[]
  caixaPostalEventLogs      CaixaPostalEventLog[]
  responsavelAreas     ClienteAreaContratada[] @relation("AreaResponsavel")
  substitutoAreas      ClienteAreaContratada[] @relation("AreaSubstituto")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  accountId         String   @map("account_id")
  providerId        String   @map("provider_id")
  accessToken       String?  @map("access_token")
  refreshToken      String?  @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope             String?
  idToken           String?  @map("id_token")
  password          String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

// ============================================================
// Módulo Cadastros — Áreas
// ============================================================

enum CostType {
  DIRECT
  INDIRECT
}

model Area {
  id                 String   @id @default(cuid())
  code               Int      @default(autoincrement())
  name               String
  isActive           Boolean  @default(true) @map("is_active")
  empresaId          String?  @map("empresa_id")

  // Visibilidade e Contratação
  availableForHiring Boolean  @default(false) @map("available_for_hiring")
  showInOrgChart     Boolean  @default(false) @map("show_in_org_chart")

  // Contato e Hierarquia
  email              String?
  leaderId           String?  @map("leader_id")
  parentId           String?  @map("parent_id")

  // Custeio por Cliente
  costType           CostType @default(DIRECT) @map("cost_type")
  costWeight         Decimal  @default(1) @map("cost_weight") @db.Decimal(10, 4)
  excludeFromCosting Boolean  @default(false) @map("exclude_from_costing")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  empresa         Empresa?         @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  parent          Area?            @relation("AreaHierarchy", fields: [parentId], references: [id])
  children        Area[]           @relation("AreaHierarchy")
  leader          User?            @relation(fields: [leaderId], references: [id])
  users           User[]           @relation("UserArea")
  cargos          Cargo[]
  colaboradores   Colaborador[]
  clienteContatos      ClienteContato[]
  clienteAreas         ClienteAreaContratada[]

  @@map("areas")
}

// ============================================================
// Módulo Cadastros — Cargos
// ============================================================

model Cargo {
  id                String   @id @default(cuid())
  code              Int      @default(autoincrement())
  name              String
  isActive          Boolean  @default(true) @map("is_active")
  empresaId         String?  @map("empresa_id")
  areaId            String?  @map("area_id")
  showInOrgChart    Boolean  @default(false) @map("show_in_org_chart")

  // Campos descritivos (rich text — HTML)
  descricaoSumaria  String?  @map("descricao_sumaria") @db.Text
  responsabilidades String?  @db.Text
  habilidades       String?  @db.Text
  autoridades       String?  @db.Text
  experiencias      String?  @db.Text
  treinamentos      String?  @db.Text
  educacao          String?  @db.Text

  // Versionamento (ISO 9001)
  version           Int      @default(1)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  empresa       Empresa?       @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  area          Area?          @relation(fields: [areaId], references: [id], onDelete: SetNull)
  users         User[]
  colaboradores Colaborador[]
  events        CargoEvent[]

  @@map("cargos")
}

// ============================================================
// Log de Eventos — Cargos (Auditoria ISO 9001)
// ============================================================

model CargoEvent {
  id        String   @id @default(cuid())
  cargoId   String   @map("cargo_id")
  userId    String?  @map("user_id")
  type      String   // "created", "updated", "deleted"
  version   Int      // Versão no momento do evento
  changes   Json?    // { campo: { from: "antigo", to: "novo" } }
  createdAt DateTime @default(now()) @map("created_at")

  cargo Cargo @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("cargo_events")
}

// ============================================================
// Módulo Cadastros — Empresas
// ============================================================

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
  IMUNE
  ISENTA
}

model Empresa {
  id                  String     @id @default(cuid())
  code                Int        @default(autoincrement())

  // Dados Legais
  razaoSocial         String     @map("razao_social")
  nomeFantasia        String?    @map("nome_fantasia")
  cnpj                String     @unique
  inscricaoEstadual   String?    @map("inscricao_estadual")
  inscricaoMunicipal  String?    @map("inscricao_municipal")
  taxRegime           TaxRegime? @map("tax_regime")
  isActive            Boolean    @default(true) @map("is_active")

  // Endereço
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String?    @db.Char(2)

  // Contato
  telefone            String?
  email               String?
  site                String?

  // Logo
  logoUrl             String?    @map("logo_url")
  logoDarkUrl         String?    @map("logo_dark_url")

  // Versionamento (ISO 9001)
  version             Int        @default(1)

  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  users               User[]
  areas               Area[]
  cargos              Cargo[]
  clientes            Cliente[]
  colaboradores       Colaborador[]
  fornecedores        Fornecedor[]
  socios              Socio[]
  events              EmpresaEvent[]

  @@map("empresas")
}

model EmpresaEvent {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  userId    String?  @map("user_id")
  type      String
  version   Int
  changes   Json?
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("empresa_events")
}

// ============================================================
// Permissões de Usuário por Módulo
// ============================================================

model UserPermission {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  moduleSlug     String   @map("module_slug")
  canRead        Boolean  @default(true) @map("can_read")
  canWrite       Boolean  @default(false) @map("can_write")
  canDelete      Boolean  @default(false) @map("can_delete")
  subPermissions Json?    @default("{}") @map("sub_permissions")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleSlug])
  @@map("user_permissions")
}

// ============================================================
// Módulo Cadastros — Clientes
// ============================================================

enum ClienteSituacao {
  MENSAL
  EM_CONSTITUICAO
  POTENCIAL
  AVULSO
  PARALIZADO
  PRE_OPERACIONAL
  PROSPECT
}

enum ClienteStatus {
  ATIVA
  INATIVA
  SUSPENSA
  BAIXADA
  INAPTA
  NULA
}

enum TipoDocumento {
  CNPJ
  CPF
}

enum RegimeContabil {
  CAIXA
  COMPETENCIA
}

model Cliente {
  id                  String           @id @default(cuid())
  code                Int              @default(autoincrement())

  // Identificação
  razaoSocial         String           @map("razao_social")
  nomeFantasia        String?          @map("nome_fantasia")
  documento           String
  tipoDocumento       TipoDocumento    @default(CNPJ) @map("tipo_documento")
  tipoCliente         String?          @map("tipo_cliente")
  logoUrl             String?          @map("logo_url")

  // Integração
  idSistema           String?          @map("id_sistema")
  idOmie              String?          @map("id_omie")
  omieEmpresa         String?          @map("omie_empresa")
  idOneClick          String?          @map("id_oneclick")

  // Comercial
  situacao            ClienteSituacao  @default(MENSAL)
  status              ClienteStatus    @default(ATIVA)
  grupo               String?
  categoria           String?          @default("NAO_INFORMADO")
  origem              String?
  dataEntrada         DateTime?        @map("data_entrada")
  dataSaida           DateTime?        @map("data_saida")
  observacoes         String?          @db.Text

  // Fiscal
  tributacao          TaxRegime?
  regime              RegimeContabil?
  inscricaoEstadual   String?          @map("inscricao_estadual")
  inscricaoMunicipal  String?          @map("inscricao_municipal")

  // Áreas contratadas (semicolon-separated: "Contabil;Fiscal;Trabalhista")
  areasContratadas    String?          @map("areas_contratadas") @db.Text

  // Legalização
  nire                String?
  rgEdificacao        String?          @map("rg_edificacao")
  codigoSimples       String?          @map("codigo_simples")
  bombeirosOcupacao   String?          @map("bombeiros_ocupacao")
  bombeirosMetragem   String?          @map("bombeiros_metragem")
  bombeirosRota       String?          @map("bombeiros_rota")
  bombeirosProjeto    String?          @map("bombeiros_projeto")
  bombeirosCapacidade String?          @map("bombeiros_capacidade")
  cnaePrincipal       String?          @map("cnae_principal")

  // Endereço
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String?          @db.Char(2)

  // Contato
  telefone            String?
  email               String?

  // Multi-empresa
  empresaId           String?          @map("empresa_id")

  // CRM
  isLead              Boolean          @default(false) @map("is_lead")

  // Versionamento (ISO 9001)
  version             Int              @default(1)
  isActive            Boolean          @default(true) @map("is_active")
  deletedAt           DateTime?        @map("deleted_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  empresa             Empresa?         @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  socios              Socio[]
  situacoesFiscais    SituacaoFiscal[]
  events              ClienteEvent[]
  arquivos            ClienteArquivo[]
  contatos            ClienteContato[]
  contratoParams      ClienteContratoParam[]
  erpSnapshots        ClienteErpSnapshot[]
  biCategorias        ClienteBiCategoria[]
  biLinhas            ClienteBiLinha[]
  biLinks             ClienteBiLink[]
  biCacheFaturamento  BiCacheFaturamento[]
  biCacheBalancete    BiCacheBalancete[]
  biKpiContasIgnoradas BiKpiContaIgnorada[]
  biKpiRegrasCalculo  BiKpiRegraCalculo[]
  historicos          ClienteHistorico[]
  servicosContratados ClienteAreaContratada[]
  folhaFiliais        FolhaFilial[]
  folhaEventoContas   FolhaEventoConta[]
  folhaImportacoes    FolhaImportacao[]

  @@map("clientes")
}

// Arquivos do Cliente
model ClienteArquivo {
  id          String   @id @default(cuid())
  clienteId   String   @map("cliente_id")
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")
  vencimento  DateTime?
  userId      String?  @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("cliente_arquivos")
}

// Contatos do Cliente
model ClienteContato {
  id          String   @id @default(cuid())
  clienteId   String   @map("cliente_id")
  areaId      String?  @map("area_id")
  nome        String
  cargo       String?
  telefone    String?
  email       String?
  observacoes String?  @db.Text
  principal   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  area        Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)

  @@map("cliente_contatos")
}

// Parâmetros do Contrato do Cliente
model ClienteContratoParam {
  id            String   @id @default(cuid())
  clienteId     String   @map("cliente_id")
  empresaId     String?  @map("empresa_id")
  honorario     Float    @default(0)
  lancamentos   Int      @default(0)
  faturamento   Float    @default(0)
  nfEntrada     Int      @default(0) @map("nf_entrada")
  nfSaida       Int      @default(0) @map("nf_saida")
  nfPrestado    Int      @default(0) @map("nf_prestado")
  nfTomado      Int      @default(0) @map("nf_tomado")
  funcionarios  Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, empresaId])
  @@map("cliente_contrato_params")
}

// Snapshots mensais do ERP (SCI) por cliente
model ClienteErpSnapshot {
  id            String   @id @default(cuid())
  clienteId     String   @map("cliente_id")
  empresaId     String?  @map("empresa_id")
  mes           String                        // formato "YYYY-MM"
  indicador     String                        // "lancamentos", "nf_entrada", "faturamento", etc
  valor         Float    @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, empresaId, mes, indicador])
  @@index([clienteId, mes])
  @@map("cliente_erp_snapshots")
}

// Histórico comercial (chat de negociações)
model ClienteHistorico {
  id            String   @id @default(cuid())
  clienteId     String   @map("cliente_id")
  userId        String?  @map("user_id")
  mensagem      String   @db.Text
  tipo          String   @default("equipe")   // "equipe" | "cliente"
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("cliente_historicos")
}

// Log de Eventos — Clientes (Auditoria ISO 9001)
// ============================================================

model ClienteEvent {
  id        String   @id @default(cuid())
  clienteId String   @map("cliente_id")
  userId    String?  @map("user_id")
  type      String   // "created", "updated", "deleted"
  version   Int      // Versão no momento do evento
  changes   Json?    // { campo: { from: "antigo", to: "novo" } }
  createdAt DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("cliente_events")
}

// ============================================================
// ============================================================
// BI Balancete — Categorias, Linhas e Links Públicos
// ============================================================

model ClienteBiCategoria {
  id            String   @id @default(cuid())
  clienteId     String   @map("cliente_id")
  conta         String
  nomeSci       String   @default("") @map("nome_sci")
  nomeExibicao  String   @default("") @map("nome_exibicao")
  parentConta   String?  @map("parent_conta")
  nivel         Int      @default(1)
  ordem         Int      @default(0)
  tipo          String   @default("real") // real | calculada | referencia
  ativo         Boolean  @default(true)
  formula       Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, conta])
  @@index([clienteId])
  @@map("cliente_bi_categorias")
}

model ClienteBiLinha {
  id            String   @id @default(cuid())
  clienteId     String   @map("cliente_id")
  periodo       String   // AAAAMM
  conta         String
  nomeConta     String   @default("") @map("nome_conta")
  saldoAnterior Decimal  @default(0) @map("saldo_anterior") @db.Decimal(18, 2)
  debitos       Decimal  @default(0) @db.Decimal(18, 2)
  creditos      Decimal  @default(0) @db.Decimal(18, 2)
  saldoAtual    Decimal  @default(0) @map("saldo_atual") @db.Decimal(18, 2)
  movimento     Decimal  @default(0) @db.Decimal(18, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, periodo, conta])
  @@index([clienteId, periodo])
  @@map("cliente_bi_linhas")
}

model ClienteBiLink {
  id        String    @id @default(cuid())
  clienteId String    @unique @map("cliente_id")
  token     String    @unique
  expiraEm  DateTime? @map("expira_em")
  createdAt DateTime  @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("cliente_bi_links")
}

