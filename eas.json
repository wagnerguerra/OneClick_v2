{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.0.58:4000",
        "npm_config_virtual_store_dir": "node_modules/.pnpm",
        "npm_config_virtual_store_dir_max_length": "120",
        "npm_config_frozen_lockfile": "false"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://app.oneclick.central-rnc.com.br",
        "npm_config_virtual_store_dir": "node_modules/.pnpm",
        "npm_config_virtual_store_dir_max_length": "120",
        "npm_config_frozen_lockfile": "false"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lint -x lintVitalRelease"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://app.oneclick.central-rnc.com.br",
        "npm_config_virtual_store_dir": "node_modules/.pnpm",
        "npm_config_virtual_store_dir_max_length": "120",
        "npm_config_frozen_lockfile": "false"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
