{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "App.tsx",
    "src/components",
    "src/lib",
    "app-env.d.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "src/app"
  ]
}
