# node_modules FLAT dentro do projeto (hardlinks do store global) — recomendado
# pelo Expo p/ monorepos pnpm. Resolve de uma vez:
#   - phantom deps (Expo/Metro fazem require bare de transitivas)
#   - resolução do Metro (tudo fica dentro do projeto/watchFolders)
#   - path curto p/ build nativo (sem o .pnpm-store profundo)
node-linker=hoisted
store-dir=D:\.pnpm-store
