# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# APKs/AABs de distribuição (vão pra VPS via scp, não pro git)
scripts/mobile-dist/*.apk
scripts/mobile-dist/*.aab

# Expo
.expo/
dist/
dist-web/
.smoke/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
# Credenciais de assinatura (NUNCA commitar — fazer backup à parte)
credentials.json
credentials/
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

# pasta de materiais soltos (não faz parte do build do app)
/materiais
