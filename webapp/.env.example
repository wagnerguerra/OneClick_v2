# Copie este arquivo para .env (na raiz webapp/) e preencha os valores.
# .env esta no .gitignore — nao sera commitado.
#
# Este e o UNICO arquivo de variaveis de ambiente do monorepo.
# Todos os modulos (API, workers, docker-compose) leem dele:
#   - API e workers Node sobem o diretorio procurando .env (loadDotenvFromUpwards)
#   - START.bat carrega no processo antes de subir o stack
#   - docker-compose.yml interpola ${VAR} a partir do shell

# ── Chaves externas ──────────────────────────────────────────────────────
# Comparador NFS-e (engines/comparacao-nfse) — Gemini para OCR de PDFs/imagens.
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional: pinar versao do modelo. Default: gemini-flash-latest (auto-atualiza).
# Outras opcoes: gemini-2.5-flash, gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-flash
# Opcional: chamadas Gemini em paralelo (default 8). Aumente em paid tier;
# diminua para nao estourar rate limit do free tier (15 RPM).
# NFSE_OCR_CONCURRENCY=8
# Opcional: threads pra extracao local com pdfplumber (default 8).
# NFSE_LOCAL_CONCURRENCY=8
# Knobs do worker Node de NFS-e (apps/worker-comparacao-nfse):
# Quantos jobs em paralelo o worker processa (default 4, max 16).
# NFSE_WORKER_CONCURRENCY=4
# Limite de chamadas Gemini por minuto, token bucket compartilhado (default 1500).
# NFSE_GEMINI_RPM=1500
# Tempo (segundos) que o circuit fica aberto apos detectar quota (default 300).
# NFSE_CIRCUIT_COOLDOWN_SEC=300

# ── API ──────────────────────────────────────────────────────────────────
# Obrigatorio. Minimo 16 caracteres. NUNCA use o valor abaixo em producao.
# Gere um forte com: openssl rand -base64 48
# (em PowerShell:  [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(48)))
JWT_SECRET=troque-este-segredo-minimo-16chars
# Opcionais (com defaults sensatos):
# PORT=8000
# REDIS_URL=redis://127.0.0.1:6381
# TEMP_JOBS_ROOT=./temp_jobs
# ALLOWED_ORIGINS=http://localhost:5176,http://192.168.0.47:5176
# MAX_UPLOAD_MB=50
# MAX_XML_FILES=5000
# MAX_UPLOAD_NFSE_MB=300
# SQLite do cadastro de clientes/fornecedores (Editor de Extrato). Em Docker o
# compose ja aponta para o volume persistente /data/extrato. Em dev local o
# default e ./data/extrato/extrato.db (relativo ao cwd da API = webapp-01).
# EXTRATO_DB_PATH=./data/extrato/extrato.db

# ── Frontend (Vite) ──────────────────────────────────────────────────────
# Em dev, o Vite faz proxy de /api para a API. Variaveis VITE_* sao
# injetadas no bundle (publicas) — nunca coloque segredos aqui.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000   # alvo do proxy (so dev)
# VITE_API_URL=http://192.168.0.47:8000          # URL absoluta (sem proxy)

# ── Workers (Python bridges) ─────────────────────────────────────────────
# Por padrao apontam para engines/<nome>. So preencha se voce moveu os modulos
# para outro lugar. (Caminhos relativos ao cwd do worker = webapp-01.)
# PYTHON_CMD=py            # Windows: py | Linux/macOS: python3
# SPED_ENGINE_DIR=../engines/sped/sped_engine
# SPED_MERGE_DIR=../engines/sped-merge
# SCI_CONSOLIDADO_PY_DIR=../engines/sci-consolidado
# COMPARACAO_PY_DIR=../engines/comparacao-planilhas
# COMPARACAO_NFSE_PY_DIR=../engines/comparacao-nfse
# GNRE_PY_DIR=../engines/gnre
# SCI_PORTAL_DIR=../engines/sci-portal-nacional   # engine do Conciliador NFS-e (TS puro)
# WORKER_XML_CHUNK=100
# SQLite com dedupe persistente do Extrator GNRE. Em Docker o compose ja aponta
# para o volume gnre-data (/data/gnre/gnre.db). Default local: <GNRE_PY_DIR>/data/gnre.db
# GNRE_DB_PATH=../engines/gnre/data/gnre.db
