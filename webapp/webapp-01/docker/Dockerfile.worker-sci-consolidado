# Build a partir da pasta pai (webapp-01 e engines/sci-consolidado lado a lado):
# docker compose build worker-sci-consolidado
FROM node:22-bookworm-slim AS build-js
WORKDIR /workspace/webapp-01
COPY webapp-01/package.json webapp-01/package-lock.json ./
COPY webapp-01/tsconfig.base.json ./
COPY webapp-01/packages ./packages
COPY webapp-01/apps ./apps
COPY webapp-01/frontend ./frontend
RUN npm ci --workspaces --include-workspace-root 2>/dev/null || npm install --workspaces --include-workspace-root
RUN npm run build -w @webapp/contracts && npm run build -w @webapp/worker-sci-consolidado

FROM node:22-bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-venv \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=build-js /workspace/webapp-01/package.json ./
COPY --from=build-js /workspace/webapp-01/node_modules ./node_modules
COPY --from=build-js /workspace/webapp-01/packages ./packages
COPY --from=build-js /workspace/webapp-01/apps/worker-sci-consolidado ./apps/worker-sci-consolidado
COPY engines/sci-consolidado /app/engines/sci-consolidado
RUN python3 -m venv /opt/sci \
  && /opt/sci/bin/pip install --no-cache-dir -r /app/engines/sci-consolidado/requirements.txt
ENV NODE_ENV=production
ENV SCI_CONSOLIDADO_PY_DIR=/app/engines/sci-consolidado
ENV PYTHON_CMD=/opt/sci/bin/python
CMD ["node", "apps/worker-sci-consolidado/dist/index.js"]
