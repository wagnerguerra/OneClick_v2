{
  "expo": {
    "name": "OneClick ERP",
    "slug": "oneclick-erp",
    "owner": "oneclick_v2",
    "version": "1.2.18",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "oneclick",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.oneclick.erp.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.oneclick.erp.mobile",
      "versionCode": 19,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f1729",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "android": {
            "backgroundColor": "#0f1729",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0ea5e9"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "31e11c47-1d43-40dc-83fd-a4ab17985b35"
      }
    }
  }
}
